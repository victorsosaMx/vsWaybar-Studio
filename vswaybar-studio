    def _build_user_module_form(self, mod: str, source_cfg: dict = None) -> Gtk.Widget:
        """Form for a user-defined custom module — Launcher or GTK Menu mode."""
        if source_cfg is None:
            source_cfg = self._cfg
        suffix = mod[7:]
        cfg    = source_cfg.setdefault(mod, {})
        fields = self._w.setdefault("mod_fields", {})

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_margin_start(20); outer.set_margin_end(20)
        outer.set_margin_top(14);   outer.set_margin_bottom(14)

        outer.pack_start(_section(f"custom/{suffix}"), False, False, 0)
        ctx = "Dock app" if (source_cfg is not None and source_cfg is not self._cfg) else "Waybar key"
        outer.pack_start(_hint(f"{ctx}: custom/{suffix}"), False, False, 4)

        # ── Glyph picker ──────────────────────────────────────────────────────
        outer.pack_start(_lbl("Icon", "field-label"), False, False, 8)

        current_glyph = cfg.get("format", "󰘳")

        pick_btn = Gtk.Button()
        pick_btn.get_style_context().add_class("open-btn")
        pick_btn.set_halign(Gtk.Align.START)
        btn_lbl = Gtk.Label()
        btn_lbl.set_markup(
            f"<span font_desc='JetBrainsMono Nerd Font Mono 28'>{current_glyph}</span>"
            "   Pick icon…")
        btn_lbl.show()
        pick_btn.add(btn_lbl)

        def _open_glyph_picker(_b):
            sel = self._glyph_picker_dialog(cfg.get("format", "󰘳"))
            if sel:
                cfg["format"] = sel
                btn_lbl.set_markup(
                    f"<span font_desc='JetBrainsMono Nerd Font Mono 28'>{sel}</span>"
                    "   Pick icon…")
                store = self._w.get("user_mod_store")
                if store:
                    for row in store:
                        if row[0] == mod:
                            row[1] = f"{sel}  {suffix}"
                            break
                self._refresh_preview()

        pick_btn.connect("clicked", _open_glyph_picker)
        outer.pack_start(pick_btn, False, False, 8)

        # ── Color ─────────────────────────────────────────────────────────────
        outer.pack_start(_lbl("Color", "field-label"), False, False, 8)
        color_row = Gtk.Box(spacing=8)
        hex_val   = cfg.get("_color", "#a6adc8")
        cbtn      = _color_btn(hex_val)
        hex_entry = Gtk.Entry()
        hex_entry.set_text(hex_val)
        hex_entry.set_max_length(7)
        hex_entry.set_width_chars(9)
        fields["_color_hex"] = hex_entry

        def _on_color(b, e=hex_entry):
            h = _rgba_to_hex(b.get_rgba())
            e.set_text(h)
            cfg["_color"] = h
            self._refresh_preview()

        def _on_hex(e, b=cbtn):
            val = e.get_text().strip()
            if re.match(r'^#[0-9a-fA-F]{6}$', val):
                b.set_rgba(_hex_to_rgba(val))
                cfg["_color"] = val.lower()
                self._refresh_preview()

        cbtn.connect("color-set", _on_color)
        hex_entry.connect("changed", _on_hex)
        color_row.pack_start(cbtn,      False, False, 0)
        color_row.pack_start(hex_entry, False, False, 0)
        outer.pack_start(color_row, False, False, 8)

        pill_row_u, pill_sw_u = _switch_row("Pill style (invert colors)", bool(cfg.get("_inverted", False)))
        pill_sw_u.set_tooltip_text("Swap: use the module color as background with base color text")
        pill_sw_u.connect("notify::active", lambda *_: self._refresh_preview())
        fields["_inverted"] = pill_sw_u
        outer.pack_start(pill_row_u, False, False, 0)
        outer.pack_start(_hint("Background = icon color, text = @base"), False, False, 4)

        # ── Mode: Launcher / Menu ─────────────────────────────────────────────
        outer.pack_start(_section("Mode"), False, False, 0)

        is_menu_mode = cfg.get("_menu_mode", False)

        mode_box = Gtk.Box(spacing=0)
        mode_box.get_style_context().add_class("linked")
        btn_launcher = Gtk.ToggleButton(label="  Launcher")
        btn_menu_m   = Gtk.ToggleButton(label="󰍜  Popup menu")
        btn_launcher.set_active(not is_menu_mode)
        btn_menu_m.set_active(is_menu_mode)
        mode_box.pack_start(btn_launcher, True, True, 0)
        mode_box.pack_start(btn_menu_m,   True, True, 0)
        outer.pack_start(mode_box, False, False, 6)

        # Contenedores intercambiables
        launcher_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        menu_box     = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)

        # ── Launcher panel ────────────────────────────────────────────────────
        oc_e = Gtk.Entry()
        oc_e.set_text(cfg.get("on-click", ""))
        oc_e.set_placeholder_text("firefox, kitty, code…")
        fields["on-click"] = oc_e
        launcher_box.pack_start(_lbl("On click", "field-label"), False, False, 8)
        launcher_box.pack_start(oc_e, False, False, 0)
        launcher_box.pack_start(_hint("Waybar shows the icon — click runs this command."), False, False, 4)

        tt_e = Gtk.Entry()
        tt_e.set_text(cfg.get("tooltip-format", ""))
        tt_e.set_placeholder_text("Optional text on hover")
        fields["tooltip-format"] = tt_e
        launcher_box.pack_start(_lbl("Tooltip", "field-label"), False, False, 8)
        launcher_box.pack_start(tt_e, False, False, 0)

        # ── Popup menu panel ──────────────────────────────────────────────────
        menu_box.pack_start(_section("Menu settings"), False, False, 0)

        # Trigger
        trigger_combo = Gtk.ComboBoxText()
        for t in ("on-click", "on-right-click", "on-middle-click",
                  "on-scroll-up", "on-scroll-down"):
            trigger_combo.append_text(t)
        cur_trigger = cfg.get("menu", "on-click")
        _triggers = ["on-click", "on-right-click", "on-middle-click",
                     "on-scroll-up", "on-scroll-down"]
        trigger_combo.set_active(_triggers.index(cur_trigger)
                                 if cur_trigger in _triggers else 0)
        self._w["_menu_trigger"] = trigger_combo
        menu_box.pack_start(_row("Trigger", trigger_combo), False, False, 0)

        # Archivo XML
        default_xml = os.path.expanduser(
            f"~/.config/waybar/{suffix}_menu.xml")
        xml_entry = Gtk.Entry()
        xml_entry.set_text(cfg.get("menu-file", default_xml))
        xml_entry.set_placeholder_text(default_xml)
        self._w["_menu_file_entry"] = xml_entry
        menu_box.pack_start(_row("XML file", xml_entry), False, False, 0)
        menu_box.pack_start(_hint("The file is generated automatically on apply."), False, False, 2)

        # ── Item list (flat) ──────────────────────────────────────────────────
        menu_box.pack_start(_section("Menu items"), False, False, 0)

        # store: (type, label, id, command)  — type: 'item' | 'separator'
        item_store = Gtk.ListStore(str, str, str, str)
        self._w["_menu_store"] = item_store

        # Cargar desde XML existente o desde cfg guardado
        xml_path = cfg.get("menu-file", default_xml)
        existing_actions = cfg.get("menu-actions", {})
        existing_rows = []
        if os.path.isfile(os.path.expanduser(xml_path)):
            existing_rows = _parse_menu_xml(xml_path, existing_actions)
        elif "_menu_rows" in cfg:
            existing_rows = [r for r in cfg["_menu_rows"]
                             if r[0] in ("item", "separator")]

        for row in existing_rows:
            item_store.append(list(row))

        # TreeView
        tv = Gtk.TreeView(model=item_store)
        tv.set_headers_visible(True)
        tv.set_reorderable(False)
        tv.set_activate_on_single_click(True)
        tv.set_size_request(-1, 180)

        def _type_icon(col, cell, model, it, *_):
            cell.set_property("text",
                "●" if model[it][0] == "item" else "─")

        cr_type = Gtk.CellRendererText()
        cr_type.set_property("foreground", self._theme.get("dim", "#888"))
        col_type = Gtk.TreeViewColumn("", cr_type)
        col_type.set_cell_data_func(cr_type, _type_icon)
        col_type.set_min_width(24)
        tv.append_column(col_type)

        cr_label = Gtk.CellRendererText()
        cr_label.set_property("editable", True)
        col_label = Gtk.TreeViewColumn("Label", cr_label, text=1)
        col_label.set_expand(True)
        tv.append_column(col_label)

        cr_cmd = Gtk.CellRendererText()
        cr_cmd.set_property("editable", True)
        cr_cmd.set_property("ellipsize", Pango.EllipsizeMode.END)
        col_cmd = Gtk.TreeViewColumn("Command", cr_cmd, text=3)
        col_cmd.set_expand(True)
        tv.append_column(col_cmd)

        tv_sw = Gtk.ScrolledWindow()
        tv_sw.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        tv_sw.set_size_request(-1, 180)
        tv_sw.add(tv)
        menu_box.pack_start(tv_sw, False, False, 4)

        # ── Botones de control ────────────────────────────────────────────────
        ctrl_row = Gtk.Box(spacing=4)

        def _new_id(base):
            existing = {row[2] for row in item_store}
            candidate = _label_to_id(base) or base
            n, n_idx = candidate, 1
            while n in existing:
                n = f"{candidate}_{n_idx}"; n_idx += 1
            return n

        def _add_item(*_):
            rid = _new_id("item")
            item_store.append(["item", "New item", rid, ""])
            it = item_store.get_iter(Gtk.TreePath(len(item_store) - 1))
            tv.get_selection().select_iter(it)
            _refresh_edit_panel(tv.get_selection())

        def _add_sep(*_):
            rid = _new_id("sep")
            item_store.append(["separator", "─ separator ─", rid, ""])

        def _delete_item(*_):
            model, it = tv.get_selection().get_selected()
            if it:
                item_store.remove(it)
                _refresh_edit_panel(tv.get_selection())

        def _move(direction):
            model, it = tv.get_selection().get_selected()
            if not it:
                return
            path = item_store.get_path(it)
            idx  = path.get_indices()[0]
            n    = len(item_store)
            if direction == -1 and idx > 0:
                item_store.swap(it, item_store.get_iter(Gtk.TreePath(idx - 1)))
            elif direction == 1 and idx < n - 1:
                item_store.swap(it, item_store.get_iter(Gtk.TreePath(idx + 1)))

        for label_b, cb in (
            ("+ Item", _add_item),
            ("─ Sep",  _add_sep),
            ("↑",      lambda *_: _move(-1)),
            ("↓",      lambda *_: _move(1)),
            ("✕",      _delete_item),
        ):
            b = Gtk.Button(label=label_b)
            b.get_style_context().add_class("open-btn")
            b.connect("clicked", cb)
            ctrl_row.pack_start(b, True, True, 0)

        menu_box.pack_start(ctrl_row, False, False, 2)

        # ── Inline edit panel ─────────────────────────────────────────────────
        menu_box.pack_start(_section("Edit selected"), False, False, 0)

        edit_grid = Gtk.Grid()
        edit_grid.set_column_spacing(8)
        edit_grid.set_row_spacing(6)
        edit_grid.set_margin_top(4)

        e_label = Gtk.Entry(); e_label.set_hexpand(True)
        e_label.set_placeholder_text("Visible label")
        e_id    = Gtk.Entry(); e_id.set_hexpand(True)
        e_id.set_placeholder_text("unique id (auto)")
        e_cmd   = Gtk.Entry(); e_cmd.set_hexpand(True)
        e_cmd.set_placeholder_text("command to run")

        _auto_id = [True]

        def _lbl_changed(*_):
            if _auto_id[0]:
                e_id.set_text(_label_to_id(e_label.get_text()))

        def _id_manual(*_):
            if e_id.get_text() != _label_to_id(e_label.get_text()):
                _auto_id[0] = False

        e_label.connect("changed", _lbl_changed)
        e_id.connect("changed",    _id_manual)

        for row_n, (lbl_txt, widget) in enumerate((
            ("Label",   e_label),
            ("ID",      e_id),
            ("Command", e_cmd),
        )):
            lbl_w = Gtk.Label(label=lbl_txt)
            lbl_w.set_xalign(1)
            lbl_w.set_size_request(70, -1)
            lbl_w.get_style_context().add_class("field-label")
            edit_grid.attach(lbl_w,  0, row_n, 1, 1)
            edit_grid.attach(widget, 1, row_n, 1, 1)

        self._w["_menu_e_label"] = e_label
        self._w["_menu_e_id"]    = e_id
        self._w["_menu_e_cmd"]   = e_cmd
        menu_box.pack_start(edit_grid, False, False, 0)
        menu_box.pack_start(_hint("The ID is generated automatically from the label."), False, False, 2)

        # ── Connect selection → edit panel ────────────────────────────────────
        _updating_edit = [False]

        def _refresh_edit_panel(selection):
            model, it = selection.get_selected()
            if not it:
                e_label.set_text(""); e_id.set_text(""); e_cmd.set_text("")
                for w in (e_label, e_id, e_cmd): w.set_sensitive(False)
                return
            rtype = model[it][0]
            for w in (e_label, e_id, e_cmd): w.set_sensitive(True)
            e_cmd.set_sensitive(rtype == "item")
            _updating_edit[0] = True
            e_label.set_text(model[it][1])
            e_id.set_text(model[it][2])
            e_cmd.set_text(model[it][3])
            _auto_id[0] = False
            _updating_edit[0] = False

        def _edit_to_store(*_):
            if _updating_edit[0]:
                return
            model, it = tv.get_selection().get_selected()
            if not it:
                return
            item_store[it][1] = e_label.get_text()
            item_store[it][2] = e_id.get_text() or _label_to_id(e_label.get_text())
            item_store[it][3] = e_cmd.get_text()

        for w in (e_label, e_id, e_cmd):
            w.connect("changed", _edit_to_store)

        tv.get_selection().connect("changed", _refresh_edit_panel)
        _refresh_edit_panel(tv.get_selection())

        def _cr_label_edited(cr, path, new_text):
            it = item_store.get_iter_from_string(path)
            item_store[it][1] = new_text
            tv.get_selection().select_iter(it)
            _refresh_edit_panel(tv.get_selection())

        def _cr_cmd_edited(cr, path, new_text):
            it = item_store.get_iter_from_string(path)
            item_store[it][3] = new_text
            tv.get_selection().select_iter(it)

        cr_label.connect("edited", _cr_label_edited)
        cr_cmd.connect("edited",   _cr_cmd_edited)

        # ── Assemble panels by mode ───────────────────────────────────────────
        outer.pack_start(launcher_box, False, False, 0)
        outer.pack_start(menu_box,     False, False, 0)

        def _show_mode(menu):
            launcher_box.set_visible(not menu)
            menu_box.set_visible(menu)
            cfg["_menu_mode"] = menu
            # in launcher mode: on-click is valid; in menu mode: removed
            if menu:
                fields.pop("on-click",       None)
                fields.pop("tooltip-format", None)
            else:
                fields["on-click"]       = oc_e
                fields["tooltip-format"] = tt_e

        _show_mode(is_menu_mode)

        def _on_launcher_toggle(btn):
            if btn.get_active():
                btn_menu_m.set_active(False)
                _show_mode(False)

        def _on_menu_toggle(btn):
            if btn.get_active():
                btn_launcher.set_active(False)
                _show_mode(True)

        btn_launcher.connect("toggled", _on_launcher_toggle)
        btn_menu_m.connect("toggled",   _on_menu_toggle)

        return _scrolled(outer)

    def _glyph_picker_dialog(self, current: str = "") -> str | None:
        """Show a scrollable grid of Nerd Font glyphs; return selected or None."""
        dlg = Gtk.Dialog(title="Choose icon", parent=self,
                         flags=Gtk.DialogFlags.MODAL)
        dlg.set_default_size(520, 420)
        dlg.add_button("Cancel", Gtk.ResponseType.CANCEL)
        box   = dlg.get_content_area()
        box.set_spacing(0)

        # search entry
        search = Gtk.SearchEntry()
        search.set_placeholder_text("Filter icons…")
        search.set_margin_start(12); search.set_margin_end(12)
        search.set_margin_top(10);   search.set_margin_bottom(6)
        box.pack_start(search, False, False, 0)

        fb    = Gtk.FlowBox()
        fb.set_max_children_per_line(8)
        fb.set_selection_mode(Gtk.SelectionMode.SINGLE)
        fb.set_column_spacing(2)
        fb.set_row_spacing(2)
        fb.set_margin_start(8); fb.set_margin_end(8)

        selected = [current]

        def _make_btn(glyph, label):
            btn = Gtk.Button()
            btn.set_tooltip_text(label)
            btn.set_size_request(52, 52)
            lbl = Gtk.Label()
            lbl.set_markup(
                f"<span font='JetBrainsMono Nerd Font Mono 18'>{glyph}</span>")
            btn.add(lbl)
            btn.connect("clicked", lambda _b, g=glyph: (
                selected.__setitem__(0, g),
                dlg.response(Gtk.ResponseType.OK)
            ))
            return btn

        all_btns = []
        for glyph, label in _USER_GLYPHS:
            btn = _make_btn(glyph, label)
            fb.add(btn)
            all_btns.append((glyph, label, btn))

        def _filter(_entry):
            q = _entry.get_text().strip().lower()
            for g, lbl, btn in all_btns:
                btn.get_parent().set_visible(not q or q in lbl.lower())

        search.connect("changed", _filter)

        sw = Gtk.ScrolledWindow()
        sw.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        sw.add(fb)
        box.pack_start(sw, True, True, 0)
        dlg.show_all()
        result = dlg.run()
        dlg.destroy()
        return selected[0] if result == Gtk.ResponseType.OK else None

    # ── DnD cross-zona ────────────────────────────────────────────────────────

    def _on_zone_drag_begin(self, tv, context, store):
        """Save source store and dragged module ID."""
        self._dnd_source_store = store
        _, it = tv.get_selection().get_selected()
        self._dnd_source_id = store.get_value(it, 0) if it else None

    def _on_zone_drag_get(self, tv, context, data, info, timestamp, store):
        """Provee el module ID como texto/plain."""
        if self._dnd_source_id:
            data.set_text(self._dnd_source_id, -1)

    def _on_zone_drag_received(self, tv, context, x, y, data, info, timestamp, store):
        """Maneja drop: reorden interno y movimiento cross-zona."""
        src    = self._dnd_source_store
        mod_id = data.get_text()

        if not mod_id or src is None:
            self._dnd_source_store = None
            self._dnd_source_id    = None
            Gtk.drag_finish(context, False, False, timestamp)
            return

        # Etiqueta de display
        if mod_id in MODULE_LABELS:
            icon, name = MODULE_LABELS[mod_id]
        else:
            glyph = (self._cfg.get(mod_id, {}) or
                     self._dock_cfg.get(mod_id, {})).get("format", "󰘳")
            name  = mod_id.split("/")[-1] if "/" in mod_id else mod_id
            icon  = glyph
        label = f"{icon}  {name}"

        # Insert at drop position
        drop_info = tv.get_dest_row_at_pos(x, y)
        if drop_info:
            path, pos = drop_info
            it_tgt = store.get_iter(path)
            if pos in (Gtk.TreeViewDropPosition.BEFORE,
                       Gtk.TreeViewDropPosition.INTO_OR_BEFORE):
                new_it = store.insert_before(it_tgt, [mod_id, label])
            else:
                new_it = store.insert_after(it_tgt, [mod_id, label])
        else:
            new_it = store.append([mod_id, label])

        # Remove from source store (the row we just inserted
        # could be the same store; search by original position, not value,
        # to avoid deleting the newly inserted row when src is store)
        it_s = src.get_iter_first()
        found = False
        while it_s and not found:
            if src.get_value(it_s, 0) == mod_id:
                if src is store:
                    # internal reorder: do not delete the newly inserted row
                    if src.get_path(it_s) != src.get_path(new_it):
                        src.remove(it_s)
                        found = True
                        continue
                else:
                    src.remove(it_s)
                    found = True
                    continue
            it_s = src.iter_next(it_s)

        self._dnd_source_store = None
        self._dnd_source_id    = None
        Gtk.drag_finish(context, True, False, timestamp)

    def _on_zone_add(self, _, zone_key, store, cfg=None):
        if cfg is None: cfg = self._cfg
        dlg = Gtk.Dialog(title="Add module", parent=self, flags=Gtk.DialogFlags.MODAL)
        dlg.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Add", Gtk.ResponseType.OK)
        content = dlg.get_content_area()
        content.set_margin_start(16)
        content.set_margin_end(16)
        content.set_margin_top(16)
        content.set_margin_bottom(16)
        # combine built-in + user modules + groups + dock apps
        user_mods  = [f"custom/{s}" for s in self._cfg.get("_user_modules", [])]
        dock_mods  = [k for k in self._dock_cfg if k.startswith("custom/") and k not in ALL_MODULES]
        cfg_mods   = [k for k in cfg if k.startswith("custom/") and k not in ALL_MODULES]
        group_mods = list(self._groups.keys())
        cffi_mods  = list(self._cffi_modules.keys())
        all_mods   = ALL_MODULES + [m for m in user_mods + dock_mods + cfg_mods + group_mods + cffi_mods
                                    if m not in ALL_MODULES]
        def _mod_label(m):
            if m in MODULE_LABELS:
                return MODULE_LABELS[m]
            if m.startswith("cffi/"):
                return ("󱋦", m[5:])
            if m.startswith("group/"):
                return ("󱒊" if "drawer" in self._groups.get(m, {}) else "󰾮", m[6:])
            suffix = m[7:] if m.startswith("custom/") else m
            glyph  = cfg.get(m, self._dock_cfg.get(m, self._cfg.get(m, {}))).get("format", "󰘳")
            return (glyph, suffix)
        sorted_mods = sorted(all_mods, key=lambda m: _mod_label(m)[1].lower())
        combo = _combo(
            [f"{_mod_label(m)[0]}  {_mod_label(m)[1]}" for m in sorted_mods],
            _mod_label(sorted_mods[0])[1],
        )
        content.add(combo)
        dlg.show_all()
        if dlg.run() == Gtk.ResponseType.OK:
            idx  = combo.get_active()
            mod  = sorted_mods[idx]
            icon, name = _mod_label(mod)
            store.append([mod, f"{icon}  {name}"])
            self._refresh_preview()
        dlg.destroy()

    def _on_zone_remove(self, _, tv):
        sel = tv.get_selection()
        model, it = sel.get_selected()
        if it:
            model.remove(it)
            self._refresh_preview()

    def _on_zone_move(self, _, tv, direction):
        sel = tv.get_selection()
        model, it = sel.get_selected()
        if not it:
            return
        path = model.get_path(it)
        idx  = path.get_indices()[0]
        target = idx + direction
        if target < 0 or target >= len(model):
            return
        other = model.get_iter(Gtk.TreePath(target))
        model.swap(it, other)
        self._refresh_preview()

