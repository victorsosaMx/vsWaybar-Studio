    def _refresh_preview(self, *_):
        self._collect()
        if self._preview_webview:
            html = self._build_preview_html()
            self._preview_webview.load_html(html, "about:blank")

    def _status(self, main: str, hint: str = "", timeout: int = 5000):
        self._status_lbl.set_text(main)
        self._status_hint.set_text(hint)
        if self._status_timer:
            GLib.source_remove(self._status_timer)
        def _clear():
            self._status_lbl.set_text("")
            self._status_hint.set_text("")
            self._status_timer = None
            return False
        self._status_timer = GLib.timeout_add(timeout, _clear)

    def _err(self, msg: str):
        dlg = Gtk.MessageDialog(
            parent=self, flags=Gtk.DialogFlags.MODAL,
            message_type=Gtk.MessageType.ERROR,
            buttons=Gtk.ButtonsType.OK, text="Error",
        )
        dlg.format_secondary_text(msg)
        dlg.run()
        dlg.destroy()



    def _connect_preview_signals(self):
        # Zone stores → refresh when modules added/removed/reordered
        for zone in ("modules-left", "modules-center", "modules-right"):
            store = self._w.get(f"zone_{zone}")
            if store:
                store.connect("row-changed",  self._refresh_preview)
                store.connect("row-inserted", self._refresh_preview)
                store.connect("row-deleted",  self._refresh_preview)
        # CSS color entries → refresh on valid hex change
        for entry in self._w.get("css_hex_entries", {}).values():
            entry.connect("changed", self._refresh_preview)
        # CSS color buttons → refresh on pick
        for btn in self._w.get("css_colors", {}).values():
            btn.connect("color-set", self._refresh_preview)


