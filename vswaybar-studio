class VsWaybarSettings(Gtk.Window):

    def __init__(self):
        super().__init__(title="vsWaybar Studio")
        self.set_default_size(960, 660)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.connect("delete-event", self._on_close)
        self.connect("key-press-event", self._on_key)

        self._config_path     = CONFIG_PATH
        self._css_path        = CSS_PATH
        self._cfg:       dict = {}
        self._css_colors:dict = {}
        self._w:         dict = {}
        self._dark            = False
        self._theme           = THEME_LIGHT
        self._css_provider    = Gtk.CssProvider()
        self._path_lbl        = None
        self._status_timer    = None
        self._selected_module = None
        self._notebook        = None
        self._rnd_mode        = None
        self._module_panel    = None
        self._bar_preview_da  = None
        self._ws_anim_t       = 0.0

        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            self._css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )
        self._apply_css()
        self._load_config()
        self._build_ui()
        self.show_all()
        GLib.timeout_add(50, self._ws_anim_tick)

    # ── events ────────────────────────────────────────────────────────────────

    def _on_close(self, *_):
        Gtk.main_quit()
        return False

    def _on_key(self, _, event):
        ctrl = event.state & Gdk.ModifierType.CONTROL_MASK
        if ctrl:
            if event.keyval == Gdk.KEY_s: self._on_preview(); return True
            if event.keyval == Gdk.KEY_o: self._on_open(); return True
        return False

    # ── CSS ───────────────────────────────────────────────────────────────────

    def _apply_css(self):
        self._css_provider.load_from_data(_build_css(self._theme))

    def _toggle_theme(self, *_):
        self._dark  = not self._dark
        self._theme = THEME_DARK if self._dark else THEME_LIGHT
        self._apply_css()
        self._rebuild_ui()

    # ── config I/O ────────────────────────────────────────────────────────────

    def _load_config(self):
        self._cfg = copy.deepcopy(DEFAULTS)
        try:
            with open(self._config_path) as f:
                user = json.load(f)
            for k in ("layer", "output", "position", "height", "spacing",
                      "margin-top", "margin-bottom", "margin-left", "margin-right"):
                if k in user:
                    self._cfg[k] = user[k]
            for zone in ("modules-left", "modules-center", "modules-right"):
                if zone in user:
                    self._cfg[zone] = user[zone]
            for mod in ALL_MODULES:
                if mod in user and isinstance(user[mod], dict):
                    # merge: start from defaults so virtual keys are preserved
                    base = copy.deepcopy(DEFAULTS.get(mod, {}))
                    base.update(user[mod])
                    self._cfg[mod] = base
            # strip deprecated/removed keys
            self._cfg.get("clock", {}).pop("format-alt", None)
        except FileNotFoundError:
            pass
        except Exception as e:
            print(f"Warning: {e}")

        self._css_colors = copy.deepcopy(CSS_COLOR_DEFAULTS)
        try:
            with open(self._css_path) as f:
                css_text = f.read()
            for m in re.finditer(r'@define-color\s+(\w+)\s+(#[0-9a-fA-F]{6})', css_text):
                name, val = m.group(1), m.group(2)
                if name in self._css_colors:
                    self._css_colors[name] = val
            # global font-size: * { font-size: Npx; }
            mf = re.search(r'\*\s*\{[^}]*font-size:\s*(\d+)px', css_text, re.DOTALL)
            if mf:
                self._cfg["font-size"] = int(mf.group(1))
            # opacity: read from rgba() in modules block
            mo = re.search(r'rgba\(\s*\d+\s*,\s*\d+\s*,\s*\d+\s*,\s*([\d.]+)\s*\)', css_text)
            if mo:
                self._cfg["opacity"] = int(float(mo.group(1)) * 100)

            # separators: detect saved marker block
            if '/* vswaybar:sep */' in css_text:
                self._cfg["separators"] = True

            # global font-family: * { font-family: "..."; } — extract first name only
            mff = re.search(r'\*\s*\{[^}]*font-family:\s*([^;]+);', css_text, re.DOTALL)
            if mff:
                first = mff.group(1).split(",")[0].strip().strip('"').strip("'")
                if first and first.lower() not in ("monospace", "sans-serif", "serif"):
                    self._cfg["font-family"] = first
            # module H-padding from zone container: .modules-* { padding: Vpx Hpx }
            mp = re.search(
                r'\.modules-left,\s*\n\.modules-center,\s*\n\.modules-right\s*\{[^}]*padding:\s*\d+px\s+(\d+)px',
                css_text, re.DOTALL
            )
            if mp:
                self._cfg["mod-padding"] = int(mp.group(1))

            # arch icon padding from #custom-arch { padding: 0 Rpx 0 Lpx }
            karch = re.search(
                r'#custom-arch\s*\{[^}]*padding:\s*\d+px\s+(\d+)px\s+\d+px\s+(\d+)px',
                css_text, re.DOTALL
            )
            arch_c = self._cfg.setdefault("custom/arch", {})
            arch_c.setdefault("arch-pad-right", int(karch.group(1)) if karch else 8)
            arch_c.setdefault("arch-pad-left",  int(karch.group(2)) if karch else 8)

            # workspace animation colors from @keyframes ws-active
            km = re.search(
                r'@keyframes\s+ws-active\s*\{.*?0%[^{]*\{[^}]*background-color:\s*(#[0-9a-fA-F]{6})',
                css_text, re.DOTALL | re.IGNORECASE
            )
            km2 = re.search(
                r'@keyframes\s+ws-active\s*\{.*?50%[^{]*\{[^}]*background-color:\s*(#[0-9a-fA-F]{6})',
                css_text, re.DOTALL | re.IGNORECASE
            )
            ws_c = self._cfg.setdefault("hyprland/workspaces", {})
            ws_c.setdefault("anim-color-1", km.group(1)  if km  else "#2980b9")
            ws_c.setdefault("anim-color-2", km2.group(1) if km2 else "#420ed2")
            # animation duration
            kd = re.search(
                r'#workspaces\s+button\.active\s*\{[^}]*animation:\s*ws-active\s+([\d.]+)s',
                css_text, re.DOTALL
            )
            ws_c.setdefault("anim-duration", float(kd.group(1)) if kd else 3.0)
            # button border-radius
            kr = re.search(
                r'#workspaces\s+button\s*\{[^}]*border-radius:\s*(\d+)px',
                css_text, re.DOTALL
            )
            ws_c.setdefault("button-radius", int(kr.group(1)) if kr else 8)
            # button padding
            kp = re.search(
                r'#workspaces\s+button\s*\{[^}]*padding:\s*(\d+)px\s+(\d+)px',
                css_text, re.DOTALL
            )
            ws_c.setdefault("button-pad-v", int(kp.group(1)) if kp else 4)
            ws_c.setdefault("button-pad-h", int(kp.group(2)) if kp else 14)
            # button min-width
            kmw = re.search(
                r'#workspaces\s+button\s*\{[^}]*min-width:\s*(\d+)px',
                css_text, re.DOTALL
            )
            ws_c.setdefault("button-minw", int(kmw.group(1)) if kmw else 32)
        except FileNotFoundError:
            pass
        except Exception as e:
            print(f"Warning CSS: {e}")

    def _collect(self):
        w = self._w
        for k in ("position", "bar-style"):
            if k in w:
                self._cfg[k] = w[k].get_active_text()
        if "output" in w:
            val = w["output"].get_active_text() or ""
            if val == "All monitors":
                self._cfg.pop("output", None)
            else:
                self._cfg["output"] = val.strip()
        if "font-family" in w:
            v = w["font-family"].get_font_name().strip()
            if v:
                # use Pango to extract family only (strips size, style, weight)
                family = Pango.FontDescription.from_string(v).get_family()
                if family:
                    self._cfg["font-family"] = family
        for k in ("height", "spacing", "margin-top", "margin-bottom", "margin-left", "margin-right", "zone-radius",
                  "font-size", "mod-padding", "border-width", "opacity"):
            if k in w:
                self._cfg[k] = int(w[k].get_value())
        if "separators" in w:
            self._cfg["separators"] = w["separators"].get_active()
        for zone in ("modules-left", "modules-center", "modules-right"):
            store = w.get(f"zone_{zone}")
            if store:
                self._cfg[zone] = [row[0] for row in store]
        for name, entry in w.get("css_hex_entries", {}).items():
            val = entry.get_text().strip()
            if re.match(r'^#[0-9a-fA-F]{6}$', val, re.IGNORECASE):
                self._css_colors[name] = val.lower()
        self._collect_module_fields()

    def _collect_module_fields(self):
        mod = self._selected_module
        if not mod:
            return
        if mod not in self._cfg:
            self._cfg[mod] = {}
        fields = self._w.get("mod_fields", {})
        for fkey, widget in fields.items():
            if "." in fkey:
                parent, child = fkey.split(".", 1)
                if parent not in self._cfg[mod] or not isinstance(self._cfg[mod][parent], dict):
                    self._cfg[mod][parent] = {}
                if isinstance(widget, Gtk.SpinButton):   # SpinButton before Entry!
                    self._cfg[mod][parent][child] = int(widget.get_value())
                elif isinstance(widget, Gtk.Entry):
                    self._cfg[mod][parent][child] = widget.get_text()
                elif isinstance(widget, Gtk.Switch):
                    self._cfg[mod][parent][child] = widget.get_active()
            elif isinstance(widget, Gtk.SpinButton):     # SpinButton before Entry!
                self._cfg[mod][fkey] = int(widget.get_value())
            elif isinstance(widget, Gtk.Entry):
                self._cfg[mod][fkey] = widget.get_text()
            elif isinstance(widget, Gtk.Switch):
                self._cfg[mod][fkey] = widget.get_active()
            elif isinstance(widget, Gtk.ComboBoxText):
                self._cfg[mod][fkey] = widget.get_active_text()

        # strip keys that must never appear in saved JSON
        if mod == "clock":
            self._cfg[mod].pop("format-alt", None)

        # rebuild custom/arch format from size + color + glyph controls
        if mod == "custom/arch":
            sz_w    = fields.get("arch-icon-size")
            col_w   = fields.get("arch-icon-color")
            glyph_w = fields.get("arch-icon-glyph")
            if sz_w is not None:
                sz     = int(sz_w.get_value()) if isinstance(sz_w, Gtk.SpinButton) else 20
                col    = col_w.get_text().strip()   if isinstance(col_w,   Gtk.Entry) else ""
                glyph  = glyph_w.get_text().strip() if isinstance(glyph_w, Gtk.Entry) else "󰣇"
                if not glyph: glyph = "󰣇"
                self._cfg[mod].pop("arch-icon-size",  None)
                self._cfg[mod].pop("arch-icon-color",  None)
                col_attr = f" color='{col}'" if re.match(r'^#[0-9a-fA-F]{6}$', col, re.IGNORECASE) else ""
                self._cfg[mod]["format"]          = f"<span font='JetBrainsMono Nerd Font Mono {sz}'{col_attr}>{glyph}</span>"
                self._cfg[mod]["arch-icon-glyph"] = glyph

    def _build_save_config(self) -> dict:
        out = {}
        for k in ("position", "height", "spacing",
                  "margin-top", "margin-bottom", "margin-left", "margin-right"):
            out[k] = self._cfg.get(k, DEFAULTS.get(k))
        if "output" in self._cfg:
            out["output"] = self._cfg["output"]
        out["modules-left"]   = self._cfg["modules-left"]
        out["modules-center"] = self._cfg["modules-center"]
        out["modules-right"]  = self._cfg["modules-right"]
        for mod in ALL_MODULES:
            if mod in self._cfg:
                mod_cfg = dict(self._cfg[mod])
                if mod == "clock":
                    for _k in _CLOCK_OPTIONAL_KEYS:
                        if _k in mod_cfg and str(mod_cfg[_k]).strip() == "":
                            mod_cfg.pop(_k)
                out[mod] = mod_cfg
        return out

    def _build_save_css(self) -> str:
        try:
            with open(self._css_path) as f:
                css_text = f.read()
        except FileNotFoundError:
            css_text = ""

        # ── @define-color replacements ────────────────────────────────────────
        for name, val in self._css_colors.items():
            pattern = rf'(@define-color\s+{re.escape(name)}\s+)(#[0-9a-fA-F]{{6}})'
            css_text = re.sub(pattern, rf'\g<1>{val}', css_text)

        # ── derived values ────────────────────────────────────────────────────
        base_hex  = self._css_colors.get("base",     "#11140e").lstrip("#")
        s0_color  = self._css_colors.get("surface0", "#1d211a")
        br, bg, bb = (int(base_hex[i:i+2], 16) for i in (0, 2, 4))
        rgb       = f"{br},{bg},{bb}"
        zone_r    = self._cfg.get("zone-radius",   12)
        bar_style = self._cfg.get("bar-style",    "islands")
        opacity   = self._cfg.get("opacity",      95) / 100
        font_sz   = self._cfg.get("font-size",    13)
        mod_pad   = self._cfg.get("mod-padding",  8)
        brd_w     = self._cfg.get("border-width", 1)

        # ── global font-family + font-size ───────────────────────────────────
        font_fam_raw = self._cfg.get("font-family", "Product Sans")
        # wrap in quotes for CSS; keep monospace fallback
        font_fam_css = f'"{font_fam_raw}", monospace'
        css_text = re.sub(
            r'(\*\s*\{[^}]*?font-family:\s*)[^;]+;',
            rf'\g<1>{font_fam_css};',
            css_text, flags=re.DOTALL
        )
        css_text = re.sub(
            r'(\*\s*\{[^}]*?font-size:\s*)\d+px',
            rf'\g<1>{font_sz}px',
            css_text, flags=re.DOTALL
        )

        # ── window#waybar background + radius (barra = full pill) ───────────
        win_bg = f"rgba({rgb},{opacity:.2f})" if bar_style == "bar" else "transparent"
        win_r  = zone_r if bar_style == "bar" else 0
        css_text = re.sub(
            r'(window#waybar\s*\{[^}]*?background:\s*)[^;]+;',
            rf'\g<1>{win_bg};',
            css_text, flags=re.DOTALL
        )
        # Add/replace border-radius inside window#waybar block
        if re.search(r'window#waybar\s*\{[^}]*?border-radius:', css_text, re.DOTALL):
            css_text = re.sub(
                r'(window#waybar\s*\{[^}]*?border-radius:\s*)[^;]+;',
                rf'\g<1>{win_r}px;',
                css_text, flags=re.DOTALL
            )
        else:
            css_text = re.sub(
                r'(window#waybar\s*\{[^}]*?)(color:\s*[^;]+;)',
                rf'\g<1>\g<2>\n    border-radius: {win_r}px;',
                css_text, flags=re.DOTALL
            )

        # ── window#waybar border (barra style only) ──────────────────────────
        win_brd = f"{brd_w}px solid {s0_color}" if bar_style == "bar" and brd_w > 0 else "none"
        if re.search(r'window#waybar\s*\{[^}]*?border:', css_text, re.DOTALL):
            css_text = re.sub(
                r'(window#waybar\s*\{[^}]*?border:\s*)[^;]+;',
                rf'\g<1>{win_brd};',
                css_text, flags=re.DOTALL
            )
        else:
            css_text = re.sub(
                r'(window#waybar\s*\{[^}]*?border-radius:\s*[^;]+;)',
                rf'\g<1>\n    border: {win_brd};',
                css_text, flags=re.DOTALL
            )

        # ── .modules-left/center/right block ─────────────────────────────────
        brd = f"{brd_w}px solid {s0_color}" if brd_w > 0 else "none"
        if bar_style == "bar":
            modules_block = (
                ".modules-left,\n.modules-center,\n.modules-right {\n"
                "    background: transparent;\n"
                "    border-radius: 0;\n"
                f"    padding: 2px {mod_pad}px;\n"
                "    border: none;\n"
                "    min-height: 0;\n"
                "}"
            )
        elif bar_style == "modules":
            modules_block = (
                ".modules-left,\n.modules-center,\n.modules-right {\n"
                "    background: transparent;\n"
                "    border: none;\n"
                f"    padding: 2px {max(2, mod_pad // 2)}px;\n"
                "    min-height: 0;\n"
                "}\n\n"
                ".modules-left > *,\n.modules-center > *,\n.modules-right > * {\n"
                f"    background: rgba({rgb},{opacity:.2f});\n"
                f"    border-radius: {zone_r}px;\n"
                f"    border: {brd};\n"
                f"    padding: 0 {mod_pad}px;\n"
                "    margin: 0 2px;\n"
                "}"
            )
        else:  # islands
            modules_block = (
                ".modules-left,\n.modules-center,\n.modules-right {\n"
                f"    background: rgba({rgb},{opacity:.2f});\n"
                f"    border-radius: {zone_r}px;\n"
                f"    padding: 2px {mod_pad}px;\n"
                f"    border: {brd};\n"
                "    min-height: 0;\n"
                "}"
            )

        css_text = re.sub(
            r'\.modules-left,\s*\n\.modules-center,\s*\n\.modules-right\s*\{[^}]+\}'
            r'(?:\s*\n\n\.modules-left\s*>\s*\*,[\s\S]*?\})?',
            modules_block,
            css_text
        )

        # ── per-module padding override ───────────────────────────────────────
        css_text = re.sub(r'\n*/\* vswaybar:modpad \*/.*$', '', css_text, flags=re.DOTALL)
        arch_c  = self._cfg.get("custom/arch", {})
        arch_pl = arch_c.get("arch-pad-left",  8)
        arch_pr = arch_c.get("arch-pad-right", 8)
        css_text += (
            f"\n/* vswaybar:modpad */\n"
            f"#clock, #cpu, #memory, #network, #pulseaudio, #battery, #tray,\n"
            f"#custom-updates, #custom-weather, #custom-swaync, #custom-power {{\n"
            f"    padding: 0 {mod_pad}px;\n"
            f"}}\n"
            f"#custom-arch {{\n"
            f"    padding: 0 {arch_pr}px 0 {arch_pl}px;\n"
            f"}}\n"
        )

        # ── separators (islas / barra only) ──────────────────────────────────
        separators = self._cfg.get("separators", False)
        css_text = re.sub(r'\n*/\* vswaybar:sep \*/.*$', '', css_text, flags=re.DOTALL)
        if separators and bar_style in ("islands", "bar"):
            sep_color = s0_color
            css_text += (
                f"\n/* vswaybar:sep */\n"
                f".modules-left > *, .modules-center > *, .modules-right > * {{\n"
                f"    border-right: {brd_w}px solid {sep_color};\n"
                f"}}\n"
                f".modules-left > *:last-child,\n"
                f".modules-center > *:last-child,\n"
                f".modules-right > *:last-child {{\n"
                f"    border-right: none;\n"
                f"}}\n"
            )

        # ── workspace animation colors ───────────────────────────────────────
        ws_c = self._cfg.get("hyprland/workspaces", {})
        ac1  = ws_c.get("anim-color-1",  "#2980b9")
        ac2  = ws_c.get("anim-color-2",  "#420ed2")
        dur  = ws_c.get("anim-duration", 3.0)
        wsr  = ws_c.get("button-radius", 8)
        css_text = re.sub(
            r'(@keyframes\s+ws-active\s*\{[^}]*0%\s*\{[^}]*background-color:\s*)(#[0-9a-fA-F]{6})',
            rf'\g<1>{ac1}',
            css_text, flags=re.DOTALL | re.IGNORECASE
        )
        css_text = re.sub(
            r'(@keyframes\s+ws-active\s*\{.*?50%\s*\{[^}]*background-color:\s*)(#[0-9a-fA-F]{6})',
            rf'\g<1>{ac2}',
            css_text, flags=re.DOTALL | re.IGNORECASE
        )
        css_text = re.sub(
            r'(#workspaces\s+button\.active\s*\{[^}]*animation:\s*ws-active\s+)([\d.]+)s',
            rf'\g<1>{dur}s',
            css_text, flags=re.DOTALL
        )
        css_text = re.sub(
            r'(#workspaces\s+button\s*\{[^}]*border-radius:\s*)\d+px',
            rf'\g<1>{wsr}px',
            css_text, flags=re.DOTALL
        )
        wpv = ws_c.get("button-pad-v", 4)
        wph = ws_c.get("button-pad-h", 14)
        css_text = re.sub(
            r'(#workspaces\s+button\s*\{[^}]*padding:\s*)\d+px\s+\d+px',
            rf'\g<1>{wpv}px {wph}px',
            css_text, flags=re.DOTALL
        )
        wmw = ws_c.get("button-minw", 32)
        css_text = re.sub(
            r'(#workspaces\s+button\s*\{[^}]*min-width:\s*)\d+px',
            rf'\g<1>{wmw}px',
            css_text, flags=re.DOTALL
        )

        return css_text

    def _on_save_as(self, *_):
        dlg = Gtk.FileChooserDialog(
            title="Save config as…", parent=self,
            action=Gtk.FileChooserAction.SAVE,
            buttons=("Cancel", Gtk.ResponseType.CANCEL, "Save", Gtk.ResponseType.OK),
        )
        dlg.set_current_name(os.path.basename(self._config_path))
        dlg.set_do_overwrite_confirmation(True)
        if dlg.run() == Gtk.ResponseType.OK:
            dest = dlg.get_filename()
            dlg.destroy()
            self._collect()
            try:
                cfg_out = self._build_save_config()
                css_out = self._build_save_css()
                with open(dest, "w") as f:
                    json.dump(cfg_out, f, indent=4, ensure_ascii=False)
                css_dest = os.path.splitext(dest)[0] + ".css"
                with open(css_dest, "w") as f:
                    f.write(css_out)
                self._status(f"✓  Saved to {os.path.basename(dest)}")
            except Exception as e:
                self._err(f"Could not save:\n{e}")
        else:
            dlg.destroy()

    def _on_open(self, *_):
        dlg = Gtk.FileChooserDialog(
            title="Open Waybar config", parent=self,
            action=Gtk.FileChooserAction.OPEN,
            buttons=("Cancel", Gtk.ResponseType.CANCEL, "Open", Gtk.ResponseType.OK),
        )
        ff = Gtk.FileFilter()
        ff.set_name("JSON configs")
        ff.add_pattern("*.json")
        dlg.add_filter(ff)
        if dlg.run() == Gtk.ResponseType.OK:
            self._config_path = dlg.get_filename()
            dlg.destroy()
            self._load_config()
            self._rebuild_ui()
            self._status("✓  Loaded")
        else:
            dlg.destroy()


    def _on_preview(self, *_):
        """Write config + CSS to disk, then restart waybar."""
        self._collect()
        try:
            cfg_out = self._build_save_config()
            css_out = self._build_save_css()   # read CSS BEFORE opening for write
            with open(self._config_path, "w") as f:
                json.dump(cfg_out, f, indent=4, ensure_ascii=False)
            with open(self._css_path, "w") as f:
                f.write(css_out)
        except Exception as e:
            self._err(f"No se pudo escribir config:\n{e}")
            return

        # Full restart — more reliable than SIGUSR2 for CSS changes
        subprocess.Popen(["pkill", "-x", "waybar"])
        GLib.timeout_add(600, self._relaunch_waybar)
        self._status("↺  Reiniciando waybar…")

    def _relaunch_waybar(self):
        try:
            subprocess.Popen(
                ["waybar", "-c", self._config_path, "-s", self._css_path],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
            self._status("✓  Waybar reiniciado")
        except Exception as e:
            self._err(f"Error al lanzar waybar:\n{e}")
        return False  # one-shot timer

    # ── UI skeleton ───────────────────────────────────────────────────────────

    def _rebuild_ui(self):
        page = self._notebook.get_current_page() if self._notebook else 0
        for child in self.get_children():
            self.remove(child)
        self._build_ui()
        self._notebook.set_current_page(page)
        self.show_all()

    def _build_ui(self):
        self._w = {"css_colors": {}, "css_hex_entries": {}, "mod_fields": {}}
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(root)
        root.pack_start(self._make_header(),      False, False, 0)
        root.pack_start(self._make_bar_preview(), False, False, 0)
        root.pack_start(self._make_notebook(),    True,  True,  0)
        root.pack_start(self._make_statusbar(),   False, False, 0)
        self._connect_preview_signals()

    def _make_statusbar(self) -> Gtk.Widget:
        bar = Gtk.Box(spacing=10)
        bar.get_style_context().add_class("status-bar")
        self._status_lbl = Gtk.Label(label="")
        self._status_lbl.set_xalign(0)
        self._status_lbl.get_style_context().add_class("status-ok")
        self._status_hint = Gtk.Label(label="")
        self._status_hint.set_xalign(0)
        self._status_hint.get_style_context().add_class("status-hint")
        bar.pack_start(self._status_lbl,  False, False, 0)
        bar.pack_start(self._status_hint, False, False, 0)
        return bar

    def _make_bar_preview(self) -> Gtk.Widget:
        wrap = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        wrap.get_style_context().add_class("preview-strip")
        da = Gtk.DrawingArea()
        da.set_size_request(-1, 120)
        da.connect("draw", self._draw_bar_preview)
        self._bar_preview_da = da
        wrap.pack_start(da, True, True, 0)
        return wrap

    def _make_header(self) -> Gtk.Widget:
        hdr = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        hdr.get_style_context().add_class("app-header")

        left = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=3)
        left.set_valign(Gtk.Align.CENTER)
        left.pack_start(_lbl("󰒓  vsWaybar Studio", "app-title"), False, False, 0)
        self._path_lbl = _lbl(self._config_path, "app-path")
        left.pack_start(self._path_lbl, False, False, 0)
        hdr.pack_start(left, True, True, 0)

        btn_box = Gtk.Box(spacing=8)
        btn_box.set_valign(Gtk.Align.CENTER)

        theme_btn = Gtk.Button(label="☾" if self._dark else "☀")
        theme_btn.get_style_context().add_class("theme-btn")
        theme_btn.connect("clicked", self._toggle_theme)

        open_btn = Gtk.Button(label="Open…")
        open_btn.get_style_context().add_class("open-btn")
        open_btn.connect("clicked", self._on_open)

        apply_btn = Gtk.Button(label="Apply")
        apply_btn.get_style_context().add_class("save-btn")
        apply_btn.connect("clicked", self._on_preview)

        saveas_btn = Gtk.Button(label="Save as…")
        saveas_btn.get_style_context().add_class("open-btn")
        saveas_btn.connect("clicked", self._on_save_as)

        for b in (theme_btn, open_btn, saveas_btn, apply_btn):
            btn_box.pack_start(b, False, False, 0)
        hdr.pack_start(btn_box, False, False, 0)
        return hdr

    def _make_notebook(self) -> Gtk.Widget:
        nb = Gtk.Notebook()
        nb.set_tab_pos(Gtk.PositionType.LEFT)
        nb.set_show_border(False)
        self._notebook = nb
        pages = [
            ("  Bar",        self._page_bar()),
            ("  Layout",     self._page_layout()),
            ("  Modules",    self._page_modules()),
            ("  Styling",    self._page_styling()),
            ("  Scripts",    self._page_scripts()),
            ("  Templates",  self._page_templates()),
            ("  About",      self._page_about()),
        ]
        for label, page in pages:
            lbl = Gtk.Label(label=label)
            lbl.set_xalign(0)
            nb.append_page(page, lbl)
        return nb

    # ── page: Bar ─────────────────────────────────────────────────────────────

    def _page_bar(self) -> Gtk.Widget:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        box.set_margin_start(28)
        box.set_margin_end(28)
        box.set_margin_top(8)
        box.set_margin_bottom(20)

        box.pack_start(_section("Position"), False, False, 0)

        pos = _combo(["top", "bottom"], self._cfg["position"])
        self._w["position"] = pos
        pos.connect("changed", self._refresh_preview)
        box.pack_start(_row("Position", pos), False, False, 0)

        out_combo = Gtk.ComboBoxText()
        self._w["output"] = out_combo

        def _fill_monitors(combo):
            current = combo.get_active_text() or self._cfg.get("output", "")
            combo.remove_all()
            combo.append_text("All monitors")
            try:
                r = subprocess.run(["hyprctl", "monitors", "-j"],
                                   capture_output=True, text=True, timeout=3)
                names = [m["name"] for m in json.loads(r.stdout)]
            except Exception:
                names = []
            for n in names:
                combo.append_text(n)
            # restore selection
            matched = False
            for i, n in enumerate(["All monitors"] + names):
                if n == current or (not current and n == "All monitors"):
                    combo.set_active(i)
                    matched = True
                    break
            if not matched:
                combo.prepend_text(current)
                combo.set_active(0)

        _fill_monitors(out_combo)
        out_combo.connect("changed", self._refresh_preview)

        refresh_btn = Gtk.Button(label="⟳")
        refresh_btn.get_style_context().add_class("open-btn")
        refresh_btn.set_tooltip_text("Re-detect monitors")
        refresh_btn.connect("clicked", lambda *_: _fill_monitors(out_combo))

        out_row = Gtk.Box(spacing=6)
        out_row.pack_start(out_combo,    False, False, 0)
        out_row.pack_start(refresh_btn,  False, False, 0)
        box.pack_start(_row("Output (monitor)", out_row), False, False, 0)

        box.pack_start(_section("Dimensions"), False, False, 0)

        height = _spin(self._cfg["height"], 20, 80)
        self._w["height"] = height
        height.connect("value-changed", self._refresh_preview)
        box.pack_start(_row("Altura (px)", height), False, False, 0)

        spacing = _spin(self._cfg["spacing"], 0, 20)
        self._w["spacing"] = spacing
        spacing.connect("value-changed", self._refresh_preview)
        box.pack_start(_row("Module spacing", spacing), False, False, 0)

        box.pack_start(_section("Appearance"), False, False, 0)

        style_combo = _combo(["islands", "bar", "modules"],
                             self._cfg.get("bar-style", "islands"))
        self._w["bar-style"] = style_combo
        style_combo.connect("changed", self._refresh_preview)
        box.pack_start(_row("Visual style", style_combo), False, False, 0)

        opacity = _spin(self._cfg.get("opacity", 95), 10, 100)
        self._w["opacity"] = opacity
        opacity.connect("value-changed", self._refresh_preview)
        box.pack_start(_row("Opacity (%)", opacity), False, False, 0)

        radius = _spin(self._cfg.get("zone-radius", 12), 0, 30)
        self._w["zone-radius"] = radius
        radius.connect("value-changed", self._refresh_preview)
        box.pack_start(_row("Zone radius (px)", radius), False, False, 0)

        border_w = _spin(self._cfg.get("border-width", 1), 0, 6)
        self._w["border-width"] = border_w
        border_w.connect("value-changed", self._refresh_preview)
        box.pack_start(_row("Border (px)", border_w), False, False, 0)

        sep_sw = Gtk.Switch()
        sep_sw.set_active(self._cfg.get("separators", False))
        sep_sw.set_halign(Gtk.Align.START)
        self._w["separators"] = sep_sw
        sep_sw.connect("notify::active", self._refresh_preview)
        box.pack_start(_row("Module separators", sep_sw), False, False, 0)

        current_ff  = self._cfg.get("font-family", "Product Sans")
        current_fsz = self._cfg.get("font-size", 13)
        fb = Gtk.FontButton()
        # include size so dialog opens with current value pre-selected
        fb.set_font(f"{current_ff} {current_fsz}")
        fb.set_use_size(True)
        fb.set_show_size(True)
        fb.set_halign(Gtk.Align.START)
        self._w["font-family"] = fb

        font_sz = _spin(current_fsz, 8, 48)
        self._w["font-size"] = font_sz
        font_sz.connect("value-changed", self._refresh_preview)

        def _on_font_set(btn):
            desc   = Pango.FontDescription.from_string(btn.get_font_name())
            family = desc.get_family()
            if family:
                self._cfg["font-family"] = family
            sz = desc.get_size()
            if sz > 0:
                px = max(8, min(48, sz // Pango.SCALE))
                font_sz.set_value(px)
            self._refresh_preview()

        fb.connect("font-set", _on_font_set)
        box.pack_start(_row("Font family", fb), False, False, 0)
        box.pack_start(_row("Font size (px)", font_sz), False, False, 0)

        mod_pad = _spin(self._cfg.get("mod-padding", 8), 0, 30)
        self._w["mod-padding"] = mod_pad
        mod_pad.connect("value-changed", self._refresh_preview)
        box.pack_start(_row("Module padding (px)", mod_pad), False, False, 0)

        box.pack_start(_section("Margins"), False, False, 0)

        mt = _spin(self._cfg["margin-top"], 0, 60)
        self._w["margin-top"] = mt
        mt.connect("value-changed", self._refresh_preview)
        box.pack_start(_row("Margin top (px)", mt), False, False, 0)

        mb = _spin(self._cfg.get("margin-bottom", 0), 0, 60)
        self._w["margin-bottom"] = mb
        mb.connect("value-changed", self._refresh_preview)
        box.pack_start(_row("Margin bottom (px)", mb), False, False, 0)

        ml = _spin(self._cfg.get("margin-left", 10), 0, 100)
        self._w["margin-left"] = ml
        ml.connect("value-changed", self._refresh_preview)
        box.pack_start(_row("Margin left (px)", ml), False, False, 0)

        mr = _spin(self._cfg.get("margin-right", 10), 0, 100)
        self._w["margin-right"] = mr
        mr.connect("value-changed", self._refresh_preview)
        box.pack_start(_row("Margin right (px)", mr), False, False, 0)

        box.pack_start(
            _hint("Margins set the space between the bar and the screen edge.\nLeft and right are not shown in the preview — apply to see them on the system."),
            False, False, 0
        )

        sep = Gtk.Separator()
        sep.set_margin_top(16)
        sep.set_margin_bottom(8)
        box.pack_start(sep, False, False, 0)

        def_btn = Gtk.Button(label="↺  Load defaults")
        def_btn.get_style_context().add_class("open-btn")
        def_btn.set_tooltip_text("Restore default bar settings")
        def_btn.connect("clicked", self._load_default_bar)
        box.pack_start(def_btn, False, False, 0)

        return _scrolled(box)

    # ── page: Layout ──────────────────────────────────────────────────────────

    def _page_layout(self) -> Gtk.Widget:
        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)

        # Zone editors
        zones_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        zones_box.set_homogeneous(True)
        for zone_key, zone_label in (
            ("modules-left",   "Left"),
            ("modules-center", "Center"),
            ("modules-right",  "Right"),
        ):
            col = self._make_zone_editor(zone_key, zone_label)
            zones_box.pack_start(col, True, True, 0)

        outer.pack_start(zones_box, True, True, 0)

        foot = Gtk.Box(spacing=0)
        foot.set_margin_start(14)
        foot.set_margin_end(14)
        foot.set_margin_top(6)
        foot.set_margin_bottom(10)
        def_btn = Gtk.Button(label="↺  Load defaults")
        def_btn.get_style_context().add_class("open-btn")
        def_btn.set_tooltip_text("Restore the original left / center / right layout")
        def_btn.connect("clicked", self._load_default_layout)
        foot.pack_start(def_btn, False, False, 0)
        outer.pack_start(foot, False, False, 0)

        return outer

    def _draw_zone_preview(self, widget, cr, side):
        """Render a single zone (left or right) at natural scale for detail view."""
        AW = widget.get_allocated_width()
        AH = widget.get_allocated_height()
        c  = self._css_colors

        def _col(name, fb): return _hex_to_rgb(c.get(name, fb))
        base     = _col("base",     "#11140e")
        surface0 = _col("surface0", "#1d211a")
        overlay0 = _col("overlay0", "#33362f")
        sub0     = _col("subtext0", "#c4c8bb")
        blue     = _col("blue",     "#abd290")
        mauve    = _col("mauve",    "#abd290")
        green    = _col("green",    "#a0cfcf")
        peach    = _col("peach",    "#1e4e4e")
        red_c    = _col("red",      "#ffb4ab")
        text_c   = _col("text",     "#e1e4d9")
        MOD_COLOR = {
            "custom/arch": blue, "hyprland/workspaces": sub0,
            "hyprland/window": sub0, "custom/weather": text_c,
            "clock": blue, "tray": sub0,
            "custom/updates": green, "pulseaudio": blue,
            "network": green, "memory": mauve,
            "cpu": peach, "battery": green,
            "custom/swaync": text_c, "custom/power": red_c,
        }

        bar_style = self._cfg.get("bar-style",   "islands")
        zone_r    = self._cfg.get("zone-radius",  12)
        font_sz   = self._cfg.get("font-size",    13)
        _arch_icon_sz = _parse_arch_icon_sz(self._cfg, font_sz)
        mod_pad   = self._cfg.get("mod-padding",  8)
        spacing   = self._cfg.get("spacing",       4)
        opacity   = self._cfg.get("opacity",       95) / 100
        separators= self._cfg.get("separators",   False)
        brd_w     = self._cfg.get("border-width",  1)
        ff        = self._cfg.get("font-family",  "JetBrainsMono Nerd Font Mono")

        zone_key  = f"modules-{side}"
        mods      = self._cfg.get(zone_key, [])

        # bg
        cr.set_source_rgb(*_hex_to_rgb(self._theme["bg"]))
        cr.paint()

        if not mods:
            return

        # measure content width at natural scale (sx=1)
        def _mod_w(mod):
            lo = PangoCairo.create_layout(cr)
            fd = Pango.FontDescription.from_string(ff)
            fd.set_absolute_size(max(6, font_sz) * Pango.SCALE)
            lo.set_font_description(fd)
            s = (self._cfg.get("custom/arch", {}).get("arch-icon-glyph", "󰣇") if mod == "custom/arch" else MOD_SAMPLE.get(mod))
            if s is None:
                icon, name = MODULE_LABELS.get(mod, ("", mod.split("/")[-1]))
                s = f"{icon} {name}" if icon else name
            lo.set_text(s, -1)
            tw, _ = lo.get_pixel_size()
            if mod == "custom/arch":
                _pl = self._cfg.get("custom/arch", {}).get("arch-pad-left",  8)
                _pr = self._cfg.get("custom/arch", {}).get("arch-pad-right", 8)
                return tw + _pl + _pr
            return tw + mod_pad * 2

        _arch_col_hex_z = _parse_arch_icon_color(self._cfg)
        _arch_col_rgb_z = _hex_to_rgb(_arch_col_hex_z) if _arch_col_hex_z else None

        sp     = spacing
        zone_w = mod_pad * 2 + sum(_mod_w(m) for m in mods) + max(0, len(mods)-1) * sp

        # position: left zone → left-aligned, right zone → right-aligned
        if side == "left":
            zx = 12
        else:
            zx = max(12, AW - zone_w - 12)

        bar_h = self._cfg.get("height", 36)
        zy    = (AH - bar_h) // 2

        # zone pill
        if bar_style in ("islands", "modules"):
            cr.set_source_rgba(*base, opacity)
            _cr_rounded_rect(cr, zx, zy, zone_w, bar_h, zone_r)
            cr.fill()
            if brd_w > 0:
                cr.set_source_rgb(*surface0)
                cr.set_line_width(brd_w)
                _cr_rounded_rect(cr, zx+.5, zy+.5, zone_w-1, bar_h-1, zone_r)
                cr.stroke()
        else:  # bar
            cr.set_source_rgba(*base, opacity)
            cr.rectangle(0, zy, AW, bar_h)
            cr.fill()

        # modules content
        mx = zx + mod_pad
        for mod in mods:
            mw  = _mod_w(mod)
            col = MOD_COLOR.get(mod, sub0) if mod != self._selected_module else blue
            lo  = PangoCairo.create_layout(cr)
            fd  = Pango.FontDescription.from_string(
                      ff + (" Bold" if mod == "clock" else
                            " Italic" if mod == "hyprland/window" else ""))
            fd.set_absolute_size((_arch_icon_sz if mod == "custom/arch" else font_sz) * Pango.SCALE)
            lo.set_font_description(fd)
            s = (self._cfg.get("custom/arch", {}).get("arch-icon-glyph", "󰣇") if mod == "custom/arch" else MOD_SAMPLE.get(mod))
            if s is None:
                icon, name = MODULE_LABELS.get(mod, ("", mod.split("/")[-1]))
                s = f"{icon} {name}" if icon else name
            lo.set_text(s, -1)
            tw, th = lo.get_pixel_size()
            if mod == "custom/arch":
                draw_col_z = _arch_col_rgb_z if _arch_col_rgb_z else col
                _pl = self._cfg.get("custom/arch", {}).get("arch-pad-left", 8)
                tx_z = mx + _pl
            else:
                draw_col_z = col
                tx_z = mx + (mw - tw) / 2
            cr.set_source_rgb(*draw_col_z)
            cr.move_to(tx_z, zy + (bar_h - th) / 2)
            PangoCairo.show_layout(cr, lo)
            mx += mw + sp

        # separators
        if separators and bar_style in ("islands", "bar") and len(mods) > 1:
            sep_inset = int(bar_h * 0.2)
            cr.set_source_rgb(*overlay0)
            cr.set_line_width(1.0)
            mx = zx + mod_pad
            for mod in mods[:-1]:
                mx += _mod_w(mod)
                sep_x = mx + max(sp, 2) / 2
                cr.move_to(sep_x, zy + sep_inset)
                cr.line_to(sep_x, zy + bar_h - sep_inset)
                cr.stroke()
                mx += sp

    def _draw_bar_preview(self, widget, cr):
        AW = widget.get_allocated_width()
        AH = widget.get_allocated_height()
        c  = self._css_colors

        # ── colors ────────────────────────────────────────────────────────────
        def _col(name, fb): return _hex_to_rgb(c.get(name, fb))
        base     = _col("base",     "#11140e")
        surface0 = _col("surface0", "#1d211a")
        surface1 = _col("surface1", "#282b24")
        overlay0 = _col("overlay0", "#33362f")
        sub0     = _col("subtext0", "#c4c8bb")
        blue     = _col("blue",     "#abd290")
        mauve    = _col("mauve",    "#abd290")
        green    = _col("green",    "#a0cfcf")
        peach    = _col("peach",    "#1e4e4e")
        red_c    = _col("red",      "#ffb4ab")
        text_c   = _col("text",     "#e1e4d9")

        MOD_COLOR = {
            "custom/arch":         blue,   "hyprland/workspaces": sub0,
            "hyprland/window":     sub0,   "custom/weather":      text_c,
            "clock":               blue,   "tray":                sub0,
            "custom/updates":      green,  "pulseaudio":          blue,
            "network":             green,  "memory":              mauve,
            "cpu":                 peach,  "battery":             green,
            "custom/swaync":       text_c, "custom/power":        red_c,
        }

        # ── CSS natural dimensions (px, not pt) ───────────────────────────────
        ZONE_PV  = 2
        _ws_c    = self._cfg.get("hyprland/workspaces", {})
        WS_PH    = int(_ws_c.get("button-pad-h",  14))
        WS_PV    = int(_ws_c.get("button-pad-v",   4))
        WS_MINW  = int(_ws_c.get("button-minw",   32))
        WS_R     = int(_ws_c.get("button-radius",   8))

        bar_h_nat  = self._cfg.get("height",      36)
        zone_r_nat = self._cfg.get("zone-radius", 12)
        spacing    = self._cfg.get("spacing",      4)
        ml_nat     = self._cfg.get("margin-left",  10)
        mr_nat     = self._cfg.get("margin-right", 10)
        position   = self._cfg.get("position",    "top")
        mt_nat     = self._cfg.get("margin-top",    6)
        mb_nat     = self._cfg.get("margin-bottom", 0)
        bar_style  = self._cfg.get("bar-style",   "islands")
        separators = self._cfg.get("separators",  False)
        brd_w_nat  = self._cfg.get("border-width", 1)
        font_sz    = self._cfg.get("font-size",    13)
        _arch_icon_sz = _parse_arch_icon_sz(self._cfg, font_sz)
        MOD_PH     = self._cfg.get("mod-padding",  8)
        ZONE_PH    = MOD_PH
        # extract first font name from CSS font-family string for Pango
        _raw_ff    = self._cfg.get("font-family", "Product Sans")
        _first_ff  = _raw_ff.split(",")[0].strip().strip('"').strip("'")

        # ── scale: fit bar on a 1920px virtual canvas, never enlarge ──────────
        VW = 1920.0
        sx = min(AW / VW, 1.0)   # only scale down, never up

        bar_h  = bar_h_nat * sx
        mt     = mt_nat * sx
        mb     = mb_nat * sx
        bar_y  = mt if position != "bottom" else (AH - mb - bar_h)

        # ── background: editor theme ──────────────────────────────────────────
        cr.set_source_rgb(*_hex_to_rgb(self._theme["bg"]))
        cr.paint()

        # ── Pango helpers — font sizes in CSS px, scaled by sx ────────────────
        def _lo(text, css_px=None, bold=False, italic=False):
            if css_px is None: css_px = font_sz
            lo = PangoCairo.create_layout(cr)
            style = ("Bold " if bold else "") + ("Italic" if italic else "")
            fd = Pango.FontDescription.from_string(
                f"{_first_ff} {style.strip()}"
            )
            fd.set_absolute_size(max(6, int(css_px * sx)) * Pango.SCALE)
            lo.set_font_description(fd)
            lo.set_text(text, -1)
            return lo

        # get_pixel_size() → screen pixels (device units)
        def _sz(lo): return lo.get_pixel_size()

        # Draw text centered at a natural-coordinate center point
        def _txt(cx_nat, cy_nat, lo, rgb):
            tw, th = _sz(lo)
            cr.set_source_rgb(*rgb)
            cr.move_to(cx_nat * sx - tw / 2, cy_nat * sx + bar_y - th / 2)
            PangoCairo.show_layout(cr, lo)

        # Filled rounded rect (natural coords)
        def _fill(x, y, w, h, r, rgba):
            cr.set_source_rgba(*rgba)
            _cr_rounded_rect(cr, x * sx, y * sx + bar_y, w * sx, h * sx, r * sx)
            cr.fill()

        # Stroked rounded rect (natural coords, 1 device px border)
        def _stroke(x, y, w, h, r, rgb):
            cr.set_source_rgb(*rgb)
            cr.set_line_width(1)
            o = 0.5
            _cr_rounded_rect(cr, x*sx + o, y*sx + bar_y + o, w*sx - 1, h*sx - 1, r*sx)
            cr.stroke()

        # ── workspaces ────────────────────────────────────────────────────────
        ws_cfg     = self._cfg.get("hyprland/workspaces", {})
        persistent = ws_cfg.get("persistent-workspaces", {}).get("*", [1, 2, 3, 4, 5])
        if not isinstance(persistent, list) or not persistent:
            persistent = [1, 2, 3, 4, 5]
        ws_active = persistent[len(persistent) // 2]  # middle = active

        # animated active-workspace color (mirrors @keyframes ws-active)
        _ac1 = _hex_to_rgb(ws_cfg.get("anim-color-1", "#2980b9"))
        _ac2 = _hex_to_rgb(ws_cfg.get("anim-color-2", "#420ed2"))
        _pulse = abs(math.sin(self._ws_anim_t * math.pi))
        ws_act_col = tuple(_ac1[i] * (1 - _pulse) + _ac2[i] * _pulse for i in range(3))

        def _ws_w(n):
            tw, _ = _sz(_lo(str(n), 14, bold=True))
            return max(int(WS_MINW * sx), tw + int(WS_PH * 2 * sx))

        ws_widths = [_ws_w(n) for n in persistent]
        ws_total_px = sum(ws_widths) + int(spacing * sx) * max(0, len(persistent) - 1)

        def _draw_ws(x0_nat):
            ws_h_px = int((bar_h_nat - WS_PV * 2) * sx)
            ws_y_px = int(WS_PV * sx) + bar_y
            wx_px   = x0_nat * sx
            sp_px   = int(spacing * sx)
            for i, n in enumerate(persistent):
                ww = ws_widths[i]
                act = (n == ws_active)
                cr.set_source_rgb(*(ws_act_col if act else surface0))
                _r = min(WS_R * sx, ws_h_px / 2, ww / 2)
                _cr_rounded_rect(cr, wx_px, ws_y_px, ww, ws_h_px, _r)
                cr.fill()
                lo = _lo(str(n), 14, bold=True)
                tw, th = _sz(lo)
                cr.set_source_rgb(*(base if act else sub0))
                cr.move_to(wx_px + (ww - tw) / 2, ws_y_px + (ws_h_px - th) / 2)
                PangoCairo.show_layout(cr, lo)
                wx_px += ww + sp_px

        # ── module widths (natural px) → screen px ────────────────────────────
        _arch_pl = self._cfg.get("custom/arch", {}).get("arch-pad-left",  8)
        _arch_pr = self._cfg.get("custom/arch", {}).get("arch-pad-right", 8)
        _arch_col_hex = _parse_arch_icon_color(self._cfg)
        _arch_col_rgb = _hex_to_rgb(_arch_col_hex) if _arch_col_hex else None

        def _mod_w_px(mod):
            if mod == "hyprland/workspaces":
                return ws_total_px + int(MOD_PH * 2 * sx)
            s = (self._cfg.get("custom/arch", {}).get("arch-icon-glyph", "󰣇") if mod == "custom/arch" else MOD_SAMPLE.get(mod))
            if s is None:
                icon, name = MODULE_LABELS.get(mod, ("", mod.split("/")[-1]))
                s = f"{icon} {name}" if icon else name
            cpx    = (_arch_icon_sz if mod == "custom/arch" else font_sz)
            bold   = (mod == "clock")
            italic = (mod == "hyprland/window")
            tw, _  = _sz(_lo(s, cpx, bold=bold, italic=italic))
            if mod == "custom/arch":
                return tw + int((_arch_pl + _arch_pr) * sx)
            return tw + int(MOD_PH * 2 * sx)

        def _zone_w_px(mods):
            if not mods: return 0
            sp = int(spacing * sx)
            return (int(ZONE_PH * 2 * sx)
                    + sum(_mod_w_px(m) for m in mods)
                    + sp * max(0, len(mods) - 1))

        # ── draw zone (positions already in screen px) ────────────────────────
        def _draw_zone_px(zx_px, mods, pill=True):
            if not mods: return
            zw = _zone_w_px(mods)
            zy = bar_y
            bh = bar_h
            r  = zone_r_nat * sx
            pv = int(ZONE_PV * sx)
            ph = int(ZONE_PH * sx)
            sp = int(spacing * sx)

            # Zone container (only in "islas" mode)
            if pill:
                cr.set_source_rgba(*base, self._cfg.get("opacity", 95) / 100)
                _cr_rounded_rect(cr, zx_px, zy, zw, bh, r)
                cr.fill()
                cr.set_source_rgb(*surface0)
                cr.set_line_width(1)
                _cr_rounded_rect(cr, zx_px + .5, zy + .5, zw - 1, bh - 1, r)
                cr.stroke()

            # Selected highlight
            mx = zx_px + ph
            for mod in mods:
                mw = _mod_w_px(mod)
                if mod == self._selected_module:
                    cr.set_source_rgba(*blue, 0.20)
                    _cr_rounded_rect(cr, mx, zy + pv, mw, bh - pv * 2, 8 * sx)
                    cr.fill()
                mx += mw + sp

            # Content
            mx = zx_px + ph
            for mod in mods:
                mw  = _mod_w_px(mod)
                col = blue if mod == self._selected_module else MOD_COLOR.get(mod, sub0)

                if mod == "hyprland/workspaces":
                    # workspaces draw function starts at mx+MOD_PH (in natural, but we're already in px)
                    ws_h_px = int((bar_h_nat - WS_PV * 2) * sx)
                    ws_y_px = int(WS_PV * sx) + bar_y
                    wx_px   = mx + int(MOD_PH * sx)
                    sp_px   = int(spacing * sx)
                    for i, n in enumerate(persistent):
                        ww = ws_widths[i]
                        act = (n == ws_active)
                        cr.set_source_rgb(*(ws_act_col if act else surface0))
                        _r = min(WS_R * sx, ws_h_px / 2, ww / 2)
                        _cr_rounded_rect(cr, wx_px, ws_y_px, ww, ws_h_px, _r)
                        cr.fill()
                        lo = _lo(str(n), 14, bold=True)
                        tw, th = _sz(lo)
                        cr.set_source_rgb(*(base if act else sub0))
                        cr.move_to(wx_px + (ww - tw) / 2, ws_y_px + (ws_h_px - th) / 2)
                        PangoCairo.show_layout(cr, lo)
                        wx_px += ww + sp_px
                else:
                    s = (self._cfg.get("custom/arch", {}).get("arch-icon-glyph", "󰣇") if mod == "custom/arch" else MOD_SAMPLE.get(mod))
                    if s is None:
                        icon, name = MODULE_LABELS.get(mod, ("", mod.split("/")[-1]))
                        s = f"{icon} {name}" if icon else name
                    cpx    = (_arch_icon_sz if mod == "custom/arch" else font_sz)
                    bold   = (mod == "clock")
                    italic = (mod == "hyprland/window")
                    lo = _lo(s, cpx, bold=bold, italic=italic)
                    tw, th = _sz(lo)
                    if mod == "custom/arch":
                        draw_col = _arch_col_rgb if _arch_col_rgb else col
                        tx = mx + int(_arch_pl * sx)
                    else:
                        draw_col = col
                        tx = mx + (mw - tw) / 2
                    cr.set_source_rgb(*draw_col)
                    cr.move_to(tx, bar_y + (bar_h - th) / 2)
                    PangoCairo.show_layout(cr, lo)

                mx += mw + sp

            # Separators (islas / barra only, not after last module)
            if separators and bar_style in ("islands", "bar") and len(mods) > 1:
                sep_inset = int(bar_h * 0.2)
                cr.set_source_rgb(*overlay0)
                cr.set_line_width(max(1.0, sx))
                mx = zx_px + ph
                for mod in mods[:-1]:
                    mx += _mod_w_px(mod)
                    sep_x = mx + max(sp, 2) / 2
                    cr.move_to(sep_x, bar_y + sep_inset)
                    cr.line_to(sep_x, bar_y + bar_h - sep_inset)
                    cr.stroke()
                    mx += sp

        # ── layout ────────────────────────────────────────────────────────────
        mods_l = self._cfg.get("modules-left",   [])
        mods_c = self._cfg.get("modules-center",  [])
        mods_r = self._cfg.get("modules-right",   [])
        all_mods = mods_l + mods_c + mods_r

        zw_l = _zone_w_px(mods_l)
        zw_c = _zone_w_px(mods_c)
        zw_r = _zone_w_px(mods_r)

        if bar_style == "bar":
            # Single full-width bar — no zone pills, transparent background zones
            bar_x = ml_nat * sx
            bar_w = AW - (ml_nat + mr_nat) * sx
            cr.set_source_rgba(*base, self._cfg.get("opacity", 95) / 100)
            _cr_rounded_rect(cr, bar_x, bar_y, bar_w, bar_h, zone_r_nat * sx)
            cr.fill()
            cr.set_source_rgb(*surface0)
            cr.set_line_width(1)
            _cr_rounded_rect(cr, bar_x + .5, bar_y + .5, bar_w - 1, bar_h - 1, zone_r_nat * sx)
            cr.stroke()
            # Draw zones without their own pill containers (pass draw_bg=False)
            _draw_zone_px(ml_nat * sx,        mods_l,  pill=False)
            _draw_zone_px((AW - zw_c) / 2,   mods_c,  pill=False)
            _draw_zone_px(AW - mr_nat*sx - zw_r, mods_r, pill=False)

        elif bar_style == "modules":
            # Each module is its own individual pill
            sp = int(spacing * sx)
            ph = int(ZONE_PH * sx)
            def _draw_mod_pills(x0_px, mods):
                mx = x0_px
                for mod in mods:
                    mw = _mod_w_px(mod)
                    cr.set_source_rgba(*base, self._cfg.get("opacity", 95) / 100)
                    _cr_rounded_rect(cr, mx, bar_y, mw, bar_h, zone_r_nat * sx)
                    cr.fill()
                    cr.set_source_rgb(*surface0)
                    cr.set_line_width(1)
                    _cr_rounded_rect(cr, mx+.5, bar_y+.5, mw-1, bar_h-1, zone_r_nat*sx)
                    cr.stroke()
                    mx += mw + sp
                return mx
            total_r = sum(_mod_w_px(m) + sp for m in mods_r) - sp
            _draw_mod_pills(ml_nat * sx, mods_l)
            cx = (AW - sum(_mod_w_px(m) + sp for m in mods_c) + sp) / 2
            _draw_mod_pills(cx, mods_c)
            _draw_mod_pills(AW - mr_nat * sx - total_r, mods_r)
            # draw content without pill containers
            _draw_zone_px(ml_nat * sx,        mods_l,  pill=False)
            _draw_zone_px((AW - zw_c) / 2,   mods_c,  pill=False)
            _draw_zone_px(AW - mr_nat*sx - zw_r, mods_r, pill=False)

        else:  # "islands" (default)
            _draw_zone_px(ml_nat * sx,            mods_l)
            _draw_zone_px((AW - zw_c) / 2,       mods_c)
            _draw_zone_px(AW - mr_nat*sx - zw_r,  mods_r)

