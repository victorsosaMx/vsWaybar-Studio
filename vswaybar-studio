        has_drawer = "drawer" in gcfg or gcfg.get("_drawer_enabled", False)
        drawer_sw_row, drawer_sw = _switch_row("Enable drawer", has_drawer)
        self._w["_grp_drawer_sw"] = drawer_sw
        outer.pack_start(drawer_sw_row, False, False, 0)

        drawer_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        drawer_src = gcfg.get("drawer", {})

        dur_spin = _spin(drawer_src.get("transition-duration", 500), 0, 2000, 50)
        self._w["_grp_drawer_dur"] = dur_spin
        drawer_box.pack_start(_row("Duration (ms)", dur_spin), False, False, 0)

        cls_entry = Gtk.Entry()
        cls_entry.set_text(drawer_src.get("children-class", ""))
        cls_entry.set_placeholder_text("CSS class for children")
        self._w["_grp_drawer_cls"] = cls_entry
        drawer_box.pack_start(_row("Children class", cls_entry), False, False, 0)

        ltr_row, ltr_sw = _switch_row("Left-to-right", drawer_src.get("transition-left-to-right", False))
        self._w["_grp_drawer_ltr"] = ltr_sw
        drawer_box.pack_start(ltr_row, False, False, 0)

