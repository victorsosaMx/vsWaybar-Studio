    def _rebuild_ui(self):
        page = self._notebook.get_current_page() if self._notebook else 0
        for child in self.get_children():
            self.remove(child)
        self._build_ui()
        self._notebook.set_current_page(page)
        self.show_all()
    def _validate_layout(self):
        """Warn about unrecognized modules in layout and unknown config blocks."""
        all_zones = (
            self._cfg.get("modules-left", []) +
            self._cfg.get("modules-center", []) +
            self._cfg.get("modules-right", [])
        )
        known = (set(ALL_MODULES) |
                 {f"custom/{s}" for s in self._cfg.get("_user_modules", [])} |
                 set(self._cfg.get("_named_instances", [])) |
                 set(self._groups.keys()) |
                 set(self._cffi_modules.keys()))

        # Modules in layout that the app doesn't know how to edit
        uneditable_in_layout = [m for m in all_zones if m not in known]

        # Config blocks preserved verbatim (not editable)
        unknown = list(self._unknown_blocks.keys())

        msgs = []
        if uneditable_in_layout:
            msgs.append(f"layout: {', '.join(uneditable_in_layout)}")
        if unknown:
            msgs.append(f"preserved: {', '.join(unknown)}")

        if msgs:
            count = len(uneditable_in_layout) + len(unknown)
            self._show_alert(
                f"⚠  {count} unrecognized module(s) — preserved but not editable here",
                " · ".join(msgs),
            )

    def _show_alert(self, title: str, detail: str = "", error: bool = False):
        """Show a dismissible banner below the preview."""
        if not hasattr(self, "_alert_bar") or self._alert_bar is None:
            return
        bar = self._alert_bar

        # Clear previous content
        for ch in bar.get_children():
            bar.remove(ch)

        css_cls = "alert-bar-error" if error else "alert-bar"
        ctx = bar.get_style_context()
        ctx.remove_class("alert-bar")
        ctx.remove_class("alert-bar-error")
        ctx.add_class(css_cls)

        row = Gtk.Box(spacing=10)

        icon = Gtk.Label()
        icon.set_markup(f'<span foreground="{"#e05050" if error else "#d4a017"}" size="14000">{"⛔" if error else "⚠"}</span>')
        row.pack_start(icon, False, False, 0)

        text_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=1)
        t_lbl = Gtk.Label()
        t_lbl.set_markup(f"<b>{title}</b>")
        t_lbl.set_halign(Gtk.Align.START)
        text_box.pack_start(t_lbl, False, False, 0)
        if detail:
            d_lbl = Gtk.Label(label=detail)
            d_lbl.set_halign(Gtk.Align.START)
            d_lbl.set_line_wrap(True)
            text_box.pack_start(d_lbl, False, False, 0)
        row.pack_start(text_box, True, True, 0)

        close = Gtk.Button(label="×")
        close.set_relief(Gtk.ReliefStyle.NONE)
        def _close(*_):
            bar.hide()
            bar.set_no_show_all(True)
        close.connect("clicked", _close)
        row.pack_start(close, False, False, 0)

        bar.pack_start(row, True, True, 0)
        bar.set_no_show_all(False)
        bar.show_all()

