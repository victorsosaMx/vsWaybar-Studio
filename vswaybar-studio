        self._w.pop("_menu_file_entry",    None)
        self._w.pop("_menu_e_label",       None)
        self._w.pop("_menu_e_id",          None)
        self._w.pop("_menu_e_cmd",         None)
        self._w.pop("_pending_menu_xml",   None)
        self._w.pop("_grp_orient",        None)
        self._w.pop("_grp_drawer_sw",     None)
        self._w.pop("_grp_drawer_dur",    None)
        self._w.pop("_grp_drawer_cls",    None)
        self._w.pop("_grp_drawer_ltr",    None)
        self._w.pop("_grp_mod_store",     None)
        self._w.pop("_cffi_path",         None)
        self._w.pop("_cffi_extra",        None)
        suffix = mod_key[7:] if mod_key.startswith("custom/") else ""
        if mod_key.startswith("cffi/"):
            panel = self._build_cffi_form(mod_key)
        elif mod_key.startswith("group/"):
            panel = self._build_group_form(mod_key)
        elif suffix and suffix not in _RESERVED_CUSTOM:
            src = self._dock_cfg if self._selected_module_is_dock else self._cfg
            panel = self._build_user_module_form(mod_key, source_cfg=src)
