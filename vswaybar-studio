# ── JSONC parser ───────────────────────────────────────────────────────────────

def _jsonc_loads(text: str):
    """Parse JSON with C-style comments (// and /* */) and trailing commas."""
    # Strip comments without touching strings
    _PATTERN = re.compile(
        r'"(?:[^"\\]|\\.)*"'   # string literals — keep as-is
        r'|//[^\n]*'            # // line comments  — remove
        r'|/\*.*?\*/',          # /* block comments */ — remove
        re.DOTALL
    )
    def _strip(m):
        s = m.group(0)
        return s if s.startswith('"') else (" " if s.startswith("//") else "")
    cleaned = _PATTERN.sub(_strip, text)
    # Remove trailing commas before ] or }  (common in JSONC)
    cleaned = re.sub(r',\s*([}\]])', r'\1', cleaned)
    return json.loads(cleaned)

def _jsonc_load(fp):
    return _jsonc_loads(fp.read())

# ── paths ─────────────────────────────────────────────────────────────────────

def _detect_config_path():
    """Return first existing waybar config, trying common names in order."""
    base = os.path.expanduser("~/.config/waybar")
    for name in ("config.jsonc", "config.json", "config"):
        p = os.path.join(base, name)
        if os.path.exists(p):
            return p
    return os.path.join(base, "config.jsonc")   # fallback (will be created on save)

CONFIG_PATH = _detect_config_path()
