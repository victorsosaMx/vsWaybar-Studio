                    e.set_text(fd.get_filename())
                fd.destroy()
            browse.connect("clicked", _browse)
            grid.attach(browse, 2, row, 1, 1)
            return entry

        cfg_entry = _make_row(
            "Config (JSON):", self._config_path, 0,
            [("Waybar config", ["*.json", "*.jsonc", "config"])]
        )
        css_entry = _make_row(
