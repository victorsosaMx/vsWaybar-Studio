    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 22px;
}

window#waybar.dock {
    background: transparent;
    border-radius: 0px;
    border: none;
    color: @text;
}

window#waybar.dock .modules-left,
window#waybar.dock .modules-center,
window#waybar.dock .modules-right {
    background: rgba(40,42,54,0.90);
    border-radius: 16px;
    padding: 4px 14px;
    border: 2px solid @surface0;
    min-height: 0;
}

tooltip {
    background: @surface0;
    border: 1px solid @overlay0;
    border-radius: 8px;
    color: @text;
}

tooltip label {
    color: @text;
}
"""

