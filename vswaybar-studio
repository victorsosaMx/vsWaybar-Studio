        "zone-radius":  zone_radius,
        "border-width": border_width,
        "height":       height,
        "spacing":      spacing,
        "mod-padding":  mod_padding,
        "ws-color-1":   ws_color1 or css["blue"],
        "ws-color-2":   ws_color2 or css["mauve"],
        "ws-radius":    ws_radius,
        "logo-glyph":   logo_glyph,
        "logo-size":    logo_size,
        "logo-color":   logo_color or css["text"],
    }

