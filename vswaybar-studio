            desc_lbl.set_text(desc)
            tv.get_buffer().set_text(self._read_script(path))

        combo.connect("changed", _on_script_change)

        return outer

    def _read_script(self, path: str) -> str:
        try:
            with open(os.path.expanduser(path)) as f:
                return f.read()
        except FileNotFoundError:
            return f"# {os.path.expanduser(path)}\n# File not found\n"

    def _script_text(self) -> str | None:
        tv = self._w.get("script_tv")
        if not tv: return None
        buf = tv.get_buffer()
        return buf.get_text(*buf.get_bounds(), True)

    def _save_current_script(self, *_):
        combo = self._w.get("script_combo")
        if not combo: return
        idx = combo.get_active()
        if idx < 0: return
        _, path, _, _dsrc = self._SCRIPTS[idx]
        path = os.path.expanduser(path)
        text = self._script_text()
        if text is None: return
        try:
            os.makedirs(os.path.dirname(path), exist_ok=True)
            # backup if file already exists
            if os.path.exists(path):
                import datetime
                ts  = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
                bak = f"{path}.{ts}.bak"
                import shutil as _sh
                _sh.copy2(path, bak)
            with open(path, "w") as f:
                f.write(text)
            self._status(f"✓  Saved  {os.path.basename(path)}", "· backup created")
        except Exception as e:
            self._err(f"Error saving script:\n{e}")

    def _save_script_as(self, *_):
        text = self._script_text()
        if text is None: return
        combo = self._w.get("script_combo")
        idx   = combo.get_active() if combo else 0
        _, default_path, _, _dsrc = self._SCRIPTS[idx] if idx >= 0 else self._SCRIPTS[0]
        dlg = Gtk.FileChooserDialog(
            title="Save script as…", parent=self,
            action=Gtk.FileChooserAction.SAVE,
            buttons=("Cancel", Gtk.ResponseType.CANCEL, "Save", Gtk.ResponseType.OK),
        )
        dlg.set_current_name(os.path.basename(os.path.expanduser(default_path)))
        if dlg.run() == Gtk.ResponseType.OK:
            path = dlg.get_filename()
            dlg.destroy()
            try:
                with open(path, "w") as f:
                    f.write(text)
                self._status(f"✓  Saved as  {os.path.basename(path)}")
            except Exception as e:
                self._err(f"Error saving:\n{e}")
        else:
            dlg.destroy()

    def _load_default_script(self, *_):
        combo = self._w.get("script_combo")
        if not combo: return
        idx = combo.get_active()
        if idx < 0: return
        _, _, _, default_src = self._SCRIPTS[idx]
        if not default_src:
            self._status("No bundled default for this script.")
            return
        app_dir  = os.path.dirname(os.path.abspath(__file__))
        src_path = os.path.join(app_dir, default_src)
        try:
            with open(src_path) as f:
                text = f.read()
        except FileNotFoundError:
            self._err(f"Default not found:\n{src_path}")
            return
        tv = self._w.get("script_tv")
        if tv:
            tv.get_buffer().set_text(text)
        self._status("↺  Default loaded — press Save to apply.")

