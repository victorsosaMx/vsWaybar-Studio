    def _load_palette_from_image(self, *_):
        if not shutil.which("matugen"):
            self._err("matugen not found.\n\nInstall it with:\n  yay -S matugen")
            return
        img = _file_chooser(self, "Select image for palette extraction",
                            mime_types=["image/png", "image/jpeg", "image/webp",
                                        "image/jpg", "image/bmp"])
        if not img:
            return
        mode = self._rnd_mode.get_active_id() if self._rnd_mode else "dark"
        try:
            result = subprocess.run(
                ["matugen", "image", img, "-m", mode, "-j", "hex",
                 "--source-color-index", "0", "--dry-run"],
                capture_output=True, text=True, timeout=15,
            )
            if result.returncode != 0 or not result.stdout.strip():
                result = subprocess.run(
                    ["matugen", "image", img, "-m", mode, "-j", "hex",
                     "--source-color-index", "0"],
                    capture_output=True, text=True, timeout=15,
                )
            if not result.stdout.strip():
                self._err(f"matugen produced no output.\n{result.stderr.strip()}")
                return
            colors = json.loads(result.stdout)["colors"]
        except Exception as e:
            self._err(f"matugen failed:\n{e}")
            return
        self._apply_matugen_colors(colors, "󰸉  Palette extracted from image")

    def _load_palette_from_color(self, *_):
        if not shutil.which("matugen"):
            self._err("matugen not found.\n\nInstall it with:\n  yay -S matugen")
            return
        dlg = Gtk.ColorChooserDialog(title="Pick a base color", parent=self)
        if dlg.run() != Gtk.ResponseType.OK:
            dlg.destroy()
            return
        rgba = dlg.get_rgba()
        dlg.destroy()
        hex_color = _rgba_to_hex(rgba)
        mode = self._rnd_mode.get_active_id() if self._rnd_mode else "dark"
        try:
            result = subprocess.run(
                ["matugen", "color", "hex", hex_color,
                 "-m", mode, "-j", "hex", "--dry-run"],
                capture_output=True, text=True, timeout=15,
            )
            if not result.stdout.strip():
                self._err(f"matugen produced no output.\n{result.stderr.strip()}")
                return
            colors = json.loads(result.stdout)["colors"]
        except Exception as e:
            self._err(f"matugen failed:\n{e}")
            return
        self._apply_matugen_colors(colors, f"  Palette from {hex_color}")

    def _apply_matugen_colors(self, colors: dict, source_label: str):
        entries  = self._w.get("css_hex_entries", {})
        buttons  = self._w.get("css_colors", {})
        applied  = 0
        for css_key, m3_role in _MATUGEN_MAP.items():
            try:
                hex_val = colors[m3_role]["default"]["color"]
            except (KeyError, TypeError):
                continue
            if css_key in entries:
                entries[css_key].set_text(hex_val)
                applied += 1
            if css_key in buttons:
                buttons[css_key].set_rgba(_hex_to_rgba(hex_val))
        self._refresh_preview()
        self._status(
            f"{source_label}  ({applied}/{len(_MATUGEN_MAP)} colors)",
            "·  Review colors above  ·  Save to apply",
        )

