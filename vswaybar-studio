            [("CSS stylesheets", ["*.css"])]
        )

        content.pack_start(grid, True, True, 0)
        dlg.show_all()

        if dlg.run() == Gtk.ResponseType.OK:
            new_cfg = cfg_entry.get_text().strip()
            new_css = css_entry.get_text().strip()
            dlg.destroy()
            if new_cfg:
                self._config_path = new_cfg
            if new_css:
                self._css_path = new_css
            self._load_config()
            self._rebuild_ui()
            self._status("✓  Loaded")
        else:
            dlg.destroy()


    def _backup_configs(self):
        """Backup current config/css/scripts with a timestamp prefix.
        On first run, also creates backups/original/ with the untouched files."""
        ts      = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        bk_dir  = os.path.join(os.path.dirname(self._config_path), "backups")
        orig_dir = os.path.join(bk_dir, "original")
        os.makedirs(bk_dir,   exist_ok=True)

        # ── original/ — created once, never overwritten ────────────────────
        if not os.path.isdir(orig_dir) or not os.listdir(orig_dir):
            os.makedirs(orig_dir, exist_ok=True)
            for src in (self._config_path, self._css_path):
                if os.path.isfile(src):
                    shutil.copy2(src, os.path.join(orig_dir, os.path.basename(src)))
            scripts_dir = os.path.join(os.path.dirname(self._config_path), "scripts")
            if os.path.isdir(scripts_dir):
                orig_scripts = os.path.join(orig_dir, "scripts")
                os.makedirs(orig_scripts, exist_ok=True)
                for fn in os.listdir(scripts_dir):
                    src = os.path.join(scripts_dir, fn)
                    if os.path.isfile(src):
                        shutil.copy2(src, os.path.join(orig_scripts, fn))

        # ── timestamped backup ─────────────────────────────────────────────
        for src in (self._config_path, self._css_path):
            if os.path.isfile(src):
                shutil.copy2(src, os.path.join(bk_dir, f"{ts}_{os.path.basename(src)}"))
        scripts_dir = os.path.join(os.path.dirname(self._config_path), "scripts")
        if os.path.isdir(scripts_dir):
            for fn in os.listdir(scripts_dir):
                src = os.path.join(scripts_dir, fn)
                if os.path.isfile(src):
                    shutil.copy2(src, os.path.join(bk_dir, f"{ts}_{fn}"))

    def _on_preview(self, *_):
        """Write config + CSS to disk, then restart waybar."""
        self._collect()
        try:
            os.makedirs(os.path.dirname(self._config_path), exist_ok=True)
            os.makedirs(os.path.dirname(self._css_path),    exist_ok=True)
            self._backup_configs()
            cfg_out = self._build_save_config()   # list [bar, dock]
            css_out = self._build_save_css()       # unified CSS
            with open(self._config_path, "w") as f:
                json.dump(cfg_out, f, indent=4, ensure_ascii=False)
            with open(self._css_path, "w") as f:
                f.write(css_out)
            # write GTK menu XML if a menu module is active
            pending = self._w.get("_pending_menu_xml")
            if pending:
                xml_path, rows = pending
                xml_path_exp = os.path.expanduser(xml_path)
                os.makedirs(os.path.dirname(xml_path_exp), exist_ok=True)
                with open(xml_path_exp, "w", encoding="utf-8") as f:
                    f.write(_build_menu_xml(rows))
                self._w.pop("_pending_menu_xml", None)
        except Exception as e:
            self._err(f"No se pudo escribir config:\n{e}")
            return

        if self._waybar_proc and self._waybar_proc.poll() is None:
            self._waybar_proc.terminate()
        subprocess.run(["pkill", "waybar"],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        GLib.timeout_add(500, self._relaunch_waybar)
        self._status("↺  Reiniciando waybar…")

    def _relaunch_waybar(self):
        cfg = self._build_save_config()   # list — may be empty if both disabled
        if not cfg:
            self._status("⏸  Bar + Dock deshabilitados.")
            return False
        try:
            self._waybar_proc = subprocess.Popen(
                ["waybar", "-c", self._config_path, "-s", self._css_path],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )
            names = [c.get("name", "bar") for c in cfg]
            self._status(f"✓  Reiniciado: {' + '.join(names)}")
        except Exception as e:
            self._err(f"Error al lanzar waybar:\n{e}")
        return False  # one-shot timer

