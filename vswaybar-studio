        # ── editor ────────────────────────────────────────────────────────────
        tv = Gtk.TextView()
        tv.set_monospace(True)
        tv.get_buffer().set_text(self._read_script(self._SCRIPTS[0][1]))

        sw = Gtk.ScrolledWindow()
        sw.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        sw.add(tv)
        sw.set_size_request(-1, 340)
        outer.pack_start(sw, True, True, 0)

        self._w["script_tv"]   = tv
        self._w["script_combo"] = combo

        # ── save buttons ──────────────────────────────────────────────────────
        btn_row = Gtk.Box(spacing=8)
        btn_row.set_margin_top(8)

        save_btn = Gtk.Button(label="💾  Save script")
        save_btn.get_style_context().add_class("open-btn")
