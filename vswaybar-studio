        grid.set_column_spacing(12)
        grid.set_margin_start(20); grid.set_margin_end(20)
        grid.set_margin_top(20);   grid.set_margin_bottom(20)

        def _make_row(label_text, current_path, row, patterns):
            lbl = Gtk.Label(label=label_text)
            lbl.set_halign(Gtk.Align.START)
            lbl.set_markup(f'<span foreground="{t["dim"]}">{label_text}</span>')
            grid.attach(lbl, 0, row, 1, 1)

            entry = Gtk.Entry()
            entry.set_text(current_path)
            entry.set_hexpand(True)
            grid.attach(entry, 1, row, 1, 1)

            browse = Gtk.Button(label="Browse…")
            browse.get_style_context().add_class("open-btn")
            def _browse(*_, e=entry, p=patterns):
                fd = Gtk.FileChooserDialog(
                    title="Select file", parent=dlg,
                    action=Gtk.FileChooserAction.OPEN,
                    buttons=("Cancel", Gtk.ResponseType.CANCEL,
                             "Select", Gtk.ResponseType.OK),
                )
                for name, globs in p:
                    ff = Gtk.FileFilter()
                    ff.set_name(name)
