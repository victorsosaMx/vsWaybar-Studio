        outer.pack_start(_section("Group modules"), False, False, 0)
        outer.pack_start(_hint("The first item is the leader — always visible in drawer mode."), False, False, 2)

        # store: (key, label)
        mod_store = Gtk.ListStore(str, str)
        self._w["_grp_mod_store"] = mod_store

        def _mod_label(key):
            if key in MODULE_LABELS:
                icon, name = MODULE_LABELS[key]
                return f"{icon}  {name}"
            if key.startswith("group/"):
                return f"󰾮  {key[6:]}"
            if key.startswith("custom/"):
                glyph = (self._cfg.get(key, {}) or
                         self._dock_cfg.get(key, {})).get("format", "󰘳")
                return f"{glyph}  {key[7:]}"
            return key

        for m in gcfg.get("modules", []):
            mod_store.append([m, _mod_label(m)])

        mod_tv = Gtk.TreeView(model=mod_store)
        mod_tv.set_headers_visible(False)
        mod_tv.set_activate_on_single_click(True)
        cr_mod = Gtk.CellRendererText()
        col_mod = Gtk.TreeViewColumn("", cr_mod, text=1)
        col_mod.set_expand(True)
        mod_tv.append_column(col_mod)
        mod_sw_tv = Gtk.ScrolledWindow()
        mod_sw_tv.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        mod_sw_tv.set_size_request(-1, 160)
        mod_sw_tv.add(mod_tv)
        outer.pack_start(mod_sw_tv, False, False, 4)

        # ── ComboBox with available modules ───────────────────────────────────
        # Build list: all known modules + user modules + other groups
        _available = []
        for m in sorted(ALL_MODULES):
            _available.append((m, _mod_label(m)))
        for s in self._cfg.get("_user_modules", []):
            k = f"custom/{s}"
            _available.append((k, _mod_label(k)))
        for g in self._groups:
            if g != gname:
                _available.append((g, _mod_label(g)))

        pick_combo = Gtk.ComboBoxText()
        for key, label in _available:
            pick_combo.append(key, label)
        pick_combo.set_active(0)
        pick_combo.set_hexpand(True)

        def _grp_add(*_):
            key = pick_combo.get_active_id()
            if key:
                mod_store.append([key, _mod_label(key)])

        def _grp_del(*_):
            _, it = mod_tv.get_selection().get_selected()
            if it:
                mod_store.remove(it)

        def _grp_move(direction):
            _, it = mod_tv.get_selection().get_selected()
            if not it:
                return
            idx = mod_store.get_path(it).get_indices()[0]
            n   = len(mod_store)
            if direction == -1 and idx > 0:
                mod_store.swap(it, mod_store.get_iter(Gtk.TreePath(idx - 1)))
            elif direction == 1 and idx < n - 1:
                mod_store.swap(it, mod_store.get_iter(Gtk.TreePath(idx + 1)))

        add_btn = Gtk.Button(label="+ Agregar")
        add_btn.get_style_context().add_class("open-btn")
        add_btn.connect("clicked", _grp_add)

        add_row = Gtk.Box(spacing=4)
        add_row.pack_start(pick_combo, True,  True,  0)
        add_row.pack_start(add_btn,   False, False, 0)
        outer.pack_start(add_row, False, False, 2)

        ctrl_row = Gtk.Box(spacing=4)
        for lbl_b, cb in (("↑", lambda *_: _grp_move(-1)),
                           ("↓", lambda *_: _grp_move(1)),
                           ("✕", _grp_del)):
            b = Gtk.Button(label=lbl_b)
            b.get_style_context().add_class("open-btn")
            b.connect("clicked", cb)
            ctrl_row.pack_start(b, True, True, 0)
        outer.pack_start(ctrl_row, False, False, 2)

        return _scrolled(outer)

    def _build_module_form(self, mod: str) -> Gtk.Widget:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        box.set_margin_start(20)
        box.set_margin_end(20)
        box.set_margin_top(14)
        box.set_margin_bottom(14)

        base_mod = mod.split("#")[0] if "#" in mod else mod
