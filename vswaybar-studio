    def _on_module_selected(self, selection):
        model, it = selection.get_selected()
        if not it:
            return
        self._collect_module_fields()
        mod_key = model[it][0]
        self._selected_module = mod_key
        for child in self._module_panel.get_children():
            self._module_panel.remove(child)
        self._w["mod_fields"] = {}
        panel = self._build_module_form(mod_key)
        self._module_panel.pack_start(panel, True, True, 0)
        self._module_panel.show_all()
        self._refresh_preview()

