def _file_chooser(parent, title, mime_types=None) -> str | None:
    dlg = Gtk.FileChooserDialog(
        title=title, parent=parent,
        action=Gtk.FileChooserAction.OPEN,
        buttons=("Cancel", Gtk.ResponseType.CANCEL, "Open", Gtk.ResponseType.OK),
    )
    if mime_types:
        ff = Gtk.FileFilter()
        ff.set_name("Allowed files")
        for m in mime_types:
            ff.add_mime_type(m)
        dlg.add_filter(ff)
    path = dlg.get_filename() if dlg.run() == Gtk.ResponseType.OK else None
    dlg.destroy()
    return path

def _lbl(text: str, style: str = "field-label", xalign: float = 0.0) -> Gtk.Label:
    w = Gtk.Label(label=text)
    w.set_xalign(xalign)
    w.get_style_context().add_class(style)
    return w

def _section(text: str) -> Gtk.Label:
    return _lbl(text.upper(), "section-title")

def _hint(text: str) -> Gtk.Label:
    l = _lbl(text, "hint-label")
    l.set_margin_bottom(6)
    return l

def _color_btn(hex_color: str) -> Gtk.ColorButton:
    btn = Gtk.ColorButton()
    btn.set_rgba(_hex_to_rgba(hex_color))
    btn.set_title("Select color")
    return btn

def _spin(value, lo, hi, step=1, digits=0) -> Gtk.SpinButton:
    try:
        value = float(value)
    except (TypeError, ValueError):
        value = lo
    adj = Gtk.Adjustment(value=value, lower=lo, upper=hi,
                         step_increment=step, page_increment=step * 10)
    sb = Gtk.SpinButton(adjustment=adj, digits=digits)
    sb.set_numeric(True)
    return sb

def _combo(options: list, active: str) -> Gtk.ComboBoxText:
    cb = Gtk.ComboBoxText()
    for o in options:
        cb.append_text(o)
    try:
        cb.set_active(options.index(str(active)))
    except ValueError:
        cb.set_active(0)
    return cb

def _scrolled(child: Gtk.Widget, hpol=Gtk.PolicyType.NEVER) -> Gtk.ScrolledWindow:
    sw = Gtk.ScrolledWindow()
    sw.set_policy(hpol, Gtk.PolicyType.AUTOMATIC)
    sw.get_style_context().add_class("page-scroll")
    sw.add(child)
    return sw

def _row(label: str, widget: Gtk.Widget) -> Gtk.Box:
    box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    box.set_margin_bottom(8)
    lbl = _lbl(label)
    lbl.set_size_request(180, -1)
    box.pack_start(lbl, False, False, 0)
    box.pack_start(widget, False, False, 0)
    return box

def _field(label: str, widget: Gtk.Widget) -> Gtk.Box:
    box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
    box.set_margin_bottom(8)
    lbl = _lbl(label)
    lbl.set_size_request(180, -1)
    box.pack_start(lbl, False, False, 0)
    box.pack_start(widget, True, True, 0)
    return box

def _switch_row(label: str, active: bool) -> tuple:
    """Returns (row_widget, switch_widget)."""
    box = Gtk.Box(spacing=12)
    box.set_margin_bottom(8)
    lbl = _lbl(label)
    lbl.set_size_request(180, -1)
    sw = Gtk.Switch()
    sw.set_active(active)
    sw.set_valign(Gtk.Align.CENTER)
    box.pack_start(lbl, False, False, 0)
    box.pack_start(sw, False, False, 0)
    return box, sw

def _cr_rounded_rect(cr, x, y, w, h, r):
    cr.new_sub_path()
    cr.arc(x + w - r, y + r,     r, -math.pi / 2, 0)
    cr.arc(x + w - r, y + h - r, r, 0,             math.pi / 2)
    cr.arc(x + r,     y + h - r, r, math.pi / 2,   math.pi)
    cr.arc(x + r,     y + r,     r, math.pi,       3 * math.pi / 2)
    cr.close_path()

def _parse_arch_icon_sz(cfg: dict, fallback: int) -> int:
    """Extract icon size from custom/arch format string, or return fallback."""
    fmt = cfg.get("custom/arch", {}).get("format", "")
    m = re.search(r"font='[^']*\s(\d+)'", fmt)
    return int(m.group(1)) if m else fallback

def _parse_arch_icon_color(cfg: dict) -> str | None:
    """Extract explicit color from custom/arch format, or None (caller uses theme)."""
    fmt = cfg.get("custom/arch", {}).get("format", "")
    m = re.search(r"color='(#[0-9a-fA-F]{6})'", fmt, re.IGNORECASE)
    return m.group(1) if m else None

def _hex_to_rgb(hx: str) -> tuple:
    hx = hx.lstrip("#")
    return (int(hx[0:2], 16) / 255, int(hx[2:4], 16) / 255, int(hx[4:6], 16) / 255)

def _hex_darker(hx: str, factor: float) -> str:
    """Return a darker version of a hex color (factor 0=black, 1=same)."""
    hx = hx.lstrip("#")
    r = int(int(hx[0:2], 16) * factor)
    g = int(int(hx[2:4], 16) * factor)
    b = int(int(hx[4:6], 16) * factor)
    return f"#{r:02x}{g:02x}{b:02x}"

def _hsv_to_hex(h: float, s: float, v: float) -> str:
    r, g, b = colorsys.hsv_to_rgb(h % 1.0, max(0.0, min(1.0, s)), max(0.0, min(1.0, v)))
    return "#{:02x}{:02x}{:02x}".format(int(r * 255), int(g * 255), int(b * 255))

