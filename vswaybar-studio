def _hex_to_rgba(h: str) -> Gdk.RGBA:
    h = h.lstrip("#")
    c = Gdk.RGBA()
    c.red   = int(h[0:2], 16) / 255
    c.green = int(h[2:4], 16) / 255
    c.blue  = int(h[4:6], 16) / 255
    c.alpha = 1.0
    return c

def _rgba_to_hex(c: Gdk.RGBA) -> str:
    return "#{:02x}{:02x}{:02x}".format(
        round(c.red * 255), round(c.green * 255), round(c.blue * 255)
    )

