    def _load_template(self, tpl: dict, name: str, apply: bool):
        css = tpl["css"]
        # CSS colors
        for k, v in css.items():
            self._css_colors[k] = v
        # Bar config — update self._cfg AND the form widgets so _collect() doesn't overwrite
        for k in ("bar-style", "zone-radius", "border-width", "height", "spacing", "mod-padding"):
            self._cfg[k] = tpl[k]
        w = self._w
        if "bar-style" in w:
            _bar_styles = ["islands", "bar", "modules"]
            try:
                w["bar-style"].set_active(_bar_styles.index(tpl["bar-style"]))
            except ValueError:
                pass
        for k in ("zone-radius", "border-width", "height", "spacing", "mod-padding"):
            if k in w:
                w[k].set_value(tpl[k])
        # Workspaces
        ws = self._cfg.setdefault("hyprland/workspaces", {})
        ws["anim-color-1"]  = tpl["ws-color-1"]
        ws["anim-color-2"]  = tpl["ws-color-2"]
        ws["button-radius"] = tpl["ws-radius"]
        # Logo (custom/arch)
        arch   = self._cfg.setdefault("custom/arch", {})
        glyph  = tpl["logo-glyph"]
        sz     = tpl["logo-size"]
        col    = tpl["logo-color"]
        col_attr = f" color='{col}'" if re.match(r'^#[0-9a-fA-F]{6}$', col, re.IGNORECASE) else ""
        arch["format"]          = f"<span font='JetBrainsMono Nerd Font Mono {sz}'{col_attr}>{glyph}</span>"
        arch["arch-icon-glyph"] = glyph
        arch["arch-pad-left"]   = self._cfg.get("custom/arch", {}).get("arch-pad-left", 15)
        arch["arch-pad-right"]  = self._cfg.get("custom/arch", {}).get("arch-pad-right", 10)
        # Update palette widgets in-place (no rebuild needed)
        self._apply_palette(tpl["css"])
        self._refresh_preview()
        if apply:
            try:
                os.makedirs(os.path.dirname(self._config_path), exist_ok=True)
                os.makedirs(os.path.dirname(self._css_path),    exist_ok=True)
                self._backup_configs()
                cfg_out = self._build_save_config()   # unified array
                css_out = self._build_save_css()       # unified CSS
                with open(self._config_path, "w") as f:
                    json.dump(cfg_out, f, indent=4, ensure_ascii=False)
                with open(self._css_path, "w") as f:
                    f.write(css_out)
            except Exception as e:
                self._err(f"No se pudo aplicar template:\n{e}")
                return
            if self._waybar_proc and self._waybar_proc.poll() is None:
                self._waybar_proc.terminate()
            subprocess.run(["pkill", "waybar"],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            GLib.timeout_add(500, self._relaunch_waybar)
            self._status(f"✓  Template «{name}» — reiniciando waybar…")
        else:
            self._status(f"👁  Preview «{name}» — no changes saved.")

