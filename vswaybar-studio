    def _load_default_bar(self, *_):
        bar_keys = ("position", "height", "spacing", "margin-top", "margin-bottom",
                    "margin-left", "margin-right", "font-family", "font-size",
                    "bar-style", "opacity", "zone-radius", "border-width",
                    "separators", "mod-padding")
        for k in bar_keys:
            if k in DEFAULTS:
                self._cfg[k] = DEFAULTS[k]
        self._cfg.pop("output", None)   # "All monitors"
        self._rebuild_ui()
        self._status("↺  Default bar settings restored.")

    def _load_default_layout(self, *_):
        for zone_key, mods in _DEFAULT_LAYOUT.items():
            self._cfg[zone_key] = list(mods)
            store = self._w.get(f"zone_{zone_key}")
            if store:
                store.clear()
                for mod in mods:
                    icon, name = MODULE_LABELS.get(mod, ("", mod))
                    store.append([mod, f"{icon}  {name}"])
        self._refresh_preview()
        self._status("↺  Default layout restored.")

    def _on_zone_add(self, _, zone_key, store):
        dlg = Gtk.Dialog(title="Add module", parent=self, flags=Gtk.DialogFlags.MODAL)
        dlg.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Add", Gtk.ResponseType.OK)
        content = dlg.get_content_area()
        content.set_margin_start(16)
        content.set_margin_end(16)
        content.set_margin_top(16)
        content.set_margin_bottom(16)
        sorted_mods = sorted(ALL_MODULES, key=lambda m: MODULE_LABELS.get(m, ("", m))[1].lower())
        combo = _combo(
            [f"{MODULE_LABELS[m][0]}  {MODULE_LABELS[m][1]}" for m in sorted_mods],
            MODULE_LABELS[sorted_mods[0]][1],
        )
        content.add(combo)
        dlg.show_all()
        if dlg.run() == Gtk.ResponseType.OK:
            idx = combo.get_active()
            mod = sorted_mods[idx]
            icon, name = MODULE_LABELS[mod]
            store.append([mod, f"{icon}  {name}"])
        dlg.destroy()

    def _on_zone_remove(self, _, tv):
        sel = tv.get_selection()
        model, it = sel.get_selected()
        if it:
            model.remove(it)

    def _on_zone_move(self, _, tv, direction):
        sel = tv.get_selection()
        model, it = sel.get_selected()
        if not it:
            return
        path = model.get_path(it)
        idx  = path.get_indices()[0]
        target = idx + direction
        if target < 0 or target >= len(model):
            return
        other = model.get_iter(Gtk.TreePath(target))
        model.swap(it, other)
        self._refresh_preview()

