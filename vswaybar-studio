    def _page_bar(self) -> Gtk.Widget:
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        box.set_margin_start(28)
        box.set_margin_end(28)
        box.set_margin_top(8)
        box.set_margin_bottom(20)

        box.pack_start(_section("Position"), False, False, 0)

        pos = _combo(["top", "bottom"], self._cfg["position"])
        self._w["position"] = pos
        pos.connect("changed", self._refresh_preview)
        box.pack_start(_row("Position", pos), False, False, 0)

        out_combo = Gtk.ComboBoxText()
        self._w["output"] = out_combo

        def _fill_monitors(combo):
            current = combo.get_active_text() or self._cfg.get("output", "")
            combo.remove_all()
            combo.append_text("Disabled")
            combo.append_text("All monitors")
            try:
