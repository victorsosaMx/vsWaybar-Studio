    def _load_config(self):
        self._cfg = copy.deepcopy(DEFAULTS)
        self._cfg["_user_modules"] = []
        self._unknown_blocks = {}   # config blocks the app can't edit — preserved verbatim
        self._groups = {}           # group/name → {orientation, drawer, modules}
        self._cffi_modules = {}     # cffi/name  → {module_path, ...extra}
        _dock_raw = None
        try:
            with open(self._config_path) as f:
                _raw = _jsonc_load(f)
            # Support unified array format [bar, dock] or legacy single-dict
            if isinstance(_raw, list):
                user      = _raw[0] if _raw else {}
                _dock_raw = _raw[1] if len(_raw) > 1 else None
            else:
                user = _raw
            for k in ("layer", "output", "position", "height", "spacing",
                      "margin-top", "margin-bottom", "margin-left", "margin-right"):
                if k in user:
                    self._cfg[k] = user[k]
            for zone in ("modules-left", "modules-center", "modules-right"):
                if zone in user:
                    self._cfg[zone] = user[zone]
            for mod in ALL_MODULES:
                if mod in user and isinstance(user[mod], dict):
                    # merge: start from defaults so virtual keys are preserved
                    base = copy.deepcopy(DEFAULTS.get(mod, {}))
                    base.update(user[mod])
                    self._cfg[mod] = base
            # detect user-defined custom modules (any custom/X not in reserved set)
            for k, v in user.items():
                if k.startswith("custom/") and isinstance(v, dict):
                    suffix = k[7:]
                    if suffix not in _RESERVED_CUSTOM:
                        self._cfg[k] = copy.deepcopy(v)
                        if suffix not in self._cfg["_user_modules"]:
                            self._cfg["_user_modules"].append(suffix)
            # detect named instances: module#instancename (e.g. battery#bat2)
            self._cfg["_named_instances"] = []
            for k, v in user.items():
                if "#" in k and isinstance(v, dict):
                    base = k.split("#")[0]
                    if base in ALL_MODULES:
                        self._cfg[k] = copy.deepcopy(
                            dict(copy.deepcopy(DEFAULTS.get(base, {})), **v)
                        )
                        self._cfg["_named_instances"].append(k)
            # strip deprecated/removed keys
            self._cfg.get("clock", {}).pop("format-alt", None)
            # detect group/ modules (bar + dock share the same group registry)
            self._groups = {}
            for k, v in user.items():
                if k.startswith("group/") and isinstance(v, dict):
                    self._groups[k] = copy.deepcopy(v)
            if _dock_raw:
                for k, v in _dock_raw.items():
                    if k.startswith("group/") and isinstance(v, dict) and k not in self._groups:
                        self._groups[k] = copy.deepcopy(v)
            # detect cffi/ modules (bar + dock share the same registry)
            self._cffi_modules = {}
            for k, v in user.items():
                if k.startswith("cffi/") and isinstance(v, dict):
                    self._cffi_modules[k] = copy.deepcopy(v)
            if _dock_raw:
                for k, v in _dock_raw.items():
                    if k.startswith("cffi/") and isinstance(v, dict) and k not in self._cffi_modules:
                        self._cffi_modules[k] = copy.deepcopy(v)
            # preserve unknown config blocks verbatim (not in ALL_MODULES, not custom/, no #)
            _skip = (set(ALL_MODULES) |
                     {"modules-left", "modules-center", "modules-right",
                      "position", "height", "spacing", "layer", "output",
                      "margin-top", "margin-bottom", "margin-left", "margin-right",
                      "name", "exclusive", "passthrough", "gtk-layer-shell",
                      "reload_style_on_change", "ipc", "mod"})
            self._unknown_blocks = {}
            for k, v in user.items():
                if (k not in _skip and
                        not k.startswith("custom/") and
                        not k.startswith("group/") and
                        not k.startswith("cffi/") and
                        "#" not in k and
                        isinstance(v, dict)):
                    self._unknown_blocks[k] = copy.deepcopy(v)
        except FileNotFoundError:
            pass
        except Exception as e:
            print(f"Warning: {e}")

        self._css_colors = copy.deepcopy(CSS_COLOR_DEFAULTS)
        try:
            with open(self._css_path) as f:
                css_text = f.read()
            for m in re.finditer(r'@define-color\s+(\w+)\s+(#[0-9a-fA-F]{6})', css_text):
                name, val = m.group(1), m.group(2)
                if name in self._css_colors:
                    self._css_colors[name] = val
            # global font-size: * { font-size: Npx; }
            mf = re.search(r'\*\s*\{[^}]*font-size:\s*(\d+)px', css_text, re.DOTALL)
            if mf:
                self._cfg["font-size"] = int(mf.group(1))
            # opacity: read from alpha(@base, X) or legacy rgba()
            mo = re.search(r'alpha\(@\w+,\s*([\d.]+)\)', css_text)
            if not mo:
                mo = re.search(r'rgba\(\s*\d+\s*,\s*\d+\s*,\s*\d+\s*,\s*([\d.]+)\s*\)', css_text)
            if mo:
                self._cfg["opacity"] = int(float(mo.group(1)) * 100)

            # separators: detect saved marker block
            if '/* vswaybar:sep */' in css_text:
                self._cfg["separators"] = True

            # global font-family: * { font-family: "..."; } — extract first name only
            mff = re.search(r'\*\s*\{[^}]*font-family:\s*([^;]+);', css_text, re.DOTALL)
            if mff:
                first = mff.group(1).split(",")[0].strip().strip('"').strip("'")
                if first and first.lower() not in ("monospace", "sans-serif", "serif"):
                    self._cfg["font-family"] = first
            # module H-padding from zone container: .modules-* { padding: Vpx Hpx }
            mp = re.search(
                r'\.modules-left,\s*\n\.modules-center,\s*\n\.modules-right\s*\{[^}]*padding:\s*\d+px\s+(\d+)px',
                css_text, re.DOTALL
            )
            if mp:
                self._cfg["mod-padding"] = int(mp.group(1))

            # arch icon padding from #custom-arch { padding: 0 Rpx 0 Lpx }
            karch = re.search(
                r'#custom-arch\s*\{[^}]*padding:\s*\d+px\s+(\d+)px\s+\d+px\s+(\d+)px',
                css_text, re.DOTALL
            )
            arch_c = self._cfg.setdefault("custom/arch", {})
            arch_c.setdefault("arch-pad-right", int(karch.group(1)) if karch else 8)
            arch_c.setdefault("arch-pad-left",  int(karch.group(2)) if karch else 8)

            # workspace animation colors from @keyframes ws-active
            km = re.search(
                r'@keyframes\s+ws-active\s*\{.*?0%[^{]*\{[^}]*background-color:\s*(#[0-9a-fA-F]{6})',
                css_text, re.DOTALL | re.IGNORECASE
            )
            km2 = re.search(
                r'@keyframes\s+ws-active\s*\{.*?50%[^{]*\{[^}]*background-color:\s*(#[0-9a-fA-F]{6})',
                css_text, re.DOTALL | re.IGNORECASE
            )
            ws_c = self._cfg.setdefault("hyprland/workspaces", {})
            ws_c.setdefault("anim-color-1", km.group(1)  if km  else "#2980b9")
            ws_c.setdefault("anim-color-2", km2.group(1) if km2 else "#420ed2")
            # animation duration
            kd = re.search(
                r'#workspaces\s+button\.active\s*\{[^}]*animation:\s*ws-active\s+([\d.]+)s',
                css_text, re.DOTALL
            )
            ws_c.setdefault("anim-duration", float(kd.group(1)) if kd else 3.0)
            # button border-radius
            kr = re.search(
                r'#workspaces\s+button\s*\{[^}]*border-radius:\s*(\d+)px',
                css_text, re.DOTALL
            )
            ws_c.setdefault("button-radius", int(kr.group(1)) if kr else 8)
            # button padding
            kp = re.search(
                r'#workspaces\s+button\s*\{[^}]*padding:\s*(\d+)px\s+(\d+)px',
                css_text, re.DOTALL
            )
            ws_c.setdefault("button-pad-v", int(kp.group(1)) if kp else 4)
            ws_c.setdefault("button-pad-h", int(kp.group(2)) if kp else 14)
            # button min-width
            kmw = re.search(
                r'#workspaces\s+button\s*\{[^}]*min-width:\s*(\d+)px',
                css_text, re.DOTALL
            )
            ws_c.setdefault("button-minw", int(kmw.group(1)) if kmw else 32)

            # bar-style detection:
            # "bar"     → window#waybar has opaque rgba background
            # "islands" → window transparent, .modules-* have rgba background
            # "modules" → both transparent
            win_bg = re.search(
                r'window#waybar(?:\.bar)?\s*\{[^}]*background(?:-color)?:\s*([^;]+);',
                css_text, re.DOTALL)
            mod_bg = re.search(
                r'\.modules-left[^{]*\{[^}]*background(?:-color)?:\s*([^;]+);',
                css_text, re.DOTALL)
            def _is_opaque(val):
                val = val.strip()
                if val == "transparent": return False
                # alpha(@token, X) format
                ma = re.search(r'alpha\(@\w+,\s*([\d.]+)\)', val)
                if ma: return float(ma.group(1)) > 0.01
                # legacy rgba(r,g,b,X)
                m = re.search(r'rgba\([^,]+,[^,]+,[^,]+,\s*([\d.]+)\)', val)
                return bool(m and float(m.group(1)) > 0.01)
            if win_bg and _is_opaque(win_bg.group(1)):
                self._cfg["bar-style"] = "bar"
            elif mod_bg and _is_opaque(mod_bg.group(1)):
                self._cfg["bar-style"] = "islands"
            else:
                self._cfg["bar-style"] = "modules"

            # zone-radius from .modules-* border-radius
            kzr = re.search(
                r'\.modules-left[^{]*\{[^}]*border-radius:\s*(\d+)px',
                css_text, re.DOTALL)
            if kzr:
                self._cfg["zone-radius"] = int(kzr.group(1))

            # border-width: bar style stores it in window#waybar,
            # islands/modules store it in .modules-left (or its children)
            kbw = (
                re.search(r'window#waybar(?:\.bar)?\s*\{[^}]*border:\s*(\d+)px', css_text, re.DOTALL) or
                re.search(r'\.modules-left[^{]*\{[^}]*border:\s*(\d+)px', css_text, re.DOTALL) or
                re.search(r'\.modules-left[^{]*>[^{]*\*[^{]*\{[^}]*border:\s*(\d+)px', css_text, re.DOTALL)
            )
            if kbw:
                self._cfg["border-width"] = int(kbw.group(1))

            # user module colors from #custom-<suffix> { color: #rrggbb; }
            for suffix in self._cfg.get("_user_modules", []):
                kuc = re.search(
                    rf'#custom-{re.escape(suffix)}\s*\{{[^}}]*color:\s*(#[0-9a-fA-F]{{6}})',
                    css_text, re.DOTALL | re.IGNORECASE
                )
                if kuc:
                    self._cfg.setdefault(f"custom/{suffix}", {})["_color"] = kuc.group(1).lower()

        except FileNotFoundError:
            pass
        except Exception as e:
            print(f"Warning CSS: {e}")
        self._load_dock_config(_dock_raw)

    def _load_dock_config(self, dock_dict=None):
        """Load dock settings — from array element or DOCK_DEFAULTS."""
        self._dock_cfg = copy.deepcopy(DOCK_DEFAULTS)
        # ── JSON (from unified array[1]) ──────────────────────────────────────
        user = dock_dict or {}
        for k in ("position", "height", "spacing", "layer",
                  "margin-top", "margin-bottom", "margin-left", "margin-right"):
            if k in user:
                self._dock_cfg[k] = user[k]
        if "output" in user:
            self._dock_cfg["output"] = user["output"]
        if "exclusive" in user:
            self._dock_cfg["exclusive"] = bool(user["exclusive"])
        for zone in ("modules-left", "modules-center", "modules-right"):
            if zone in user:
                self._dock_cfg[zone] = user[zone]
        for k, v in user.items():
            if k.startswith("custom/") and isinstance(v, dict):
                self._dock_cfg[k] = copy.deepcopy(v)
        # ── CSS (from unified style.css — window#dock section) ────────────────
        try:
            with open(self._css_path) as f:
                css = f.read()
            # Extract window#dock block for dock-specific parsing
            dock_block = re.search(
                r'window#waybar\.dock\s*\{([^}]+)\}', css, re.DOTALL)
            # opacity: rgba() inside window#dock .modules-* rules
            # search in the area after window#dock
            dock_section = css[css.find("window#waybar.dock"):] if "window#waybar.dock" in css else ""
            mo = re.search(r'alpha\(@\w+,\s*([\d.]+)\)', dock_section)
            if not mo:
                mo = re.search(r'rgba\(\s*\d+\s*,\s*\d+\s*,\s*\d+\s*,\s*([\d.]+)\s*\)', dock_section)
            if mo:
                self._dock_cfg["opacity"] = int(float(mo.group(1)) * 100)
            mzr = re.search(
                r'window#waybar\.dock[^{]*\.modules-(?:left|center|right)[^{]*\{[^}]*border-radius:\s*(\d+)px',
                css, re.DOTALL)
            if mzr:
                self._dock_cfg["zone-radius"] = int(mzr.group(1))
            mbw = re.search(
                r'window#waybar\.dock[^{]*\.modules-(?:left|center|right)[^{]*\{[^}]*border:\s*(\d+)px',
                css, re.DOTALL)
            if mbw:
                self._dock_cfg["border-width"] = int(mbw.group(1))
            mp = re.search(
                r'window#waybar\.dock[^{]*\.modules-(?:left|center|right)[^{]*\{[^}]*padding:\s*\d+px\s+(\d+)px',
                css, re.DOTALL)
            if mp:
                self._dock_cfg["mod-padding"] = int(mp.group(1))
            # font-size and font-family: shared * { } block
            mfs = re.search(r'\*\s*\{[^}]*font-size:\s*(\d+)px', css, re.DOTALL)
            # font-size for dock may differ — look in dock section
            mfs_dock = re.search(r'window#waybar\.dock\s[^}]+font-size:\s*(\d+)px', dock_section, re.DOTALL)
            if mfs_dock:
                self._dock_cfg["font-size"] = int(mfs_dock.group(1))
            mff = re.search(r'\*\s*\{[^}]*font-family:\s*([^;]+);', css, re.DOTALL)
            if mff:
                first = mff.group(1).split(",")[0].strip().strip('"').strip("'")
                if first and first.lower() not in ("monospace", "sans-serif", "serif"):
                    self._dock_cfg["font-family"] = first
            if '/* vswaybar:dock:sep */' in css:
                self._dock_cfg["separators"] = True
            # _color per dock module: #custom-X { color: ... } inside dock section
            for mod in (self._dock_cfg.get("modules-left", []) +
                        self._dock_cfg.get("modules-center", []) +
                        self._dock_cfg.get("modules-right", [])):
                if mod.startswith("custom/"):
                    suffix = mod[7:]
                    kc = re.search(
                        rf'window#waybar\.dock\s+#{re.escape("custom-" + suffix)}\s*\{{[^}}]*color:\s*(#[0-9a-fA-F]{{6}})',
                        css, re.DOTALL | re.IGNORECASE)
                    if kc:
                        self._dock_cfg.setdefault(mod, {})["_color"] = kc.group(1).lower()
        except FileNotFoundError:
            pass
        except Exception as e:
            print(f"Warning dock CSS: {e}")

    def _collect(self):
        w = self._w
        for k in ("position", "bar-style"):
            if k in w:
                self._cfg[k] = w[k].get_active_text()
        if "output" in w:
            val = w["output"].get_active_text() or ""
            if val == "Disabled":
                self._cfg["output"] = "__disabled__"
            elif val == "All monitors":
                self._cfg.pop("output", None)
            else:
                self._cfg["output"] = val.strip()
        if "font-family" in w:
            v = w["font-family"].get_font().strip()
            if v:
                # use Pango to extract family only (strips size, style, weight)
                family = Pango.FontDescription.from_string(v).get_family()
                if family:
                    self._cfg["font-family"] = family
        for k in ("height", "spacing", "margin-top", "margin-bottom", "margin-left", "margin-right", "zone-radius",
                  "font-size", "mod-padding", "border-width", "opacity"):
            if k in w:
                self._cfg[k] = int(w[k].get_value())
        if "separators" in w:
            self._cfg["separators"] = w["separators"].get_active()
        for zone in ("modules-left", "modules-center", "modules-right"):
            store = w.get(f"zone_{zone}")
            if store:
                self._cfg[zone] = [row[0] for row in store]
        for name, entry in w.get("css_hex_entries", {}).items():
            val = entry.get_text().strip()
            if re.match(r'^#[0-9a-fA-F]{6}$', val, re.IGNORECASE):
                self._css_colors[name] = val.lower()
        self._collect_module_fields()
        self._collect_dock()

    def _collect_dock(self):
        w = self._w_dock
        if not w:
            return
        for k in ("position", "bar-style"):
            if k in w:
                self._dock_cfg[k] = w[k].get_active_text()
        if "output" in w:
            val = w["output"].get_active_text() or ""
            if val == "Disabled":
                self._dock_cfg["output"] = "__disabled__"
            elif val == "All monitors":
                self._dock_cfg.pop("output", None)
            else:
                self._dock_cfg["output"] = val.strip()
        if "font-family" in w:
            v = w["font-family"].get_font().strip()
            if v:
                family = Pango.FontDescription.from_string(v).get_family()
                if family:
                    self._dock_cfg["font-family"] = family
        for k in ("height", "spacing", "margin-top", "margin-bottom",
                  "margin-left", "margin-right", "zone-radius",
                  "font-size", "mod-padding", "border-width", "opacity"):
            if k in w:
                self._dock_cfg[k] = int(w[k].get_value())
        if "separators" in w:
            self._dock_cfg["separators"] = w["separators"].get_active()
        if "exclusive" in w:
            self._dock_cfg["exclusive"] = w["exclusive"].get_active()
        for zone in ("modules-left", "modules-center", "modules-right"):
            store = w.get(f"zone_{zone}")
            if store:
                self._dock_cfg[zone] = [row[0] for row in store]

    def _collect_module_fields(self):
        mod = self._selected_module
        if not mod:
            return

        # cffi/ modules have their own collection path
        if mod.startswith("cffi/"):
            ccfg = self._cffi_modules.setdefault(mod, {})
            mp_w = self._w.get("_cffi_path")
            if mp_w:
                ccfg["module_path"] = mp_w.get_text().strip()
            extra_tv = self._w.get("_cffi_extra")
            if extra_tv:
                buf = extra_tv.get_buffer()
                txt = buf.get_text(buf.get_start_iter(), buf.get_end_iter(), False).strip()
                try:
                    extra = _json.loads(txt)
                    # keep only module_path plus whatever extra keys the user defined
                    for k in list(ccfg.keys()):
                        if k != "module_path" and k not in extra:
                            ccfg.pop(k)
                    for k, v in extra.items():
                        if k != "module_path":
                            ccfg[k] = v
                except Exception:
                    pass
            return

        # group/ modules have their own collection path
        if mod.startswith("group/"):
            gcfg = self._groups.setdefault(mod, {})
            orient_w  = self._w.get("_grp_orient")
            drawer_sw = self._w.get("_grp_drawer_sw")
            dur_w     = self._w.get("_grp_drawer_dur")
            cls_w     = self._w.get("_grp_drawer_cls")
            ltr_w     = self._w.get("_grp_drawer_ltr")
            store_w   = self._w.get("_grp_mod_store")
            if orient_w:
                gcfg["orientation"] = orient_w.get_active_text() or "inherit"
            if drawer_sw:
                enabled = drawer_sw.get_active()
                gcfg["_drawer_enabled"] = enabled
                if enabled and dur_w and cls_w and ltr_w:
                    gcfg["drawer"] = {
                        "transition-duration":      int(dur_w.get_value()),
                        "children-class":           cls_w.get_text().strip(),
                        "transition-left-to-right": ltr_w.get_active(),
                    }
                elif not enabled:
                    gcfg.pop("drawer", None)
            if store_w is not None:
                gcfg["modules"] = [row[0] for row in store_w
                                   if row[0]]   # col 0 = module key
            return

        target_cfg = self._dock_cfg if self._selected_module_is_dock else self._cfg
        if mod not in target_cfg:
            target_cfg[mod] = {}
        fields = self._w.get("mod_fields", {})
        for fkey, widget in fields.items():
            if "." in fkey:
                parent, child = fkey.split(".", 1)
                if parent not in target_cfg[mod] or not isinstance(target_cfg[mod][parent], dict):
                    target_cfg[mod][parent] = {}
                if isinstance(widget, Gtk.SpinButton):   # SpinButton before Entry!
                    target_cfg[mod][parent][child] = int(widget.get_value())
                elif isinstance(widget, Gtk.Entry):
                    target_cfg[mod][parent][child] = widget.get_text()
                elif isinstance(widget, Gtk.Switch):
                    target_cfg[mod][parent][child] = widget.get_active()
            elif isinstance(widget, Gtk.SpinButton):     # SpinButton before Entry!
                target_cfg[mod][fkey] = int(widget.get_value())
            elif isinstance(widget, Gtk.Entry):
                target_cfg[mod][fkey] = widget.get_text()
            elif isinstance(widget, Gtk.Switch):
                target_cfg[mod][fkey] = widget.get_active()
            elif isinstance(widget, Gtk.ComboBoxText):
                # use active_id (the semantic key) — falls back to active_text for legacy combos
                val = widget.get_active_id()
                if val is None:
                    val = widget.get_active_text() or ""
                target_cfg[mod][fkey] = val

        # strip keys that must never appear in saved JSON
        if mod == "clock":
            target_cfg[mod].pop("format-alt", None)

        # hyprland/workspaces — persistent-workspaces is a dict, handle separately
        if mod == "hyprland/workspaces":
            pw_sw  = self._w.get("_pw_switch")
            pw_en  = self._w.get("_pw_entry")
            if pw_sw is not None and isinstance(pw_sw, Gtk.Switch):
                if pw_sw.get_active() and pw_en is not None:
                    try:
                        target_cfg[mod]["persistent-workspaces"] = _json.loads(pw_en.get_text())
                    except Exception:
                        pass  # keep existing value if JSON is invalid
                else:
                    target_cfg[mod].pop("persistent-workspaces", None)

        # collect color for user modules
        suffix = mod[7:] if mod.startswith("custom/") else ""
        if suffix and suffix not in _RESERVED_CUSTOM:
            col_entry = self._w.get("mod_fields", {}).get("_color_hex")
            if col_entry and isinstance(col_entry, Gtk.Entry):
                val = col_entry.get_text().strip()
                if re.match(r'^#[0-9a-fA-F]{6}$', val, re.IGNORECASE):
                    target_cfg[mod]["_color"] = val.lower()

        # custom user module — GTK menu mode
        suffix = mod[7:] if mod.startswith("custom/") else ""
        if suffix and suffix not in _RESERVED_CUSTOM and target_cfg[mod].get("_menu_mode"):
            store   = self._w.get("_menu_store")
            trigger = self._w.get("_menu_trigger")
            xml_ent = self._w.get("_menu_file_entry")
            if store is not None:
                # collect flat rows from ListStore
                rows = [(row[0], row[1], row[2], row[3]) for row in store]

                # build menu-actions (only items with commands)
                actions = {r[2]: r[3] for r in rows
                           if r[0] == "item" and r[3].strip()}

                xml_path = xml_ent.get_text().strip() if xml_ent else ""
                if not xml_path:
                    xml_path = os.path.expanduser(f"~/.config/waybar/{suffix}_menu.xml")

                trig_val = "on-click"
                if trigger is not None:
                    t = trigger.get_active_text()
                    if t:
                        trig_val = t

                target_cfg[mod]["menu"]         = trig_val
                target_cfg[mod]["menu-file"]    = xml_path
                target_cfg[mod]["menu-actions"] = actions
                target_cfg[mod]["_menu_rows"]   = rows   # preserve for reload

                # remove on-click / tooltip-format — replaced by menu
                target_cfg[mod].pop("on-click",       None)
                target_cfg[mod].pop("tooltip-format", None)

                # stash XML for _on_preview to write
                self._w["_pending_menu_xml"] = (xml_path, rows)

        # rebuild custom/arch format from size + color + glyph controls
        if mod == "custom/arch":
            sz_w    = fields.get("arch-icon-size")
            col_w   = fields.get("arch-icon-color")
            glyph_w = fields.get("arch-icon-glyph")
            if sz_w is not None:
                sz     = int(sz_w.get_value()) if isinstance(sz_w, Gtk.SpinButton) else 20
                col    = col_w.get_text().strip()   if isinstance(col_w,   Gtk.Entry) else ""
                glyph  = glyph_w.get_text().strip() if isinstance(glyph_w, Gtk.Entry) else "󰣇"
                if not glyph: glyph = "󰣇"
                target_cfg[mod].pop("arch-icon-size",  None)
                target_cfg[mod].pop("arch-icon-color",  None)
                col_attr = f" color='{col}'" if re.match(r'^#[0-9a-fA-F]{6}$', col, re.IGNORECASE) else ""
                target_cfg[mod]["format"]          = f"<span font='JetBrainsMono Nerd Font Mono {sz}'{col_attr}>{glyph}</span>"
                target_cfg[mod]["arch-icon-glyph"] = glyph

    def _build_save_config(self) -> dict:
        out = {}
        for k in ("position", "height", "spacing",
                  "margin-top", "margin-bottom", "margin-left", "margin-right"):
            out[k] = self._cfg.get(k, DEFAULTS.get(k))
        if "output" in self._cfg and self._cfg["output"] != "__disabled__":
            out["output"] = self._cfg["output"]
        out["modules-left"]   = self._cfg["modules-left"]
        out["modules-center"] = self._cfg["modules-center"]
        out["modules-right"]  = self._cfg["modules-right"]
        for mod in ALL_MODULES:
            if mod in self._cfg:
                mod_cfg = dict(self._cfg[mod])
                if mod == "clock":
                    for _k in _CLOCK_OPTIONAL_KEYS:
                        if _k in mod_cfg and str(mod_cfg[_k]).strip() == "":
                            mod_cfg.pop(_k)
                if not mod_cfg.get("justify", ""):
                    mod_cfg.pop("justify", None)
                out[mod] = mod_cfg
        # named instances (e.g. battery#bat2, pulseaudio#microphone)
        for k in self._cfg.get("_named_instances", []):
            if k in self._cfg:
                mod_cfg = dict(self._cfg[k])
                out[k] = mod_cfg
        # user-defined custom modules (launcher style — only relevant keys)
        # only write to bar dict if the module is actually used in bar zones
        _bar_zone_mods = set(
            self._cfg.get("modules-left", []) +
            self._cfg.get("modules-center", []) +
            self._cfg.get("modules-right", [])
        )
        for suffix in self._cfg.get("_user_modules", []):
            key = f"custom/{suffix}"
            if key in self._cfg and key in _bar_zone_mods:
                mc = self._cfg[key]
                entry = {"format": mc.get("format", "󰘳"), "tooltip": False}
                if mc.get("_menu_mode"):
                    # GTK menu mode — write menu-* keys, omit on-click/tooltip
                    entry["tooltip"] = False
                    trig = mc.get("menu", "on-click")
                    entry[trig]          = "noop"   # needed by Waybar to register click
                    entry["menu"]        = trig
                    entry["menu-file"]   = mc.get("menu-file", f"~/.config/waybar/{suffix}_menu.xml")
                    entry["menu-actions"] = mc.get("menu-actions", {})
                else:
                    oc = mc.get("on-click", "").strip()
                    if oc:
                        entry["on-click"] = oc
                    tt = mc.get("tooltip-format", "").strip()
                    if tt:
                        entry["tooltip-format"] = tt
                        entry["tooltip"] = True
                out[key] = entry
        # dock modules used in bar zones — copy definition from dock_cfg
        bar_mods = (self._cfg.get("modules-left", []) +
                    self._cfg.get("modules-center", []) +
                    self._cfg.get("modules-right", []))
        for mod in bar_mods:
            if mod not in out and mod in self._dock_cfg:
                mc = self._dock_cfg[mod]
                entry = {"format": mc.get("format", "󰘳"), "tooltip": mc.get("tooltip", False)}
                oc = mc.get("on-click", "").strip()
                if oc:
                    entry["on-click"] = oc
                tt = mc.get("tooltip-format", "").strip()
                if tt:
                    entry["tooltip-format"] = tt
                    entry["tooltip"] = True
                out[mod] = entry
        # modules referenced inside groups — ensure they have a config block
        for gcfg_item in self._groups.values():
            for m in gcfg_item.get("modules", []):
                if m in out or m.startswith("group/"):
                    continue   # already written or nested group
                if m in ALL_MODULES:
                    # use cfg if available, else fall back to DEFAULTS
                    src = self._cfg.get(m, DEFAULTS.get(m, {}))
                    if src:
                        mod_cfg = dict(src)
                        # strip internal Studio keys
                        for _ik in ("anim-color-1", "anim-color-2", "anim-duration",
                                    "button-radius", "button-pad-v", "button-pad-h",
                                    "button-minw", "_color", "_menu_mode", "_menu_rows"):
                            mod_cfg.pop(_ik, None)
                        out[m] = mod_cfg
                elif m.startswith("custom/") and m in self._cfg:
                    mc = self._cfg[m]
                    entry = {"format": mc.get("format", "󰘳"), "tooltip": False}
                    oc = mc.get("on-click", "").strip()
                    if oc:
                        entry["on-click"] = oc
                    out[m] = entry

        out["name"] = "bar"

        # group/ modules — serialize with full structure
        for gname, gcfg in self._groups.items():
            entry = {
                "orientation": gcfg.get("orientation", "inherit"),
                "modules":     gcfg.get("modules", []),
            }
            if gcfg.get("_drawer_enabled", "drawer" in gcfg):
                drawer_src = gcfg.get("drawer", {})
                entry["drawer"] = {
                    "transition-duration":    drawer_src.get("transition-duration", 500),
                    "children-class":         drawer_src.get("children-class", ""),
                    "transition-left-to-right": drawer_src.get("transition-left-to-right", False),
                }
            out[gname] = entry

        # cffi/ modules in bar zones
        _bar_zone_set = set(
            self._cfg.get("modules-left", []) +
            self._cfg.get("modules-center", []) +
            self._cfg.get("modules-right", [])
        )
        for cname, ccfg in self._cffi_modules.items():
            if cname in _bar_zone_set:
                out[cname] = copy.deepcopy(ccfg)

        # unknown blocks — preserved verbatim so we don't drop user config
        for k, v in self._unknown_blocks.items():
            if k not in out:
                out[k] = v

        # ── Dock config ───────────────────────────────────────────────────────
        dock = {}
        dock["name"] = "dock"
        for k in ("position", "height", "spacing", "layer",
                  "margin-top", "margin-bottom", "margin-left", "margin-right"):
            dock[k] = self._dock_cfg.get(k, DOCK_DEFAULTS.get(k))
        if "output" in self._dock_cfg and self._dock_cfg["output"] != "__disabled__":
            dock["output"] = self._dock_cfg["output"]
        dock["exclusive"]       = self._dock_cfg.get("exclusive", True)
        dock["passthrough"]     = False
        dock["gtk-layer-shell"] = True
        for zone in ("modules-left", "modules-center", "modules-right"):
            dock[zone] = self._dock_cfg.get(zone, [])
        all_dock_mods = dock["modules-left"] + dock["modules-center"] + dock["modules-right"]
        for mod in all_dock_mods:
            if mod.startswith("custom/"):
                # prefer dock_cfg definition, fall back to bar cfg
                # (modules created via "+" in Modules tab are stored in self._cfg)
                if mod in self._dock_cfg:
                    mc = self._dock_cfg[mod]
                elif mod in self._cfg:
                    mc = self._cfg[mod]
                else:
                    continue
                entry = {"format": mc.get("format", "󰘳"), "tooltip": False}
                oc    = mc.get("on-click", "").strip()
                if oc:
                    entry["on-click"] = oc
                tt = mc.get("tooltip-format", "").strip()
                if tt:
                    entry["tooltip-format"] = tt
                    entry["tooltip"]        = True
                dock[mod] = entry
        # group/ modules referenced in dock zones — write group block + member configs
        _dock_zone_set = set(all_dock_mods)
        for gname, gcfg in self._groups.items():
            if gname not in _dock_zone_set:
                continue
            entry = {
                "orientation": gcfg.get("orientation", "inherit"),
                "modules":     gcfg.get("modules", []),
            }
            if gcfg.get("_drawer_enabled", "drawer" in gcfg):
                drawer_src = gcfg.get("drawer", {})
                entry["drawer"] = {
                    "transition-duration":      drawer_src.get("transition-duration", 500),
                    "children-class":           drawer_src.get("children-class", ""),
                    "transition-left-to-right": drawer_src.get("transition-left-to-right", False),
                }
            dock[gname] = entry
            # ensure member modules have a config block in dock dict
            for m in gcfg.get("modules", []):
                if m in dock or m.startswith("group/"):
                    continue
                if m in ALL_MODULES:
                    src = self._cfg.get(m, DEFAULTS.get(m, {}))
                    if src:
                        mod_cfg = dict(src)
                        for _ik in ("anim-color-1", "anim-color-2", "anim-duration",
                                    "button-radius", "button-pad-v", "button-pad-h",
                                    "button-minw", "_color", "_menu_mode", "_menu_rows"):
                            mod_cfg.pop(_ik, None)
                        dock[m] = mod_cfg
                elif m.startswith("custom/") and m not in dock:
                    mc = self._cfg.get(m) or self._dock_cfg.get(m)
                    if mc:
                        entry_m = {"format": mc.get("format", "󰘳"), "tooltip": False}
                        oc = mc.get("on-click", "").strip()
                        if oc:
                            entry_m["on-click"] = oc
                        dock[m] = entry_m

        # cffi/ modules in dock zones
        _dock_zone_cffi = set(all_dock_mods)
        for cname, ccfg in self._cffi_modules.items():
            if cname in _dock_zone_cffi:
                dock[cname] = copy.deepcopy(ccfg)

        # Return array, filtering disabled bars
        bar_disabled  = self._cfg.get("output")      == "__disabled__"
        dock_disabled = self._dock_cfg.get("output") == "__disabled__"
        result = []
        if not bar_disabled:
            result.append(out)
        if not dock_disabled:
            result.append(dock)
        return result

    def _build_save_css(self) -> str:
        try:
            with open(self._css_path) as f:
                css_text = f.read()
        except FileNotFoundError:
            css_text = ""
        _required = (".modules-left", "@keyframes ws-active", "#workspaces button")
        _has_win  = "window#waybar" in css_text
        if not css_text.strip() or not _has_win or not all(m in css_text for m in _required):
            css_text = _BASE_CSS

        # ── @define-color replacements ────────────────────────────────────────
        for name, val in self._css_colors.items():
            pattern = rf'(@define-color\s+{re.escape(name)}\s+)(#[0-9a-fA-F]{{6}})'
            if re.search(pattern, css_text):
                css_text = re.sub(pattern, rf'\g<1>{val}', css_text)
            else:
                # token missing from CSS — inject it at the top
                css_text = f"@define-color {name} {val};\n" + css_text

        # ── derived values ────────────────────────────────────────────────────
        s0_color  = self._css_colors.get("surface0", "#1d211a")
        zone_r    = self._cfg.get("zone-radius",   12)
        bar_style = self._cfg.get("bar-style",    "islands")
        opacity   = self._cfg.get("opacity",      95) / 100
        font_sz   = self._cfg.get("font-size",    13)
        mod_pad   = self._cfg.get("mod-padding",  8)
        brd_w     = self._cfg.get("border-width", 1)
        # alpha() usa tokens CSS → backgrounds responden a vshypr-theme-manager
        bg_alpha  = f"alpha(@base, {opacity:.2f})"

        # ── global font-family + font-size ───────────────────────────────────
        font_fam_raw = self._cfg.get("font-family", "Product Sans")
        # wrap in quotes for CSS; keep monospace fallback
        font_fam_css = f'"{font_fam_raw}", monospace'
        css_text = re.sub(
            r'(\*\s*\{[^}]*?font-family:\s*)[^;]+;',
            rf'\g<1>{font_fam_css};',
            css_text, flags=re.DOTALL
        )
        css_text = re.sub(
            r'(\*\s*\{[^}]*?font-size:\s*)\d+px',
            rf'\g<1>{font_sz}px',
            css_text, flags=re.DOTALL
        )

        # ── window#waybar background + radius (barra = full pill) ───────────
        win_bg = bg_alpha if bar_style == "bar" else "transparent"
        win_r  = zone_r if bar_style == "bar" else 0
        css_text = re.sub(
            r'(window#waybar(?:\.bar)?\s*\{[^}]*?background:\s*)[^;]+;',
            rf'\g<1>{win_bg};',
            css_text, flags=re.DOTALL
        )
        # Add/replace border-radius inside window#waybar block
        if re.search(r'window#waybar(?:\.bar)?\s*\{[^}]*?border-radius:', css_text, re.DOTALL):
            css_text = re.sub(
                r'(window#waybar(?:\.bar)?\s*\{[^}]*?border-radius:\s*)[^;]+;',
                rf'\g<1>{win_r}px;',
                css_text, flags=re.DOTALL
            )
        else:
            css_text = re.sub(
                r'(window#waybar(?:\.bar)?\s*\{[^}]*?)(color:\s*[^;]+;)',
                rf'\g<1>\g<2>\n    border-radius: {win_r}px;',
                css_text, flags=re.DOTALL
            )

        # ── window#waybar border (barra style only) ──────────────────────────
        win_brd = f"{brd_w}px solid @surface0" if bar_style == "bar" and brd_w > 0 else "none"
        if re.search(r'window#waybar(?:\.bar)?\s*\{[^}]*?border:', css_text, re.DOTALL):
            css_text = re.sub(
                r'(window#waybar(?:\.bar)?\s*\{[^}]*?border:\s*)[^;]+;',
                rf'\g<1>{win_brd};',
                css_text, flags=re.DOTALL
            )
        else:
            css_text = re.sub(
                r'(window#waybar(?:\.bar)?\s*\{[^}]*?border-radius:\s*[^;]+;)',
                rf'\g<1>\n    border: {win_brd};',
                css_text, flags=re.DOTALL
            )

        # ── .modules-left/center/right block ─────────────────────────────────
        brd = f"{brd_w}px solid @surface0" if brd_w > 0 else "none"
        if bar_style == "bar":
            modules_block = (
                ".modules-left,\n.modules-center,\n.modules-right {\n"
                "    background: transparent;\n"
                "    border-radius: 0;\n"
                f"    padding: 2px {mod_pad}px;\n"
                "    border: none;\n"
                "    min-height: 0;\n"
                "}"
            )
        elif bar_style == "modules":
            modules_block = (
                ".modules-left,\n.modules-center,\n.modules-right {\n"
                "    background: transparent;\n"
                "    border: none;\n"
                f"    padding: 2px {max(2, mod_pad // 2)}px;\n"
                "    min-height: 0;\n"
                "}\n\n"
                ".modules-left > *,\n.modules-center > *,\n.modules-right > * {\n"
                f"    background: {bg_alpha};\n"
                f"    border-radius: {zone_r}px;\n"
                f"    border: {brd};\n"
                f"    padding: 0 {mod_pad}px;\n"
                "    margin: 0 2px;\n"
                "}"
            )
        else:  # islands
            modules_block = (
                ".modules-left,\n.modules-center,\n.modules-right {\n"
                f"    background: {bg_alpha};\n"
                f"    border-radius: {zone_r}px;\n"
                f"    padding: 2px {mod_pad}px;\n"
                f"    border: {brd};\n"
                "    min-height: 0;\n"
                "}"
            )

        right_pad = mod_pad + 10
        modules_block += f"\n\n.modules-right {{\n    padding-right: {right_pad}px;\n}}"

        css_text = re.sub(
            r'\.modules-left,\s*\n\.modules-center,\s*\n\.modules-right\s*\{[^}]+\}'
            r'(?:\s*\n\n\.modules-left\s*>\s*\*,[\s\S]*?\})?'
            r'(?:\s*\n\n\.modules-right\s*\{[^}]+\})*',
            modules_block,
            css_text
        )

        # ── per-module padding override ───────────────────────────────────────
        css_text = re.sub(r'\n*/\* vswaybar:modpad \*/.*$', '', css_text, flags=re.DOTALL)
        arch_c  = self._cfg.get("custom/arch", {})
        arch_pl = arch_c.get("arch-pad-left",  8)
        arch_pr = arch_c.get("arch-pad-right", 8)
        B = "window#waybar"
        css_text += (
            f"\n/* vswaybar:modpad */\n"
            f"{B} #clock, {B} #cpu, {B} #memory, {B} #network,\n"
            f"{B} #pulseaudio, {B} #battery, {B} #tray,\n"
            f"{B} #custom-updates, {B} #custom-weather, {B} #custom-swaync,\n"
            f"{B} #custom-power, {B} #custom-settings, {B} #custom-claudebar,\n"
            f"{B} #custom-bar-cpu, {B} #custom-bar-mem,\n"
            f"{B} #custom-bar-vol, {B} #custom-bar-wifi {{\n"
            f"    padding: 0 {mod_pad}px;\n"
            f"}}\n"
            f"{B} #custom-arch {{\n"
            f"    padding: 0 {arch_pr}px 0 {arch_pl}px;\n"
            f"}}\n"
            f"{B} #custom-bar-cpu  {{ color: @peach; }}\n"
            f"{B} #custom-bar-mem  {{ color: @mauve; }}\n"
            f"{B} #custom-bar-vol  {{ color: @blue; }}\n"
            f"{B} #custom-bar-wifi {{ color: @green; }}\n"
        )
        # user modules: one block each with padding + color (or pill style)
        for suffix in self._cfg.get("_user_modules", []):
            mod_u   = f"custom/{suffix}"
            color   = self._cfg.get(mod_u, {}).get("_color", "#a6adc8")
            inverted = self._cfg.get(mod_u, {}).get("_inverted", False)
            if inverted:
                css_text += (
                    f"{B} #custom-{suffix} {{\n"
                    f"    padding: 0 {mod_pad}px;\n"
                    f"    background: {color};\n"
                    f"    color: @base;\n"
                    f"    border-radius: {zone_r}px;\n"
                    f"    margin: 2px 0;\n"
                    f"}}\n"
                )
            else:
                css_text += (
                    f"{B} #custom-{suffix} {{\n"
                    f"    padding: 0 {mod_pad}px;\n"
                    f"    color: {color};\n"
                    f"}}\n"
                )
        # dock modules used in bar zones — padding + color (window#bar scoped)
        bar_all = (self._cfg.get("modules-left", []) +
                   self._cfg.get("modules-center", []) +
                   self._cfg.get("modules-right", []))
        seen_dock = set()
        for mod in bar_all:
            if not mod.startswith("custom/"):
                continue
            if mod not in self._dock_cfg:
                continue
            if mod in seen_dock:
                continue
            seen_dock.add(mod)
            suffix = mod[7:]
            color = self._dock_cfg[mod].get("_color", "@text")
            css_text += (
                f"{B} #custom-{suffix} {{\n"
                f"    padding: 0 {mod_pad}px;\n"
                f"    color: {color};\n"
                f"}}\n"
            )
        # ── separators (bar namespace) ────────────────────────────────────────
        separators = self._cfg.get("separators", False)
        css_text = re.sub(r'\n*/\* vswaybar:sep \*/.*$', '', css_text, flags=re.DOTALL)
        if separators and bar_style in ("islands", "bar"):
            sep_color = s0_color
            css_text += (
                f"\n/* vswaybar:sep */\n"
                f"{B} .modules-left > *, {B} .modules-center > *, {B} .modules-right > * {{\n"
                f"    border-right: {brd_w}px solid {sep_color};\n"
                f"}}\n"
                f"{B} .modules-left > *:last-child,\n"
                f"{B} .modules-center > *:last-child,\n"
                f"{B} .modules-right > *:last-child {{\n"
                f"    border-right: none;\n"
                f"}}\n"
            )

        # ── enforce module color assignments to match preview MOD_COLOR ─────────
        _MOD_CSS_TOKENS = {
            "clock":            "@blue",
            "cpu":              "@peach",
            "memory":           "@mauve",
            "network":          "@green",
            "pulseaudio":       "@blue",
            "wireplumber":      "@blue",
            "battery":          "@green",
            "tray":             "@subtext0",
            "window":           "@subtext0",
            "custom-updates":   "@green",
            "custom-weather":   "@peach",
            "custom-swaync":    "@text",
            "custom-power":     "@red",
            "custom-settings":  "@subtext0",
            "custom-claudebar": "@green",
            "custom-bar-cpu":   "@peach",
            "custom-bar-mem":   "@mauve",
            "custom-bar-vol":   "@blue",
            "custom-bar-wifi":  "@green",
            "temperature":      "@peach",
            "disk":             "@yellow",
            "bluetooth":        "@blue",
            "backlight":        "@yellow",
            "mpris":            "@mauve",
            "idle-inhibitor":   "@subtext0",
        }
        for _css_id, _token in _MOD_CSS_TOKENS.items():
            css_text = re.sub(
                rf'(#{re.escape(_css_id)}\s*\{{[^}}]*?color:\s*)[^;]+;',
                rf'\g<1>{_token};',
                css_text, flags=re.DOTALL
            )

        # ── pill (inverted) rules — MUST be after _MOD_CSS_TOKENS so they aren't patched ──
        _PILL_CSS_MAP = {
            "clock":            ("clock",            "@blue"),
            "cpu":              ("cpu",              "@peach"),
            "memory":           ("memory",           "@mauve"),
            "network":          ("network",          "@green"),
            "pulseaudio":       ("pulseaudio",       "@blue"),
            "wireplumber":      ("wireplumber",      "@blue"),
            "battery":          ("battery",          "@green"),
            "temperature":      ("temperature",      "@peach"),
            "disk":             ("disk",             "@yellow"),
            "bluetooth":        ("bluetooth",        "@blue"),
            "backlight":        ("backlight",        "@yellow"),
            "mpris":            ("mpris",            "@mauve"),
            "idle_inhibitor":   ("idle_inhibitor",   "@subtext0"),
            "tray":             ("tray",             "@subtext0"),
            "custom/updates":   ("custom-updates",   "@green"),
            "custom/weather":   ("custom-weather",   "@peach"),
            "custom/swaync":    ("custom-swaync",    "@text"),
            "custom/power":     ("custom-power",     "@red"),
            "custom/settings":  ("custom-settings",  "@subtext0"),
            "custom/claudebar": ("custom-claudebar", "@green"),
            "custom/bar-cpu":   ("custom-bar-cpu",   "@peach"),
            "custom/bar-mem":   ("custom-bar-mem",   "@mauve"),
            "custom/bar-vol":   ("custom-bar-vol",   "@blue"),
            "custom/bar-wifi":  ("custom-bar-wifi",  "@green"),
        }
        for _pk, (_cid, _tok) in _PILL_CSS_MAP.items():
            if self._cfg.get(_pk, {}).get("_inverted", False):
                css_text += (
                    f"{B} #{_cid} {{\n"
                    f"    background: {_tok};\n"
                    f"    color: @base;\n"
                    f"    border-radius: {zone_r}px;\n"
                    f"    margin: 2px 0;\n"
                    f"}}\n"
                )

        # ── workspace animation colors ───────────────────────────────────────
        ws_c = self._cfg.get("hyprland/workspaces", {})
        ac1  = ws_c.get("anim-color-1",  "#2980b9")
        ac2  = ws_c.get("anim-color-2",  "#420ed2")
        dur  = ws_c.get("anim-duration", 3.0)
        wsr  = ws_c.get("button-radius", 8)
        css_text = re.sub(
            r'(@keyframes\s+ws-active\s*\{[^}]*0%\s*\{[^}]*background-color:\s*)(#[0-9a-fA-F]{6})',
            rf'\g<1>{ac1}',
            css_text, flags=re.DOTALL | re.IGNORECASE
        )
        css_text = re.sub(
            r'(@keyframes\s+ws-active\s*\{.*?50%\s*\{[^}]*background-color:\s*)(#[0-9a-fA-F]{6})',
            rf'\g<1>{ac2}',
            css_text, flags=re.DOTALL | re.IGNORECASE
        )
        css_text = re.sub(
            r'(#workspaces\s+button\.active\s*\{[^}]*animation:\s*ws-active\s+)([\d.]+)s',
            rf'\g<1>{dur}s',
            css_text, flags=re.DOTALL
        )
        css_text = re.sub(
            r'(#workspaces\s+button\s*\{[^}]*border-radius:\s*)\d+px',
            rf'\g<1>{wsr}px',
            css_text, flags=re.DOTALL
        )
        wpv = ws_c.get("button-pad-v", 4)
        wph = ws_c.get("button-pad-h", 14)
        css_text = re.sub(
            r'(#workspaces\s+button\s*\{[^}]*padding:\s*)\d+px\s+\d+px',
            rf'\g<1>{wpv}px {wph}px',
            css_text, flags=re.DOTALL
        )
        wmw = ws_c.get("button-minw", 32)
        css_text = re.sub(
            r'(#workspaces\s+button\s*\{[^}]*min-width:\s*)\d+px',
            rf'\g<1>{wmw}px',
            css_text, flags=re.DOTALL
        )

        # ── append dock CSS (fully namespaced under window#waybar.dock) ─────────
        # strip previous dock section if present
        css_text = re.sub(r'\n*/\* vswaybar:dock:begin \*/.*$', '', css_text, flags=re.DOTALL)
        css_text += "\n\n/* vswaybar:dock:begin */\n"
        css_text += self._build_save_dock_css()

        return css_text

    def _build_save_dock_config(self) -> dict:
        out = {}
        for k in ("position", "height", "spacing", "layer",
                  "margin-top", "margin-bottom", "margin-left", "margin-right"):
            out[k] = self._dock_cfg.get(k, DOCK_DEFAULTS.get(k))
        if "output" in self._dock_cfg and self._dock_cfg["output"] != "__disabled__":
            out["output"] = self._dock_cfg["output"]
        out["exclusive"]       = self._dock_cfg.get("exclusive", True)
        out["passthrough"]     = False
        out["gtk-layer-shell"] = True
        out["modules-left"]    = self._dock_cfg.get("modules-left",   [])
        out["modules-center"]  = self._dock_cfg.get("modules-center", [])
        out["modules-right"]   = self._dock_cfg.get("modules-right",  [])
        all_mods = out["modules-left"] + out["modules-center"] + out["modules-right"]
        for mod in all_mods:
            if mod.startswith("custom/") and mod in self._dock_cfg:
                mc    = self._dock_cfg[mod]
                entry = {"format": mc.get("format", "󰘳"), "tooltip": False}
                oc    = mc.get("on-click", "").strip()
                if oc:
                    entry["on-click"] = oc
                tt = mc.get("tooltip-format", "").strip()
                if tt:
                    entry["tooltip-format"] = tt
                    entry["tooltip"]        = True
                out[mod] = entry
        return out

    def _build_save_dock_css(self) -> str:
        """Generate dock CSS completely from scratch — no file patching."""
        zone_r    = self._dock_cfg.get("zone-radius",  16)
        bar_style = self._dock_cfg.get("bar-style",    "islands")
        opacity   = self._dock_cfg.get("opacity",       90) / 100
        font_sz   = self._dock_cfg.get("font-size",     22)
        mod_pad   = self._dock_cfg.get("mod-padding",   14)
        brd_w     = self._dock_cfg.get("border-width",  2)
        font_fam  = self._dock_cfg.get("font-family",   "JetBrainsMono Nerd Font")
        separators= self._dock_cfg.get("separators",    False)
        # alpha() usa tokens CSS → backgrounds responden a vshypr-theme-manager
        bg_alpha  = f"alpha(@base, {opacity:.2f})"
        brd  = f"{brd_w}px solid @surface0" if brd_w > 0 else "none"
        pv, ph = 4, mod_pad

        D  = "window#waybar.dock"   # namespace prefix
        out = []

        # ── font override (dock overrides global * { font-size }) ─────────────
        out.append(f"{D} * {{")
        out.append(f'    font-family: "{font_fam}", monospace;')
        out.append(f"    font-size: {font_sz}px;")
        out.append("}")
        out.append("")

        # ── window#waybar.dock ────────────────────────────────────────────────
        win_bg = bg_alpha if bar_style == "bar" else "transparent"
        out.append(f"{D} {{")
        out.append(f"    background: {win_bg};")
        out.append("    border: none;")
        out.append("}")
        out.append("")

        # ── module zone blocks ────────────────────────────────────────────────
        active_zones = [z for z in ("modules-left", "modules-center", "modules-right")
                        if self._dock_cfg.get(z)]

        def _zone_sels(zones, child=""):
            suffix = f" > {child}" if child else ""
            return ",\n".join(f"{D} .{z}{suffix}" for z in zones)

        if bar_style == "bar":
            out.append(f"{_zone_sels(['modules-left','modules-center','modules-right'])} {{")
            out.append("    background: transparent;")
            out.append("    border-radius: 0;")
            out.append(f"    padding: {pv}px {ph}px;")
            out.append("    border: none;")
            out.append("    min-height: 0;")
            out.append("}")
        elif bar_style == "islands":
            out.append(f"{_zone_sels(['modules-left','modules-center','modules-right'])} {{")
            out.append("    background: transparent;")
            out.append("    border: none;")
            out.append("    padding: 0;")
            out.append("    min-height: 0;")
            out.append("    min-width: 0;")
            out.append("}")
            if active_zones:
                out.append("")
                out.append(f"{_zone_sels(active_zones)} {{")
                out.append(f"    background: {bg_alpha};")
                out.append(f"    border-radius: {zone_r}px;")
                out.append(f"    padding: {pv}px {ph}px;")
                out.append(f"    border: {brd};")
                out.append("    min-height: 0;")
                out.append("}")
        else:  # modules
            out.append(f"{_zone_sels(['modules-left','modules-center','modules-right'])} {{")
            out.append("    background: transparent;")
            out.append("    border-radius: 0;")
            out.append(f"    padding: {pv}px 0;")
            out.append("    border: none;")
            out.append("    min-height: 0;")
            out.append("}")
            out.append("")
            out.append(f"{_zone_sels(['modules-left','modules-center','modules-right'], '*')} {{")
            out.append(f"    background: {bg_alpha};")
            out.append(f"    border-radius: {zone_r}px;")
            out.append(f"    padding: {pv}px {ph}px;")
            out.append(f"    border: {brd};")
            out.append("    margin: 0 2px;")
            out.append("}")
        out.append("")

        # ── per-icon rules (namespaced under window#dock) ─────────────────────
        all_dock_mods = []
        for zone in ("modules-left", "modules-center", "modules-right"):
            for mod in self._dock_cfg.get(zone, []):
                if mod.startswith("custom/") and mod not in all_dock_mods:
                    all_dock_mods.append(mod)

        if all_dock_mods:
            _HOVER_DEFAULTS = {
                "rofi":     ("@mauve",  "203,166,247"),
                "firefox":  ("@blue",   "139,213,202"),
                "nautilus": ("@yellow", "249,226,175"),
                "dolphin":  ("@yellow", "249,226,175"),
                "terminal": ("@green",  "166,227,161"),
                "vscode":   ("@mauve",  "203,166,247"),
            }
            ids = ",\n".join(f"{D} #{m.replace('/', '-')}" for m in all_dock_mods)
            out.append(f"/* Dock icons */\n{ids} {{")
            out.append(f"    padding: {pv}px {ph}px;")
            out.append("    border-radius: 10px;")
            out.append("    transition: all 0.2s ease;")
            out.append("    min-width: 30px;")
            out.append("}")
            out.append("")
            for mod in all_dock_mods:
                css_id = f"{D} #{mod.replace('/', '-')}"
                # fall back to bar cfg for modules shared between bar user_modules and dock
                col = (self._dock_cfg.get(mod, {}).get("_color", "")
                       or self._cfg.get(mod, {}).get("_color", ""))
                inverted = (self._dock_cfg.get(mod, {}).get("_inverted", False)
                            or self._cfg.get(mod, {}).get("_inverted", False))
                if inverted and re.match(r'^#[0-9a-fA-F]{6}$', col, re.IGNORECASE):
                    out.append(f"{css_id} {{ background: {col}; color: @base; border-radius: {zone_r}px; margin: 2px 0; }}")
                elif re.match(r'^#[0-9a-fA-F]{6}$', col, re.IGNORECASE):
                    out.append(f"{css_id} {{ color: {col}; }}")
                else:
                    out.append(f"{css_id} {{ color: @text; }}")
            out.append("")
            for mod in all_dock_mods:
                suffix = mod[7:]
                css_id = f"{D} #{mod.replace('/', '-')}"
                inverted = (self._dock_cfg.get(mod, {}).get("_inverted", False)
                            or self._cfg.get(mod, {}).get("_inverted", False))
                if suffix in _HOVER_DEFAULTS and not inverted:
                    hcol, hrgb = _HOVER_DEFAULTS[suffix]
                    out.append(f"{css_id}:hover {{ color: {hcol}; background: rgba({hrgb},0.12); }}")
                else:
                    col = (self._dock_cfg.get(mod, {}).get("_color", "")
                           or self._cfg.get(mod, {}).get("_color", ""))
                    if re.match(r'^#[0-9a-fA-F]{6}$', col, re.IGNORECASE):
                        h = col.lstrip("#")
                        r2, g2, b2 = int(h[0:2],16), int(h[2:4],16), int(h[4:6],16)
                        if inverted:
                            out.append(f"{css_id}:hover {{ background: rgba({r2},{g2},{b2},0.85); color: @base; }}")
                        else:
                            out.append(f"{css_id}:hover {{ color: {col}; background: rgba({r2},{g2},{b2},0.12); }}")
            out.append("")

        # ── separators ────────────────────────────────────────────────────────
        if separators and bar_style in ("islands", "bar"):
            out.append("/* vswaybar:dock:sep */")
            out.append(f"{_zone_sels(['modules-left','modules-center','modules-right'], '*')} {{")
            out.append(f"    border-right: {brd_w}px solid {s0_color};")
            out.append("}")
            lc = f"{D} .modules-left > *:last-child,\n{D} .modules-center > *:last-child,\n{D} .modules-right > *:last-child"
            out.append(f"{lc} {{")
            out.append("    border-right: none;")
            out.append("}")
            out.append("")

        return "\n".join(out)

    def _on_export_zip(self, *_):
        import zipfile as _zf
        ts  = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        dlg = Gtk.FileChooserDialog(
            title="Export as ZIP…", parent=self,
            action=Gtk.FileChooserAction.SAVE,
            buttons=("Cancel", Gtk.ResponseType.CANCEL, "Export", Gtk.ResponseType.OK),
        )
        dlg.set_current_name(f"waybar-config-{ts}.zip")
        dlg.set_do_overwrite_confirmation(True)
        ff = Gtk.FileFilter()
        ff.set_name("ZIP archives")
        ff.add_pattern("*.zip")
        dlg.add_filter(ff)

        if dlg.run() != Gtk.ResponseType.OK:
            dlg.destroy()
            return
        dest = dlg.get_filename()
        dlg.destroy()

        try:
            waybar_dir = os.path.dirname(self._config_path)
            with _zf.ZipFile(dest, "w", _zf.ZIP_DEFLATED) as z:
                # config
                if os.path.isfile(self._config_path):
                    z.write(self._config_path,
                            os.path.basename(self._config_path))
                # CSS
                if os.path.isfile(self._css_path):
                    z.write(self._css_path, os.path.basename(self._css_path))
                # scripts/
                scripts_dir = os.path.join(waybar_dir, "scripts")
                if os.path.isdir(scripts_dir):
                    for fn in os.listdir(scripts_dir):
                        fp = os.path.join(scripts_dir, fn)
                        if os.path.isfile(fp):
                            z.write(fp, os.path.join("scripts", fn))
            self._status(f"✓  Exported → {os.path.basename(dest)}")
        except Exception as e:
            self._show_alert("Export failed", str(e), error=True)

    def _on_save_as(self, *_):
        dlg = Gtk.FileChooserDialog(
            title="Save config as…", parent=self,
            action=Gtk.FileChooserAction.SAVE,
            buttons=("Cancel", Gtk.ResponseType.CANCEL, "Save", Gtk.ResponseType.OK),
        )
        dlg.set_current_name(os.path.basename(self._config_path))
        dlg.set_do_overwrite_confirmation(True)
        if dlg.run() == Gtk.ResponseType.OK:
            dest = dlg.get_filename()
            dlg.destroy()
            self._collect()
            try:
                self._backup_configs()
                cfg_out = self._build_save_config()
                css_out = self._build_save_css()
                with open(dest, "w") as f:
                    json.dump(cfg_out, f, indent=4, ensure_ascii=False)
                css_dest = os.path.splitext(dest)[0] + ".css"
                with open(css_dest, "w") as f:
                    f.write(css_out)
                self._status(f"✓  Saved to {os.path.basename(dest)}")
            except Exception as e:
                self._err(f"Could not save:\n{e}")
        else:
            dlg.destroy()

    def _on_open(self, *_):
        t = self._theme

        dlg = Gtk.Dialog(title="Open Waybar files", parent=self,
                         flags=Gtk.DialogFlags.MODAL)
