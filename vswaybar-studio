# ── CSS builder ───────────────────────────────────────────────────────────────

def _build_css(t: dict) -> bytes:
    return f"""
* {{ font-family: "JetBrainsMono Nerd Font", monospace; }}
window {{ background-color: {t['bg']}; }}

.app-header {{
    background-color: {t['hdr']};
    border-bottom: 1px solid {t['brd']};
    padding: 14px 20px;
}}
.app-title {{ color: {t['txt']}; font-size: 18px; font-weight: bold; }}
.app-path  {{ color: {t['dim']}; font-size: 12px; }}

notebook {{ background-color: {t['bg']}; }}
notebook > header.left {{
    background-color: {t['hdr']};
    border-right: 1px solid {t['brd']};
    padding: 8px 0;
}}
notebook > header > tabs > tab {{
    background-color: transparent;
    color: {t['dim']};
    font-size: 14px;
    padding: 10px 20px 10px 16px;
    border: none;
    border-left: 3px solid transparent;
    border-radius: 0;
    min-width: 120px;
}}
notebook > header > tabs > tab:checked {{
    background-color: {t['bg']};
    color: {t['acc']};
    border-left-color: {t['acc']};
}}
notebook > header > tabs > tab:hover:not(:checked) {{
    color: {t['txt']};
    background-color: rgba({t['acc_rgb']}, 0.07);
}}

.page-scroll {{ background-color: {t['bg']}; }}
.section-title {{
    color: {t['acc']};
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 1px;
    margin-top: 18px;
    margin-bottom: 6px;
}}
.field-label  {{ color: {t['dim']}; font-size: 13px; }}
.color-key    {{ color: {t['mid']}; font-size: 13px; font-family: monospace; }}
.hint-label   {{ color: {t['dim']}; font-size: 12px; font-style: italic; }}
.module-title {{ color: {t['txt']}; font-size: 15px; font-weight: bold; }}

label {{ color: {t['txt']}; }}
button label {{ color: inherit; }}

entry, spinbutton, spinbutton entry, spinbutton text {{
    background-color: {t['hdr']};
    background-image: none;
    color: {t['txt']};
    border: 1px solid {t['brd']};
    border-radius: 5px;
    padding: 5px 10px;
    caret-color: {t['acc']};
    box-shadow: none;
}}
entry:focus, spinbutton:focus {{ border-color: {t['acc']}; }}
spinbutton button {{
    background-color: {t['btn_bg']};
    background-image: none;
    color: {t['txt']};
    border: none;
    border-radius: 0;
    padding: 2px 4px;
    box-shadow: none;
    min-height: 0;
    min-width: 0;
}}
spinbutton button:hover {{ color: {t['acc']}; background-color: {t['btn_bg']}; }}

combobox, combobox button, combobox entry {{
    background-color: {t['btn_bg']};
    background-image: none;
    color: {t['txt']};
    border: 1px solid {t['brd']};
    border-radius: 5px;
    padding: 5px 8px;
    box-shadow: none;
}}
combobox button:hover {{ border-color: {t['acc']}; }}

button {{
    background-color: {t['btn_bg']};
    background-image: none;
    color: {t['txt']};
    border: 1px solid {t['brd']};
    border-radius: 5px;
    padding: 5px 14px;
    box-shadow: none;
}}
button:hover {{
    background-color: {t['btn_bg']};
    background-image: none;
    border-color: {t['acc']};
    color: {t['acc']};
}}

.save-btn {{
    background-color: {t['acc']};
    background-image: none;
    color: {t['save_fg']};
    border: none;
    border-radius: 6px;
    padding: 6px 22px;
    font-weight: bold;
    font-size: 14px;
    box-shadow: none;
}}
.save-btn:hover {{
    background-color: rgba({t['acc_rgb']}, 0.8);
    background-image: none;
}}

.open-btn {{
    background-color: {t['btn_bg']};
    background-image: none;
    color: {t['dim']};
    border: 1px solid {t['brd']};
    box-shadow: none;
}}
.open-btn:hover {{
    background-color: {t['btn_bg']};
    background-image: none;
    color: {t['acc']};
    border-color: {t['acc']};
}}

.plugin-card {{
    background-color: {t['hdr']};
    border: 1px solid {t['brd']};
    border-radius: 6px;
}}
.plugin-card-active {{
    background-color: {t['hdr']};
    border: 1px solid {t['acc']};
    border-radius: 6px;
}}

.theme-btn {{
    background-color: {t['btn_bg']};
    background-image: none;
    color: {t['dim']};
    border: 1px solid {t['brd']};
    border-radius: 5px;
    padding: 5px 10px;
    font-size: 13px;
    box-shadow: none;
}}
.theme-btn:hover {{
    background-color: {t['btn_bg']};
    background-image: none;
    color: {t['acc']};
    border-color: {t['acc']};
}}

