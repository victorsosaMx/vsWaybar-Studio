    def _load_default_dock_layout(self, *_):
        self._dock_cfg["modules-left"]   = []
        self._dock_cfg["modules-center"] = list(DOCK_DEFAULTS.get("modules-center", []))
        self._dock_cfg["modules-right"]  = []
        for zone_key in ("modules-left", "modules-center", "modules-right"):
            store = self._w_dock.get(f"zone_{zone_key}")
            if store:
                store.clear()
                for mod in self._dock_cfg[zone_key]:
                    icon, name = MODULE_LABELS.get(mod, ("", mod))
                    store.append([mod, f"{icon}  {name}"])
        self._refresh_preview()
        self._status("↺  Default dock layout restored.")

    def _draw_zone_preview(self, widget, cr, side):
        """Render a single zone (left or right) at natural scale for detail view."""
        AW = widget.get_allocated_width()
        AH = widget.get_allocated_height()
        c  = self._css_colors

        def _col(name, fb): return _hex_to_rgb(c.get(name, fb))
        base     = _col("base",     "#11140e")
        surface0 = _col("surface0", "#1d211a")
        overlay0 = _col("overlay0", "#33362f")
        sub0     = _col("subtext0", "#c4c8bb")
        blue     = _col("blue",     "#abd290")
        mauve    = _col("mauve",    "#abd290")
        green    = _col("green",    "#a0cfcf")
        peach    = _col("peach",    "#1e4e4e")
        red_c    = _col("red",      "#ffb4ab")
        text_c   = _col("text",     "#e1e4d9")
        MOD_COLOR = {
            "custom/arch": blue, "hyprland/workspaces": sub0,
            "hyprland/window": sub0, "custom/weather": peach,
            "clock": blue, "tray": sub0,
            "custom/updates": green, "pulseaudio": blue,
            "network": green, "memory": mauve,
            "cpu": peach, "battery": green,
            "custom/swaync": text_c, "custom/power": red_c,
            "custom/settings": sub0, "custom/claudebar": green,
        }
        # add user command modules with their stored color
        for _suf in self._cfg.get("_user_modules", []):
            _hex = self._cfg.get(f"custom/{_suf}", {}).get("_color", "")
            MOD_COLOR[f"custom/{_suf}"] = _hex_to_rgb(_hex) if _hex else sub0
        # dock modules used in bar zones — use their dock-side _color
        for _m in (self._cfg.get("modules-left", []) +
                   self._cfg.get("modules-center", []) +
                   self._cfg.get("modules-right", [])):
            if _m.startswith("custom/") and _m in self._dock_cfg:
                _hex = self._dock_cfg[_m].get("_color", "")
                MOD_COLOR[_m] = _hex_to_rgb(_hex) if re.match(r'^#[0-9a-fA-F]{6}$', _hex) else sub0

        bar_style = self._cfg.get("bar-style",   "islands")
        zone_r    = self._cfg.get("zone-radius",  12)
        font_sz   = self._cfg.get("font-size",    13)
        _arch_icon_sz = _parse_arch_icon_sz(self._cfg, font_sz)
        mod_pad   = self._cfg.get("mod-padding",  8)
        spacing   = self._cfg.get("spacing",       4)
        opacity   = self._cfg.get("opacity",       95) / 100
        separators= self._cfg.get("separators",   False)
        brd_w     = self._cfg.get("border-width",  1)
        ff        = self._cfg.get("font-family",  "JetBrainsMono Nerd Font Mono")

        zone_key  = f"modules-{side}"
        mods      = self._cfg.get(zone_key, [])

        # bg
        cr.set_source_rgb(*_hex_to_rgb(self._theme["bg"]))
        cr.paint()

        if not mods:
            return

        # measure content width at natural scale (sx=1)
        def _mod_w(mod):
            lo = PangoCairo.create_layout(cr)
            fd = Pango.FontDescription.from_string(ff)
            fd.set_absolute_size(max(6, font_sz) * Pango.SCALE)
            lo.set_font_description(fd)
            s = (self._cfg.get("custom/arch", {}).get("arch-icon-glyph", "󰣇") if mod == "custom/arch" else (MOD_SAMPLE.get(mod) or self._cfg.get(mod, self._dock_cfg.get(mod, {})).get("format") if mod.startswith("custom/") else MOD_SAMPLE.get(mod)))
            if s is None:
                icon, name = MODULE_LABELS.get(mod, ("", mod.split("/")[-1]))
                s = f"{icon} {name}" if icon else name
            lo.set_text(s, -1)
            tw, _ = lo.get_pixel_size()
            if mod == "custom/arch":
                _pl = self._cfg.get("custom/arch", {}).get("arch-pad-left",  8)
                _pr = self._cfg.get("custom/arch", {}).get("arch-pad-right", 8)
                return tw + _pl + _pr
            return tw + mod_pad * 2

        _arch_col_hex_z = _parse_arch_icon_color(self._cfg)
        _arch_col_rgb_z = _hex_to_rgb(_arch_col_hex_z) if _arch_col_hex_z else None

        sp     = spacing
        zone_w = mod_pad * 2 + sum(_mod_w(m) for m in mods) + max(0, len(mods)-1) * sp

        # position: left zone → left-aligned, right zone → right-aligned
        if side == "left":
            zx = 12
        else:
            zx = max(12, AW - zone_w - 12)

        bar_h = self._cfg.get("height", 36)
        zy    = (AH - bar_h) // 2

        # zone pill
        if bar_style in ("islands", "modules"):
            cr.set_source_rgba(*base, opacity)
            _cr_rounded_rect(cr, zx, zy, zone_w, bar_h, zone_r)
            cr.fill()
            if brd_w > 0:
                cr.set_source_rgb(*surface0)
                cr.set_line_width(brd_w)
                _cr_rounded_rect(cr, zx+.5, zy+.5, zone_w-1, bar_h-1, zone_r)
                cr.stroke()
        else:  # bar
            cr.set_source_rgba(*base, opacity)
            cr.rectangle(0, zy, AW, bar_h)
            cr.fill()

        # modules content
        mx = zx + mod_pad
        for mod in mods:
            mw  = _mod_w(mod)
            _is_user = mod.startswith("custom/") and mod[7:] not in _RESERVED_CUSTOM
            col = MOD_COLOR.get(mod, sub0) if (mod != self._selected_module or _is_user) else blue
            lo  = PangoCairo.create_layout(cr)
            fd  = Pango.FontDescription.from_string(
                      ff + (" Bold" if mod == "clock" else
                            " Italic" if mod == "hyprland/window" else ""))
            fd.set_absolute_size((_arch_icon_sz if mod == "custom/arch" else font_sz) * Pango.SCALE)
            lo.set_font_description(fd)
            s = (self._cfg.get("custom/arch", {}).get("arch-icon-glyph", "󰣇") if mod == "custom/arch" else (MOD_SAMPLE.get(mod) or self._cfg.get(mod, self._dock_cfg.get(mod, {})).get("format") if mod.startswith("custom/") else MOD_SAMPLE.get(mod)))
            if s is None:
                icon, name = MODULE_LABELS.get(mod, ("", mod.split("/")[-1]))
                s = f"{icon} {name}" if icon else name
            lo.set_text(s, -1)
            tw, th = lo.get_pixel_size()
            if mod == "custom/arch":
                draw_col_z = _arch_col_rgb_z if _arch_col_rgb_z else col
                _pl = self._cfg.get("custom/arch", {}).get("arch-pad-left", 8)
                tx_z = mx + _pl
            else:
                draw_col_z = col
                tx_z = mx + (mw - tw) / 2
            cr.set_source_rgb(*draw_col_z)
            cr.move_to(tx_z, zy + (bar_h - th) / 2)
            PangoCairo.show_layout(cr, lo)
            mx += mw + sp

        # separators
        if separators and bar_style in ("islands", "bar") and len(mods) > 1:
            sep_inset = int(bar_h * 0.2)
            cr.set_source_rgb(*overlay0)
            cr.set_line_width(1.0)
            mx = zx + mod_pad
            for mod in mods[:-1]:
                mx += _mod_w(mod)
                sep_x = mx + max(sp, 2) / 2
                cr.move_to(sep_x, zy + sep_inset)
                cr.line_to(sep_x, zy + bar_h - sep_inset)
                cr.stroke()
                mx += sp

    def _build_preview_html(self) -> str:
        """Genera HTML con bar + dock para el WebKit2 preview."""

        c    = self._css_colors
        cfg  = self._cfg
        dock = self._dock_cfg

        def hx(name, fb="#000000"):
            return c.get(name, fb)

        def to_rgba(hex_c, a=1.0):
            h = hex_c.lstrip("#")
            if len(h) == 6:
                r, g, b = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
                return f"rgba({r},{g},{b},{a:.2f})"
            return hex_c

        base     = hx("base",     "#11140e")
        text_c   = hx("text",     "#e1e4d9")
        surface0 = hx("surface0", "#1d211a")
        blue     = hx("blue",     "#89b4fa")
        peach    = hx("peach",    "#fab387")
        green    = hx("green",    "#a6e3a1")
        mauve    = hx("mauve",    "#cba6f7")
        red_c    = hx("red",      "#f38ba8")
        yellow   = hx("yellow",   "#f9e2af")
        sub0     = hx("subtext0", "#a6adc8")

        bar_style  = cfg.get("bar-style",    "islands")
        bar_h      = cfg.get("height",         42)
        bar_pos    = cfg.get("position",       "top")
        font_sz    = cfg.get("font-size",       13)
        mod_pad    = cfg.get("mod-padding",      8)
        zone_r     = cfg.get("zone-radius",     12)
        opacity    = cfg.get("opacity",         95) / 100
        brd_w      = cfg.get("border-width",     1)
        spacing    = cfg.get("spacing",         10)
        mt         = cfg.get("margin-top",       0)
        mb_b       = cfg.get("margin-bottom",    0)
        ml         = cfg.get("margin-left",      0)
        mr         = cfg.get("margin-right",     0)
        separators = cfg.get("separators",   False)
        font_fam   = cfg.get("font-family",  "JetBrainsMono Nerd Font")

        dock_h     = dock.get("height",       54)
        dock_pos   = dock.get("position",     "bottom")
        dock_style = dock.get("bar-style",    "islands")
        dock_sz    = dock.get("font-size",    22)
        dock_pad   = dock.get("mod-padding",  14)
        dock_r     = dock.get("zone-radius",  16)
        dock_op    = dock.get("opacity",      90) / 100
        dock_brd   = dock.get("border-width",  2)
        dock_mb    = dock.get("margin-bottom",  8)
        dock_sep   = dock.get("separators",  False)
        dock_sp    = dock.get("spacing",       6)
        dock_fam   = dock.get("font-family",  "JetBrainsMono Nerd Font")

        ws_c = cfg.get("hyprland/workspaces", {})
        ac1  = ws_c.get("anim-color-1", "#2980b9")
        ac2  = ws_c.get("anim-color-2", "#420ed2")
        ws_r = ws_c.get("button-radius",  8)
        dur  = ws_c.get("anim-duration", 3.0)

        bg_theme = self._theme.get("bg", "#1a1b26")

        MOD_COLOR = {
            "custom/arch":         blue,   "hyprland/workspaces": sub0,
            "hyprland/window":     sub0,   "custom/weather":      peach,
            "clock":               blue,   "tray":                sub0,
            "custom/updates":      green,  "pulseaudio":          blue,
            "wireplumber":         blue,   "network":             green,
            "memory":              mauve,  "cpu":                 peach,
            "battery":             green,  "custom/swaync":       text_c,
            "custom/power":        red_c,  "custom/settings":     sub0,
            "temperature":         peach,  "disk":                yellow,
            "bluetooth":           blue,   "backlight":           yellow,
            "idle_inhibitor":      sub0,   "mpris":               mauve,
            "privacy":             sub0,   "wlr/taskbar":         sub0,
            "custom/claudebar":    green,
            "custom/bar-cpu":      peach,
            "custom/bar-mem":      mauve,
            "custom/bar-vol":      blue,
            "custom/bar-wifi":     green,
        }
        for suf in cfg.get("_user_modules", []):
            h = cfg.get(f"custom/{suf}", {}).get("_color", "")
            MOD_COLOR[f"custom/{suf}"] = h if re.match(r'^#[0-9a-fA-F]{6}$', h) else sub0
        # dock modules: populate MOD_COLOR from dock cfg (fall back to bar cfg)
        for _m in (dock.get("modules-left", []) +
                   dock.get("modules-center", []) +
                   dock.get("modules-right", [])):
            if _m.startswith("custom/"):
                h = (dock.get(_m, {}).get("_color", "")
                     or cfg.get(_m, {}).get("_color", ""))
                if re.match(r'^#[0-9a-fA-F]{6}$', h):
                    MOD_COLOR[_m] = h

        def mod_html(mod, is_dock=False):
            pad    = dock_pad if is_dock else mod_pad
            bstyle = dock_style if is_dock else bar_style
            r      = dock_r if is_dock else zone_r
            op     = dock_op if is_dock else opacity

            # cffi/ — render as plugin pill with icon
            if mod.startswith("cffi/"):
                suffix = mod[5:]
                return _pill(f"󱋦  {suffix}", pad, bstyle, r, op)

            # group/ — render leader (first child) + collapse indicator
            if mod.startswith("group/"):
                gcfg    = self._groups.get(mod, {})
                members = gcfg.get("modules", [])
                leader  = members[0] if members else None
                rest    = len(members) - 1 if members else 0
                leader_html = mod_html(leader, is_dock) if leader else ""
                indicator   = (
                    f'<span style="color:{sub0};font-size:0.7em;'
                    f'padding:0 2px">+{rest}</span>'
                    if rest > 0 else ""
                )
                return leader_html + indicator

            if mod == "hyprland/workspaces":
                bubbles = ""
                for i in range(1, 6):
                    cls   = "ws-active" if i == 1 else ""
                    bg_ws = "" if i == 1 else f"background:{surface0};"
                    bubbles += (
                        f'<span class="ws-btn {cls}" '
                        f'style="border-radius:{ws_r}px;{bg_ws}">{i}</span>'
                    )
                return (
                    f'<span class="mod" style="padding:0 {pad}px;'
                    f'display:inline-flex;align-items:center;gap:3px">'
                    + bubbles + "</span>"
                )

            # For dock modules use the format (glyph) from the dock config
            _custom_fb = "󰘳" if mod.startswith("custom/") else mod.split("/")[-1][:4]
            if is_dock:
                # fall back to bar cfg for modules that live in both bar user_modules and dock
                _dock_fmt = dock.get(mod, {}).get("format", "") or cfg.get(mod, {}).get("format", "")
                label = _dock_fmt or MOD_SAMPLE.get(mod, _custom_fb)
            else:
                label = MOD_SAMPLE.get(mod, _custom_fb)
            color = MOD_COLOR.get(mod, sub0)
            if is_dock:
                dc = dock.get(mod, {}).get("_color", "") or cfg.get(mod, {}).get("_color", "")
                if re.match(r'^#[0-9a-fA-F]{6}$', dc):
                    color = dc

            # pill / inverted style
            _src_cfg = dock if is_dock else cfg
            inverted = _src_cfg.get(mod, {}).get("_inverted", False)
            if not inverted and not is_dock:
                # for bar user modules, also check self._cfg directly
                inverted = cfg.get(mod, {}).get("_inverted", False)

            h_total = dock_h if is_dock else bar_h
            if inverted:
                h_mod = h_total - 8
                return (
                    f'<span class="mod" style="padding:0 {pad}px;'
                    f'background:{color};color:{base};'
                    f'border-radius:{r}px;margin:0 2px;'
                    f'height:{h_mod}px;display:inline-flex;align-items:center;">'
                    f'{label}</span>'
                )
            extra = ""
            if bstyle == "modules":
                h_mod = h_total - 8
                extra = (
                    f"background:{to_rgba(base, op)};"
                    f"border-radius:{r}px;margin:0 2px;"
                    f"height:{h_mod}px;display:inline-flex;align-items:center;"
                )
            return (
                f'<span class="mod" style="padding:0 {pad}px;'
                f'color:{color};{extra}">{label}</span>'
            )

        def zone_html(mods, zone_cls, is_dock=False):
            bstyle = dock_style if is_dock else bar_style
            r      = dock_r if is_dock else zone_r
            op     = dock_op if is_dock else opacity
            bw     = dock_brd if is_dock else brd_w
            pad    = dock_pad if is_dock else mod_pad
            sep_on = dock_sep if is_dock else separators

            # Altura de la zona basada en la altura de la barra/dock
            h_total = dock_h if is_dock else bar_h
            h_zone  = h_total - 4   # margen vertical
            h_mod   = h_total - 8   # para estilo modules

            if bstyle == "islands" and mods:
                zone_css = (
                    f"background:{to_rgba(base, op)};"
                    f"border-radius:{r}px;padding:0 {pad}px;"
                    f"height:{h_zone}px;"
                    + (f"border:{bw}px solid {surface0};" if bw > 0 else "")
                )
            elif bstyle == "bar":
                zone_css = f"padding:0 {pad}px;height:100%;"
            else:
                zone_css = f"padding:0 {pad}px;"

            items = []
            for i, m in enumerate(mods):
                items.append(mod_html(m, is_dock))
                if sep_on and bstyle in ("islands", "bar") and i < len(mods) - 1:
                    items.append(
                        f'<span style="border-right:1px solid {surface0};'
                        f'height:60%;align-self:center;margin:0 1px"></span>'
                    )
            return (
                f'<div class="zone {zone_cls}" style="display:inline-flex;'
                f'align-items:center;{zone_css}">'
                + "".join(items) + "</div>"
            )

        # Bar
        mods_l = cfg.get("modules-left",   [])
        mods_c = cfg.get("modules-center", [])
        mods_r = cfg.get("modules-right",  [])

        bar_bg  = to_rgba(base, opacity) if bar_style == "bar" else "transparent"
        bar_brd = f"{brd_w}px solid {surface0}" if bar_style == "bar" and brd_w > 0 else "none"
        ff_bar  = font_fam.replace("'", "\\'")

        # Cada zona ocupa flex:1 para que center quede absolutamente centrado
        def _wrap_zone(content, justify):
            return (
                f'<div style="flex:1;display:flex;align-items:center;'
                f'justify-content:{justify};">{content}</div>'
            )

        bar_div = (
            f'<div id="bar" style="height:{bar_h}px;background:{bar_bg};'
            f"border:{bar_brd};margin:{mt}px {mr}px {mb_b}px {ml}px;"
            f"display:flex;align-items:center;"
            f"font-size:{font_sz}px;"
            f"font-family:'{ff_bar}',monospace;color:{text_c};"
            + '">'
            + _wrap_zone(zone_html(mods_l, "left"),   "flex-start")
            + _wrap_zone(zone_html(mods_c, "center"), "center")
            + _wrap_zone(zone_html(mods_r, "right"),  "flex-end")
            + "</div>"
        )

        # Dock
        dock_mods_l = dock.get("modules-left",   [])
        dock_mods_c = dock.get("modules-center", [])
        dock_mods_r = dock.get("modules-right",  [])

        dock_win_bg = to_rgba(base, dock_op) if dock_style == "bar" else "transparent"
        ff_dock     = dock_fam.replace("'", "\\'")

        dock_div = (
            f'<div id="dock" style="height:{dock_h}px;background:{dock_win_bg};'
            f"display:flex;align-items:center;"
            f"font-size:{dock_sz}px;"
            f"font-family:'{ff_dock}',monospace;color:{text_c};"
            f"margin-bottom:{dock_mb}px;padding:0 8px;"
            + '">'
            + _wrap_zone(zone_html(dock_mods_l, "left",   True), "flex-start")
            + _wrap_zone(zone_html(dock_mods_c, "center", True), "center")
            + _wrap_zone(zone_html(dock_mods_r, "right",  True), "flex-end")
            + "</div>"
        )

        if bar_pos == "top":
            layout = bar_div + '<div class="desktop"></div>' + dock_div
        else:
            layout = dock_div + '<div class="desktop"></div>' + bar_div

        return (
            "<!DOCTYPE html>\n<html><head><meta charset=\"utf-8\">\n<style>\n"
            "* { margin:0; padding:0; box-sizing:border-box; }\n"
            f"html, body {{ width:100%; height:100%; background:{bg_theme};"
            " overflow:hidden; display:flex; flex-direction:column; }\n"
            ".desktop { flex:1; }\n"
            f".ws-btn {{ display:inline-flex; align-items:center; justify-content:center;"
            f" min-width:20px; height:20px; font-size:10px; color:{text_c}; padding:0 4px; }}\n"
            f".ws-active {{ animation: ws-pulse {dur:.1f}s ease-in-out infinite; }}\n"
            f"@keyframes ws-pulse {{ 0%,100% {{ background:{ac1}; }} 50% {{ background:{ac2}; }} }}\n"
            "</style>\n</head>\n"
            f"<body>{layout}</body>\n</html>"
        )

    def _make_zone_editor(self, zone_key: str, zone_label: str,
                          cfg: dict = None, w_dict: dict = None) -> Gtk.Widget:
        if cfg    is None: cfg    = self._cfg
        if w_dict is None: w_dict = self._w
        col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)

        # Zone header
        hdr = Gtk.Box()
        hdr.get_style_context().add_class("zone-header")
        hdr.pack_start(_lbl(zone_label, "section-title"), False, False, 0)
        col.pack_start(hdr, False, False, 0)

        inner = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        inner.set_margin_start(10)
        inner.set_margin_end(10)
        inner.set_margin_top(8)
        inner.set_margin_bottom(8)

        inner.pack_start(_hint("Drag to reorder"), False, False, 0)

        def _zone_label(mod):
            if mod in MODULE_LABELS:
                return MODULE_LABELS[mod]
            if mod.startswith("cffi/"):
                return ("󱋦", mod[5:])
            if mod.startswith("group/"):
                suffix = mod[6:]
                has_drawer = "drawer" in self._groups.get(mod, {})
                return ("󱒊" if has_drawer else "󰾮", suffix)
            glyph = (cfg.get(mod, {}) or
                     self._dock_cfg.get(mod, {}) or
                     self._cfg.get(mod, {})).get("format", "")
            name  = mod.split("/")[-1] if "/" in mod else mod
            return (glyph or "󰘳", name)

        store = Gtk.ListStore(str, str)
        for mod in cfg.get(zone_key, []):
            icon, name = _zone_label(mod)
            store.append([mod, f"{icon}  {name}"])
        w_dict[f"zone_{zone_key}"] = store

        tv = Gtk.TreeView(model=store)
        tv.set_headers_visible(False)
        tv.append_column(Gtk.TreeViewColumn("", Gtk.CellRendererText(), text=1))

        # Unified DnD (within and between zones) — text/plain target only
        # Do not use set_reorderable: registers GTK_TREE_MODEL_ROW which takes priority
        # over TEXT in negotiation, causing data.get_text() to fail cross-zone.
        _dnd_tgts = [Gtk.TargetEntry.new("text/plain", Gtk.TargetFlags.SAME_APP, 0)]
        tv.enable_model_drag_source(
            Gdk.ModifierType.BUTTON1_MASK, _dnd_tgts, Gdk.DragAction.MOVE
        )
        tv.enable_model_drag_dest(_dnd_tgts, Gdk.DragAction.MOVE)
        tv.connect("drag-begin",         self._on_zone_drag_begin,    store)
        tv.connect("drag-data-get",      self._on_zone_drag_get,      store)
        tv.connect("drag-data-received", self._on_zone_drag_received, store)

        up_btn = Gtk.Button(label="▲")
        up_btn.get_style_context().add_class("open-btn")
        up_btn.connect("clicked", self._on_zone_move, tv, -1)

        dn_btn = Gtk.Button(label="▼")
        dn_btn.get_style_context().add_class("open-btn")
        dn_btn.connect("clicked", self._on_zone_move, tv, +1)

        arrow_col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        arrow_col.set_valign(Gtk.Align.CENTER)
        arrow_col.pack_start(up_btn, False, False, 0)
        arrow_col.pack_start(dn_btn, False, False, 0)

        tv_row = Gtk.Box(spacing=4)
        tv_row.pack_start(tv,        True,  True,  0)
        tv_row.pack_start(arrow_col, False, False, 0)
        inner.pack_start(tv_row, False, False, 0)

        btn_row = Gtk.Box(spacing=4)
        btn_row.set_margin_top(6)

        add_btn = Gtk.Button(label="+ Add")
        add_btn.get_style_context().add_class("open-btn")
        add_btn.connect("clicked", self._on_zone_add, zone_key, store, cfg)

        rm_btn = Gtk.Button(label="− Remove")
        rm_btn.get_style_context().add_class("open-btn")
        rm_btn.connect("clicked", self._on_zone_remove, tv)

        btn_row.pack_start(add_btn, True, True, 0)
        btn_row.pack_start(rm_btn,  True, True, 0)
        inner.pack_start(btn_row, False, False, 0)

        col.pack_start(inner, True, True, 0)
        return col

    def _load_default_bar(self, *_):
        bar_keys = ("position", "height", "spacing", "margin-top", "margin-bottom",
                    "margin-left", "margin-right", "font-family", "font-size",
                    "bar-style", "opacity", "zone-radius", "border-width",
                    "separators", "mod-padding")
        for k in bar_keys:
            if k in DEFAULTS:
                self._cfg[k] = DEFAULTS[k]
        self._cfg.pop("output", None)   # "All monitors"
        self._rebuild_ui()
        self._status("↺  Default bar settings restored.")

    def _load_default_layout(self, *_):
        for zone_key, mods in _DEFAULT_LAYOUT.items():
            self._cfg[zone_key] = list(mods)
            store = self._w.get(f"zone_{zone_key}")
            if store:
                store.clear()
                for mod in mods:
                    icon, name = MODULE_LABELS.get(mod, ("", mod))
                    store.append([mod, f"{icon}  {name}"])
        self._refresh_preview()
        self._status("↺  Default layout restored.")

    # ── User module add/remove ────────────────────────────────────────────────

    def _on_user_mod_add(self, *_):
        dlg = Gtk.Dialog(title="New custom module", parent=self,
                         flags=Gtk.DialogFlags.MODAL)
        dlg.add_buttons("Cancel", Gtk.ResponseType.CANCEL,
                        "Create", Gtk.ResponseType.OK)
        box = dlg.get_content_area()
        box.set_spacing(10)
        box.set_margin_start(16); box.set_margin_end(16)
        box.set_margin_top(12);   box.set_margin_bottom(12)
        box.pack_start(_lbl("Module name (e.g. vpn, fan, ping)"), False, False, 0)
        name_entry = Gtk.Entry()
        name_entry.set_placeholder_text("mymodule")
        box.pack_start(name_entry, False, False, 0)
        box.pack_start(_hint("Will be added as  custom/<name>  in your config."), False, False, 0)
        dlg.show_all()
        if dlg.run() == Gtk.ResponseType.OK:
            raw = name_entry.get_text().strip().lower()
            raw = re.sub(r'[^a-z0-9_-]', '', raw)
            dlg.destroy()
            if not raw or raw in _RESERVED_CUSTOM:
                self._err("Invalid or reserved name.")
                return
            suffix = raw
            if suffix in self._cfg.get("_user_modules", []):
                self._err(f"custom/{suffix} already exists.")
                return
            self._cfg.setdefault("_user_modules", []).append(suffix)
            self._cfg[f"custom/{suffix}"] = {
                "format":      "󰘳",
                "exec":        "",
                "return-type": "",
                "interval":    30,
                "on-click":    "",
                "tooltip":     False,
                "_color":      "#a6adc8",
            }
            store = self._w.get("user_mod_store")
            if store:
                store.append([f"custom/{suffix}", f"󰘳  {suffix}", False, False])
                # select the new row so user can edit it immediately
                tv = self._w.get("module_tv")
                if tv:
                    last = store.get_iter(Gtk.TreePath(len(store) - 1))
                    tv.get_selection().select_iter(last)
                    tv.scroll_to_cell(store.get_path(last))
            self._refresh_preview()
        else:
            dlg.destroy()

    def _on_user_mod_remove(self, *_):
        tv = self._w.get("module_tv")
        if not tv:
            return
        model, it = tv.get_selection().get_selected()
        if not it:
            self._show_alert("No module selected", "Select a module from the list first.")
            return
        mod_key    = model[it][0]
        is_dock_app = bool(model[it][3])

        # cffi/ modules — remove directly
        if mod_key.startswith("cffi/"):
            self._cffi_modules.pop(mod_key, None)
            for zone in ("modules-left", "modules-center", "modules-right"):
                for lst, ws in ((self._cfg, self._w), (self._dock_cfg, self._w_dock)):
                    z = lst.get(zone, [])
                    if mod_key in z:
                        z.remove(mod_key)
                    zs = ws.get(f"zone_{zone}")
                    if zs:
                        for row in list(zs):
                            if row[0] == mod_key:
                                zs.remove(row.iter)
                                break
            model.remove(it)
            self._selected_module = None
            self._refresh_preview()
            return

        # group/ modules — remove directly
        if mod_key.startswith("group/"):
            self._groups.pop(mod_key, None)
            for zone in ("modules-left", "modules-center", "modules-right"):
                # bar zones
                lst = self._cfg.get(zone, [])
                if mod_key in lst:
                    lst.remove(mod_key)
                zone_store = self._w.get(f"zone_{zone}")
                if zone_store:
                    for row in list(zone_store):
                        if row[0] == mod_key:
                            zone_store.remove(row.iter)
                            break
                # dock zones
                lst_d = self._dock_cfg.get(zone, [])
                if mod_key in lst_d:
                    lst_d.remove(mod_key)
                zone_store_d = self._w_dock.get(f"zone_{zone}")
                if zone_store_d:
                    for row in list(zone_store_d):
                        if row[0] == mod_key:
                            zone_store_d.remove(row.iter)
                            break
            model.remove(it)
            self._selected_module = None
            self._refresh_preview()
            return

        # Waybar built-in modules — cannot remove
        if not mod_key.startswith("custom/"):
            self._show_alert(
                "Cannot remove built-in module",
                f'"{mod_key}" is a Waybar built-in module. Remove it from Layout instead.')
            return

        suffix = mod_key[7:]

        # Reserved custom modules — cannot remove
        if suffix in _RESERVED_CUSTOM:
            self._show_alert(
                "Cannot remove built-in module",
                f"custom/{suffix} is a built-in custom module. Remove it from Layout if you don't need it.")
            return

        # ── Dock app ──────────────────────────────────────────────────────────
        if is_dock_app:
            self._dock_cfg.pop(mod_key, None)
        else:
            # ── User command (bar) ────────────────────────────────────────────
            user_mods = self._cfg.get("_user_modules", [])
            if suffix in user_mods:
                user_mods.remove(suffix)
            self._cfg.pop(mod_key, None)

        # remove from all zones — both bar and dock (cfg dicts + layout widgets)
        for zone in ("modules-left", "modules-center", "modules-right"):
            lst = self._cfg.get(zone, [])
            if mod_key in lst:
                lst.remove(mod_key)
            zone_store = self._w.get(f"zone_{zone}")
            if zone_store:
                for row in list(zone_store):
                    if row[0] == mod_key:
                        zone_store.remove(row.iter)
                        break
            lst_d = self._dock_cfg.get(zone, [])
            if mod_key in lst_d:
                lst_d.remove(mod_key)
            zone_store_d = self._w_dock.get(f"zone_{zone}")
            if zone_store_d:
                for row in list(zone_store_d):
                    if row[0] == mod_key:
                        zone_store_d.remove(row.iter)
                        break
        # remove row from sidebar store (in-place, no rebuild)
        model.remove(it)
        # clear module panel
        if self._module_panel:
            for child in self._module_panel.get_children():
                self._module_panel.remove(child)
            ph = _lbl("← Select a module", "hint-label")
            ph.set_valign(Gtk.Align.CENTER)
            ph.set_halign(Gtk.Align.CENTER)
            self._module_panel.pack_start(ph, True, True, 0)
            self._module_panel.show_all()
        self._selected_module          = None
        self._selected_module_is_dock  = False
        self._refresh_preview()

    def _on_group_add(self, *_):
        """Create a new group/ module."""
        dlg = Gtk.Dialog(title="New group", parent=self,
                         flags=Gtk.DialogFlags.MODAL)
        dlg.add_buttons("Cancel", Gtk.ResponseType.CANCEL,
                        "Create", Gtk.ResponseType.OK)
        box = dlg.get_content_area()
        box.set_spacing(10)
        box.set_margin_start(16); box.set_margin_end(16)
        box.set_margin_top(12);   box.set_margin_bottom(12)
        box.pack_start(_lbl('Group name (without "group/"):', "field-label"), False, False, 0)
        entry = Gtk.Entry()
        entry.set_placeholder_text("e.g. hardware, power, apps…")
        entry.connect("activate", lambda _: dlg.response(Gtk.ResponseType.OK))
        box.pack_start(entry, False, False, 0)
        box.show_all()

        if dlg.run() == Gtk.ResponseType.OK:
            name = re.sub(r'[^a-zA-Z0-9_\-]', '', entry.get_text().strip())
            dlg.destroy()
            if not name:
                return
            gname = f"group/{name}"
            if gname in self._groups:
                self._show_alert("Already exists", f'"{gname}" is already defined.')
                return
            # create empty group
            self._groups[gname] = {"orientation": "inherit", "modules": []}
            # add to sidebar store
            store = self._w.get("group_store")
            if store:
                # find "Groups" header row and insert after last group row
                groups_end = None
                in_groups  = False
                for i, row in enumerate(store):
                    if row[2] and row[1] == "Groups":
                        in_groups = True
                        groups_end = i
                        continue
                    if in_groups:
                        if row[2]:   # next header → stop
                            break
                        groups_end = i
                if groups_end is not None:
                    it_pos = store.get_iter(Gtk.TreePath(groups_end + 1))
                    store.insert_before(it_pos, [gname, f"󰾮  {name}", False, False])
                else:
                    store.append([gname, f"󰾮  {name}", False, False])
        else:
            dlg.destroy()

    def _on_cffi_add(self, *_):
        """Crear un nuevo cffi/ module."""
        dlg = Gtk.Dialog(title="New CFFI module", parent=self,
                         flags=Gtk.DialogFlags.MODAL)
        dlg.add_buttons("Cancel", Gtk.ResponseType.CANCEL,
                        "Create", Gtk.ResponseType.OK)
        box = dlg.get_content_area()
        box.set_spacing(10)
        box.set_margin_start(16); box.set_margin_end(16)
        box.set_margin_top(12);   box.set_margin_bottom(12)
        box.pack_start(_lbl('Module name (without "cffi/"):', "field-label"), False, False, 0)
        name_entry = Gtk.Entry()
        name_entry.set_placeholder_text("e.g. lyrics, shader, my_plugin…")
        name_entry.connect("activate", lambda _: dlg.response(Gtk.ResponseType.OK))
        box.pack_start(name_entry, False, False, 0)
        box.pack_start(_lbl("Module path (.so):", "field-label"), False, False, 0)
        path_entry = Gtk.Entry()
        path_entry.set_placeholder_text("~/.config/waybar/cffi/module.so")
        path_entry.connect("activate", lambda _: dlg.response(Gtk.ResponseType.OK))
        box.pack_start(path_entry, False, False, 0)
        box.show_all()

        if dlg.run() == Gtk.ResponseType.OK:
            name = re.sub(r'[^a-zA-Z0-9_\-]', '', name_entry.get_text().strip())
            path = path_entry.get_text().strip()
            dlg.destroy()
            if not name:
                return
            cname = f"cffi/{name}"
            if cname in self._cffi_modules:
                self._show_alert("Already exists", f'"{cname}" is already defined.')
                return
            self._cffi_modules[cname] = {"module_path": path}
            # add to sidebar store after "CFFI Modules" header
            store = self._w.get("cffi_store")
            if store:
                cffi_end = None
                in_cffi  = False
                for i, row in enumerate(store):
                    if row[2] and row[1] == "CFFI Modules":
                        in_cffi = True
                        cffi_end = i
                        continue
                    if in_cffi:
                        if row[2]:
                            break
                        cffi_end = i
                if cffi_end is not None:
                    it_pos = store.get_iter(Gtk.TreePath(cffi_end + 1))
                    store.insert_before(it_pos, [cname, f"󱋦  {name}", False, False])
                else:
                    store.append([cname, f"󱋦  {name}", False, False])
            # select the new row immediately
            tv = self._w.get("module_tv")
            if tv and store:
                for i, row in enumerate(store):
                    if row[0] == cname:
                        it = store.get_iter(Gtk.TreePath(i))
                        tv.get_selection().select_iter(it)
                        tv.scroll_to_cell(store.get_path(it))
                        break
        else:
            dlg.destroy()

    def _build_cffi_form(self, cname: str) -> Gtk.Widget:
        """Form for a cffi/name module."""
        ccfg   = self._cffi_modules.setdefault(cname, {})
        suffix = cname[5:]

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        outer.set_margin_start(20); outer.set_margin_end(20)
        outer.set_margin_top(14);   outer.set_margin_bottom(14)

        outer.pack_start(_section(f"cffi/{suffix}"), False, False, 0)
        outer.pack_start(_hint("CFFI — third-party dynamic library widget"), False, False, 4)

        # module_path
        mp_entry = Gtk.Entry()
        mp_entry.set_text(ccfg.get("module_path", ""))
        mp_entry.set_placeholder_text("~/.config/waybar/cffi/module.so")
        self._w["_cffi_path"] = mp_entry
        outer.pack_start(_field("Module path (.so)", mp_entry), False, False, 0)

        # extra keys — free JSON for library-specific options
        extra = {k: v for k, v in ccfg.items() if k != "module_path"}
