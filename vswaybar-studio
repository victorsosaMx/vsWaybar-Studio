    def _make_notebook(self) -> Gtk.Widget:
        nb = Gtk.Notebook()
        nb.set_tab_pos(Gtk.PositionType.LEFT)
        nb.set_show_border(False)
        self._notebook = nb
        self._tab_defs = [
            ("󰕰  Bar",        self._page_bar),
            ("󰝰  Dock",       self._page_dock),
            ("󰕮  Layout",     self._page_layout),
            ("󰒓  Modules",    self._page_modules),
            ("󰏘  Styling",    self._page_styling),
            ("󰈮  Scripts",    self._page_scripts),
            ("󰔎  Templates",  self._page_templates),
            ("󰆦  vsHub",      self._page_hub),
            ("󰋽  About",      self._page_about),
        ]
        self._tabs_built = set()
        self._nb_hub_idx = len(self._tab_defs) - 2  # index of vsHub (before About)
        for label, _ in self._tab_defs:
            placeholder = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            lbl = Gtk.Label(label=label)
            lbl.set_xalign(0)
            nb.append_page(placeholder, lbl)
        nb.connect("switch-page", self._on_tab_switch)
        self._build_tab(0)  # build Bar tab immediately
        return nb

    def _on_tab_switch(self, nb, page, idx):
        if idx not in self._tabs_built:
            self._build_tab(idx)

    def _build_tab(self, idx):
        if idx in self._tabs_built:
            return
        self._tabs_built.add(idx)
        _, builder = self._tab_defs[idx]
        try:
            real_content = builder()
        except Exception as e:
            import traceback
            traceback.print_exc()
            err_lbl = _lbl(f"Error building tab: {e}", "hint-label")
            err_lbl.set_line_wrap(True)
            err_lbl.set_valign(Gtk.Align.CENTER)
            err_lbl.set_halign(Gtk.Align.CENTER)
            placeholder = self._notebook.get_nth_page(idx)
            placeholder.pack_start(err_lbl, True, True, 0)
            placeholder.show_all()
            return
        placeholder = self._notebook.get_nth_page(idx)
        placeholder.pack_start(real_content, True, True, 0)
        placeholder.show_all()

